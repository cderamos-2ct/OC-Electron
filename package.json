{
  "name": "openclaw",
  "version": "0.1.0",
  "private": true,
  "description": "Aegilume — AI agent orchestration platform",
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev:dashboard": "pnpm --filter openclaw-dashboard dev",
    "dev:shell": "pnpm --filter openclaw-shell dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "clean": "pnpm -r exec rm -rf dist node_modules/.cache"
  }
}
