{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "jsx": "react-jsx",
    "paths": {
      "@openclaw/core": ["../openclaw-core/src/index.ts"],
      "@openclaw/core/*": ["../openclaw-core/src/*.ts"]
    }
  },
  "include": ["src"],
  "exclude": ["dist", "node_modules"]
}
