{
  "name": "openclaw-db",
  "version": "0.1.0",
  "private": true,
  "description": "PostgreSQL database layer for OpenClaw — schema, migrations, connection pool, RLS",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./migrations": {
      "import": "./dist/migrations/index.js",
      "types": "./dist/migrations/index.d.ts"
    },
    "./seeds": {
      "import": "./dist/seeds/index.js",
      "types": "./dist/seeds/index.d.ts"
    },
    "./embedding-client": {
      "import": "./dist/embedding-client.js",
      "types": "./dist/embedding-client.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "migrate": "node --loader ts-node/esm src/migrate.ts",
    "seed": "node --loader ts-node/esm src/seed.ts",
    "migrate:up": "node --loader ts-node/esm src/migrate.ts up",
    "migrate:down": "node --loader ts-node/esm src/migrate.ts down",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "pg": "^8.13.3",
    "pg-pool": "^3.7.1",
    "pgvector": "^0.2.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/pg": "^8.11.11",
    "@vitest/coverage-v8": "^3.2.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.0",
    "vitest": "^3.2.1"
  }
}
