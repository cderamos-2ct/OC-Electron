// ── KnowledgeModuleView ──────────────────────────────────────────────────────
function KnowledgeModuleView({ onAskAbout }) {
  const [docs, setDocs] = React.useState([]);
  const [query, setQuery] = React.useState('');
  const [results, setResults] = React.useState([]);
  React.useEffect(() => {
    fetch('/api/knowledge/stats').then(r=>r.json()).then(d=>setDocs(d.documents||[])).catch(()=>{});
