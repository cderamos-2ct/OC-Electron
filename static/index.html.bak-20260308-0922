        React.createElement('button', {onClick: () => handleArchive(selectedMsg.id), style:{background:'var(--surface2)',border:'1px solid var(--border)',borderRadius:6,padding:'4px 10px',fontSize:12,color:'var(--text)',cursor:'pointer'}}, 'Archive'),
        React.createElement('button', {onClick: () => onAskAbout('Handle this message: ' + selectedMsg.subject), style:{background:'transparent',border:'1px solid rgba(34,211,238,0.3)',color:'var(--accent)',borderRadius:6,padding:'4px 10px',fontSize:12,cursor:'pointer'}}, 'Ask AI')
      ),
      // Message body
      React.createElement('div', {style:{padding:'24px 28px',overflowY:'auto',flex:1,fontSize:14,lineHeight:1.7,color:'var(--text)'}},
        bodyLoading ? React.createElement('div', {className:'loading'}, React.createElement('div', {className:'spinner'}))
        : React.createElement('div', {style:{whiteSpace:'pre-wrap'}}, selectedBody || selectedMsg.content || selectedMsg.body || selectedMsg.preview || '')
      )
    );
  }

  // -- Mobile detail view --
  function renderMobileDetail() {
    if (!selectedMsg) return null;
    const sender = selectedMsg.sender || selectedMsg.from_name || 'Unknown';
    return React.createElement('div', {style:{display:'flex',flexDirection:'column',height:'100%'}},
      React.createElement('div', {style:{padding:'12px 16px',borderBottom:'1px solid var(--border)',flexShrink:0}},
