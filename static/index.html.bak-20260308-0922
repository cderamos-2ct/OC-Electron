// ── Widget Strip Component ──────────────────────────────────────────────────
function WidgetStrip({ onOpenInbox, onOpenCalendar, onOpenActions, wsMsg }) {
  const [msgCount, setMsgCount] = React.useState(0);
  const [nextEvent, setNextEvent] = React.useState(null);
  const [pendingActions, setPendingActions] = React.useState(0);
  const [sysStatus, setSysStatus] = React.useState('healthy');

  React.useEffect(() => {
    fetch('/api/messages/filtered?limit=50')
      .then(r => r.json()).then(d => setMsgCount(d.filtered || d.count || 0)).catch(()=>{});
    fetch('/api/calendar?days=1')
      .then(r => r.json()).then(d => {
        const events = d.events || [];
        const now = new Date();
        const upcoming = events.find(e => {
          if (!e.time || e.time === 'All day') return false;
          try {
            const [h, m] = e.time.split(':').map(Number);
            const t = new Date(); t.setHours(h, m, 0, 0);
            return t >= now;
          } catch { return false; }
        }) || events[0];
        setNextEvent(upcoming || null);
      }).catch(()=>{});
    fetch('/api/stats')
      .then(r => r.json()).then(d => setPendingActions(d.pending_actions || 0)).catch(()=>{});
  }, []);

  React.useEffect(() => {
    if (wsMsg?.type === 'heartbeat') setSysStatus(wsMsg.data?.status || 'healthy');
    if (wsMsg?.type === 'new_messages') {
      fetch('/api/messages/filtered?limit=50').then(r=>r.json()).then(d=>setMsgCount(d.filtered||d.count||0)).catch(()=>{});
    }
    if (wsMsg?.type === 'new_actions' || wsMsg?.type === 'action_resolved') {
      fetch('/api/stats').then(r=>r.json()).then(d=>setPendingActions(d.pending_actions||0)).catch(()=>{});
    }
  }, [wsMsg]);

  const sysOk = sysStatus === 'healthy';

  return (
    <div className="widget-strip">
      <div className={`widget-card ${msgCount > 5 ? 'alert' : ''}`} onClick={onOpenInbox}>
        <span className="widget-icon">📬</span>
        <div>
          <div className="widget-value">{msgCount}</div>
          <div className="widget-label">Messages</div>
        </div>
      </div>
      <div className="widget-card" onClick={onOpenCalendar}>
        <span className="widget-icon">📅</span>
        <div>
          <div className="widget-value" style={{fontSize:12}}>{nextEvent ? (nextEvent.time || 'Today') : '\u2014'}</div>
          <div className="widget-sub">{nextEvent ? nextEvent.title : 'No events'}</div>
        </div>
      </div>
      <div className={`widget-card ${pendingActions > 0 ? 'alert' : 'ok'}`} onClick={onOpenActions}>
        <span className="widget-icon">⚡</span>
        <div>
          <div className="widget-value">{pendingActions}</div>
          <div className="widget-label">Actions</div>
        </div>
      </div>
      <div className={`widget-card ${sysOk ? 'ok' : 'alert'}`}>
        <span className="widget-icon">{sysOk ? '🟢' : '🟡'}</span>
        <div>
          <div className="widget-value" style={{fontSize:11,textTransform:'capitalize'}}>{sysStatus}</div>
          <div className="widget-label">System</div>
        </div>
      </div>
    </div>
  );
}

// ── Inbox Tab View Component ────────────────────────────────────────────────
function InboxTabView({ onAskAbout, wsMsg, onOpenCompose }) {
  const [messages, setMessages] = React.useState([]);
  const [selectedId, setSelectedId] = React.useState(null);
  const [selectedBody, setSelectedBody] = React.useState(null);
  const [bodyLoading, setBodyLoading] = React.useState(false);
  const [filter, setFilter] = React.useState('all');
  const [loading, setLoading] = React.useState(true);
  const [isMobile, setIsMobile] = React.useState(window.innerWidth < 768);
  const [hoveredId, setHoveredId] = React.useState(null);

  React.useEffect(() => {
    const onResize = () => setIsMobile(window.innerWidth < 768);
    window.addEventListener('resize', onResize);
    return () => window.removeEventListener('resize', onResize);
  }, []);

  const load = React.useCallback(() => {
    setLoading(true);
    const params = new URLSearchParams({ limit: '40' });
    if (filter === 'high') params.set('priority', 'HIGH');
    if (filter === 'email') params.set('source', 'gmail');
    if (filter === 'imessage') params.set('source', 'imessage');
    fetch('/api/messages/filtered?' + params)
      .then(r=>r.json())
      .then(d=>{ setMessages(d.messages||[]); setLoading(false); })
      .catch(()=>setLoading(false));
  }, [filter]);

  React.useEffect(load, [load]);
  React.useEffect(() => {
    if (wsMsg?.type === 'new_messages') load();
  }, [wsMsg, load]);

  // Fetch body when selected
  React.useEffect(() => {
    if (!selectedId) { setSelectedBody(null); return; }
    const msg = messages.find(m => m.id === selectedId);
    if (!msg) return;
    const src = (msg.source || '').toLowerCase();
    if (src === 'imessage') {
      setSelectedBody(msg.content || msg.body || msg.preview || '');
      return;
    }
    setSelectedBody(null);
    setBodyLoading(true);
    fetch('/api/email/' + selectedId)
      .then(r => r.json())
      .then(d => setSelectedBody(d.content || d.body || msg.content || msg.body || ''))
      .catch(() => setSelectedBody(msg.content || msg.body || ''))
      .finally(() => setBodyLoading(false));
  }, [selectedId]);

  async function handleArchive(id) {
    try {
      await fetch('/api/email/' + id + '/archive', { method: 'POST' });
      setMessages(prev => prev.filter(m => m.id !== id));
      if (selectedId === id) setSelectedId(null);
    } catch(e) {}
  }

  const selectedMsg = messages.find(m => m.id === selectedId);
  const unreadCount = messages.filter(m => !m.read && m.priority !== 'LOW').length;
  const filters = [{id:'all',label:'All'},{id:'email',label:'Email'},{id:'imessage',label:'iMessage'},{id:'high',label:'High'}];

  const filteredMessages = messages;

  // -- Message list column --
  function renderMessageList(fullWidth) {
    return React.createElement('div', {style: {
      width: fullWidth ? '100%' : 340, flexShrink: 0, borderRight: fullWidth ? 'none' : '1px solid var(--border)',
      display: 'flex', flexDirection: 'column', height: '100%'
    }},
      // Sticky header
      React.createElement('div', {style: {height:52,padding:'0 16px',display:'flex',alignItems:'center',justifyContent:'space-between',borderBottom:'1px solid var(--border)',background:'var(--surface)',flexShrink:0}},
        React.createElement('div', {style:{display:'flex',alignItems:'center'}},
          React.createElement('span', {style:{fontSize:15,fontWeight:600}}, 'Inbox'),
          unreadCount > 0 && React.createElement('span', {style:{background:'var(--accent)',color:'#000',fontSize:11,fontWeight:700,padding:'2px 7px',borderRadius:10,marginLeft:8}}, unreadCount)
        ),
        React.createElement('button', {onClick: () => onOpenCompose && onOpenCompose(), style:{background:'var(--accent)',color:'#000',border:'none',borderRadius:6,padding:'4px 10px',fontSize:12,fontWeight:600,cursor:'pointer'}}, '+ Compose')
      ),
      // Filter chips
      React.createElement('div', {style:{padding:'8px 12px',display:'flex',gap:6,overflowX:'auto',scrollbarWidth:'none',borderBottom:'1px solid var(--border)',flexShrink:0}},
        filters.map(f =>
          React.createElement('button', {key:f.id, onClick:()=>setFilter(f.id), style:{
            background:'var(--surface2)',border: filter===f.id ? '1px solid var(--accent)' : '1px solid var(--border)',
            borderRadius:20,fontSize:11,color: filter===f.id ? 'var(--accent)' : 'var(--muted)',padding:'4px 10px',cursor:'pointer',whiteSpace:'nowrap'
          }}, f.label)
        )
      ),
      // Message list
      React.createElement('div', {style:{overflowY:'auto',flex:1}},
        loading ? React.createElement('div', {className:'loading'}, React.createElement('div', {className:'spinner'}))
        : filteredMessages.length === 0 ? React.createElement('div', {className:'empty'}, React.createElement('div', {className:'empty-icon'}, '\uD83D\uDCED'), React.createElement('div', null, 'All caught up'))
        : filteredMessages.map((m, i) => {
          const sender = m.sender || m.from_name || 'Unknown';
          const isSelected = selectedId === m.id;
          const isHovered = hoveredId === m.id;
          const isUnread = !m.read && m.priority !== 'LOW';
          return React.createElement('div', {
            key: m.id || i,
