    fetch('/api/tools')
      .then(r => r.json())
      .then(d => { setTools(d.tools || []); setLoading(false); })
      .catch(() => setLoading(false));
  }, []);

  React.useEffect(() => { if (open) loadTools(); }, [open, loadTools]);

  async function toggleTool(id, enabled) {
    try {
      await fetch(`/api/tools/${id}/toggle`, { method: 'POST' });
      setTools(prev => prev.map(t => t.id === id ? {...t, enabled: enabled ? 0 : 1} : t));
    } catch(e) {}
