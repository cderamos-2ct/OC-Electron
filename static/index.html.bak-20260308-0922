// ── Calendar Panel ──────────────────────────────────────────────────────────
function CalendarPanel({ open, onClose }) {
  const [events, setEvents] = React.useState([]);
  const [raw, setRaw] = React.useState('');
  const [loading, setLoading] = React.useState(true);
  const [days, setDays] = React.useState(7);
  const [showCreate, setShowCreate] = React.useState(false);
  const [newEvent, setNewEvent] = React.useState({ summary:'', date:'', startTime:'09:00', endTime:'10:00', description:'' });

  const load = React.useCallback(() => {
    setLoading(true);
    fetch(`/api/calendar?days=${days}`)
      .then(r=>r.json())
      .then(d=>{ setEvents(d.events||[]); setRaw(d.raw||''); setLoading(false); })
      .catch(()=>setLoading(false));
  }, [days]);

  React.useEffect(()=>{ if(open) load(); }, [open, load]);

  async function createEvent() {
    const { summary, date, startTime, endTime, description } = newEvent;
    if(!summary || !date) return;
    const start_iso = `${date}T${startTime}:00`;
    const end_iso   = `${date}T${endTime}:00`;
    try {
      await fetch('/api/calendar', {
        method:'POST', headers:{'Content-Type':'application/json'},
        body: JSON.stringify({ summary, start_iso, end_iso, description })
      });
      setShowCreate(false);
      setNewEvent({ summary:'', date:'', startTime:'09:00', endTime:'10:00', description:'' });
      setTimeout(load, 1000);
    } catch(e){}
  }

  // Group events by date
  const grouped = events.reduce((acc, e) => {
    if(!acc[e.date]) acc[e.date] = [];
    acc[e.date].push(e);
    return acc;
  }, {});

  if (!open) return null;
  return (
    <>
      <div className="panel-overlay" onClick={onClose}></div>
      <div className="inbox-panel">
        <div className="inbox-drag-handle"></div>
        <div className="inbox-header">
          <span className="inbox-title">📅 Calendar</span>
          <div style={{display:'flex',gap:6,alignItems:'center'}}>
            {[3,7,14].map(d=>(
              <button key={d} className={`filter-pill ${days===d?'active':''}`} onClick={()=>setDays(d)} style={{fontSize:11}}>{d}d</button>
            ))}
          </div>
          <button onClick={()=>setShowCreate(s=>!s)} style={{background:'var(--accent)',color:'#000',border:'none',borderRadius:8,padding:'6px 12px',fontSize:12,fontWeight:700,cursor:'pointer'}}>+ Event</button>
          <button className="inbox-close" onClick={onClose}>&times;</button>
        </div>
        {showCreate && (
          <div style={{padding:'12px 16px',background:'var(--surface2)',borderBottom:'1px solid var(--border)'}}>
            <div style={{display:'grid',gap:8}}>
              <input style={{background:'var(--bg)',border:'1px solid var(--border)',borderRadius:8,padding:'8px 10px',color:'var(--text)',fontSize:13,width:'100%'}}
                placeholder="Event title" value={newEvent.summary} onChange={e=>setNewEvent(p=>({...p,summary:e.target.value}))} />
              <input type="date" style={{background:'var(--bg)',border:'1px solid var(--border)',borderRadius:8,padding:'8px 10px',color:'var(--text)',fontSize:13}}
                value={newEvent.date} onChange={e=>setNewEvent(p=>({...p,date:e.target.value}))} />
              <div style={{display:'flex',gap:8}}>
                <input type="time" style={{flex:1,background:'var(--bg)',border:'1px solid var(--border)',borderRadius:8,padding:'8px',color:'var(--text)',fontSize:13}}
                  value={newEvent.startTime} onChange={e=>setNewEvent(p=>({...p,startTime:e.target.value}))} />
                <span style={{alignSelf:'center',color:'var(--muted)'}}>→</span>
                <input type="time" style={{flex:1,background:'var(--bg)',border:'1px solid var(--border)',borderRadius:8,padding:'8px',color:'var(--text)',fontSize:13}}
                  value={newEvent.endTime} onChange={e=>setNewEvent(p=>({...p,endTime:e.target.value}))} />
              </div>
              <button onClick={createEvent} style={{background:'var(--accent)',color:'#000',border:'none',borderRadius:8,padding:'10px',fontSize:13,fontWeight:700,cursor:'pointer'}}>Create Event</button>
            </div>
          </div>
        )}
        <div className="inbox-content">
          {loading ? <div className="loading"><div className="spinner"></div></div>
          : Object.keys(grouped).length === 0 ? (
            <div className="empty">
              <div className="empty-icon">📅</div>
              <div>No events</div>
              {raw && <div style={{fontSize:11,color:'var(--muted)',marginTop:8,padding:'0 16px',textAlign:'left',whiteSpace:'pre-wrap'}}>{raw}</div>}
            </div>
          ) : Object.entries(grouped).map(([date, dayEvents]) => (
            <div key={date}>
              <div style={{padding:'8px 16px 4px',fontSize:12,fontWeight:700,color:'var(--accent)',letterSpacing:0.5,background:'var(--surface2)',borderBottom:'1px solid var(--border)'}}>{date}</div>
              {dayEvents.map((e,i)=>(
                <div key={i} style={{padding:'10px 16px',borderBottom:'1px solid var(--border)'}}>
                  <div style={{display:'flex',gap:8,alignItems:'center'}}>
                    <span style={{fontSize:11,color:'var(--muted)',minWidth:100,flexShrink:0}}>{e.time}</span>
                    <span style={{fontSize:13,fontWeight:500,color:'var(--text)'}}>{e.title}</span>
                  </div>
                  {e.location && <div style={{fontSize:11,color:'var(--muted)',marginTop:3,paddingLeft:108}}>📍 {e.location}</div>}
                </div>
              ))}
            </div>
          ))}
        </div>
      </div>
    </>
  );
}

// ── Tasks Panel ──────────────────────────────────────────────────────────────
function TasksPanel({ open, onClose }) {
  const [tasks, setTasks] = React.useState([]);
  const [reminders, setReminders] = React.useState([]);
  const [loading, setLoading] = React.useState(true);
  const [tab, setTab] = React.useState('tasks');
  const [newTask, setNewTask] = React.useState('');
  const [newDue, setNewDue] = React.useState('');
  const [newList, setNewList] = React.useState('Tasks - AG');
  const [adding, setAdding] = React.useState(false);
  const [newRemTitle, setNewRemTitle] = React.useState('');
  const [newRemDue, setNewRemDue] = React.useState('');
  const [newRemList, setNewRemList] = React.useState('Reminders');
  const [addingRem, setAddingRem] = React.useState(false);
  const { addToast } = React.useContext(toastContext);

  const load = React.useCallback(() => {
    setLoading(true);
    Promise.all([
      fetch('/api/tasks').then(r=>r.json()).catch(()=>({tasks:[]})),
      fetch('/api/reminders/structured').then(r=>r.json()).catch(()=>({reminders:[]}))
    ]).then(([t,r])=>{ setTasks(t.tasks||[]); setReminders(r.reminders||[]); setLoading(false); });
  }, []);

  React.useEffect(()=>{ if(open) load(); }, [open, load]);

  async function addTask() {
    if(!newTask.trim()) return;
    setAdding(true);
    try {
      await fetch('/api/tasks', {
        method:'POST', headers:{'Content-Type':'application/json'},
        body: JSON.stringify({ title: newTask, due_date: newDue, list: newList })
      });
      setNewTask(''); setNewDue('');
      setTimeout(load, 800);
    } catch(e){}
    setAdding(false);
  }

  async function completeTask(id) {
    try {
      await fetch('/api/tasks/' + id + '/complete', { method:'POST' });
      setTasks(prev => prev.map(t => t.id===id ? {...t, done:true} : t));
    } catch(e){}
  }

  async function deleteTask(id) {
    try {
      await fetch('/api/tasks/' + id, { method:'DELETE' });
      setTasks(prev => prev.filter(t => t.id !== id));
    } catch(e){}
  }

  async function completeReminder(id) {
    try {
      await fetch('/api/reminders/' + id + '/complete', { method:'POST' });
      setReminders(prev => prev.map(r => r.id===id ? {...r, completed:true} : r));
    } catch(e){}
  }

  async function deleteReminder(id) {
    try {
      await fetch('/api/reminders/' + id, { method:'DELETE' });
      setReminders(prev => prev.filter(r => r.id !== id));
    } catch(e){}
  }

  async function addReminder() {
    if(!newRemTitle.trim()) return;
    setAddingRem(true);
    try {
      await fetch('/api/reminders', {
        method:'POST', headers:{'Content-Type':'application/json'},
        body: JSON.stringify({ title: newRemTitle, due_date: newRemDue, list: newRemList })
      });
      setNewRemTitle(''); setNewRemDue('');
      setTimeout(load, 800);
    } catch(e){}
    setAddingRem(false);
  }

  function isOverdue(due) {
    if (!due) return false;
    return new Date(due) < new Date();
  }

  const priorityColor = p => p === 'high' || p === 'HIGH' ? 'var(--red)' : p === 'medium' || p === 'MED' ? 'var(--orange)' : 'var(--muted)';

  if (!open) return null;
  return (
