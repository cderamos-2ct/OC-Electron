              <div key={r.id||i} className="reminder-item" style={{opacity:r.completed?0.5:1}}>
                <div onClick={()=>!r.completed&&r.id&&completeReminder(r.id)} style={{width:20,height:20,borderRadius:4,border:'2px solid '+(r.completed?'var(--green)':'var(--border)'),background:r.completed?'var(--green)':'transparent',cursor:r.completed?'default':'pointer',flexShrink:0,display:'flex',alignItems:'center',justifyContent:'center',marginTop:1}}>
                  {r.completed && <span style={{color:'#000',fontSize:12}}>{'\u2713'}</span>}
