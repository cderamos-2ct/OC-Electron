        <div className="nav-status-row">
          <div className={`status-dot ${wsConnected?'connected':'disconnected'}`} style={{width:6,height:6}} />
          <span style={{fontSize:10}}>{wsConnected ? 'Live' : 'Offline'}</span>
        </div>
      </div>
    </div>
  );
}

// ── AISidebar Component ──────────────────────────────────────────────────────
function AISidebar({ messages, streaming, isTyping, statusMsg, input, setInput, onSend, wsConnected, activeModule, messagesEndRef, inputRef, recording, speaking, supported, onVoiceToggle, onCancel, attachedFile, onClearFile }) {
  const contextChips = {
    inbox:       ['Summarize my inbox', 'Draft a reply to top email', 'Any urgent emails?'],
    calendar:    ['What\'s on my schedule?', 'Prep me for next meeting', 'Any conflicts today?'],
    work:        ['What needs my approval?', 'Prioritize my tasks', 'What\'s overdue?'],
    notes:       ['Summarize my recent notes', 'Find notes about...', 'Create a meeting note'],
    delegations: ['Follow up on delegations', 'What\'s overdue?', 'Summarize team work'],
  }[activeModule] || ['What can I help with?', 'Morning brief', 'What\'s urgent?'];

  const moduleLabel = {
    inbox: 'Email', calendar: 'Calendar', work: 'Work',
    notes: 'Notes', delegations: 'Delegations', actions: 'Actions',
    journal: 'Journal', knowledge: 'Knowledge', docs: 'Documents', projects: 'Projects',
  }[activeModule] || '';

  function handleKeyDown(e) {
    if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); onSend(); }
  }

  function autoResize(e) {
    e.target.style.height = 'auto';
    e.target.style.height = Math.min(e.target.scrollHeight, 100) + 'px';
    setInput(e.target.value);
  }

  return (
    <div className="app-ai-sidebar">
      <div className="app-ai-header">
        <span style={{fontSize:18, color:'var(--accent)'}}>{'\u2726'}</span>
        <span className="app-ai-title">AI Assistant</span>
        {moduleLabel && <span className="app-ai-context-badge">{moduleLabel}</span>}
        <div className={`status-dot ${wsConnected?'connected':'disconnected'}`} style={{width:7,height:7,flexShrink:0}} />
      </div>

      <div className="app-ai-messages">
        {messages.length === 0 && (
          <div style={{color:'var(--muted)',fontSize:12,textAlign:'center',padding:'24px 8px',lineHeight:1.6}}>
            Ask me anything about your email, calendar, tasks, or what's happening today.
          </div>
        )}
        {messages.map((msg, i) => (
          <div key={i} className={`chat-bubble ${msg.role}`}>
            {msg.role === 'assistant'
              ? <span dangerouslySetInnerHTML={{__html: (typeof marked !== 'undefined' ? marked.parse(msg.content || '') : (msg.content || ''))}} />
              : msg.content
            }
          </div>
        ))}
        {isTyping && !streaming && (
          <div className="chat-bubble assistant">
            <div className="typing-indicator"><div className="typing-dot"/><div className="typing-dot"/><div className="typing-dot"/></div>
          </div>
        )}
        {streaming && (
          <div className="chat-bubble assistant" style={{whiteSpace:'pre-wrap'}}>
            {streaming}<span className="stream-cursor">&#8203;</span>
          </div>
        )}
        {statusMsg && (
          <div className="status-msg" style={{fontSize:11}}>
            <div className="spinner" style={{width:12,height:12}}/>
            {statusMsg}
          </div>
        )}
        <div ref={messagesEndRef} />
      </div>

      <div className="app-ai-chips">
        {contextChips.map((chip, i) => (
          <button key={i} className="app-ai-chip" onClick={() => { setInput(chip); setTimeout(() => onSend(chip), 50); }}>
            {chip}
          </button>
        ))}
      </div>

      <div className="app-ai-input-zone">
        {attachedFile && (
          <div style={{fontSize:11,color:'var(--muted)',padding:'4px 0',display:'flex',alignItems:'center',gap:6}}>
            <span>{'\uD83D\uDCCE'} {attachedFile.name}</span>
            <button onClick={onClearFile} style={{background:'none',border:'none',color:'var(--red)',cursor:'pointer',fontSize:12}}>{'\u2715'}</button>
          </div>
        )}
        <div className="app-ai-input-row">
          {supported && (
            <button className={`mic-btn ${recording?'recording':speaking?'speaking':''}`} onClick={onVoiceToggle} style={{flexShrink:0}}>
              {recording ? '\u23F9' : speaking ? '\uD83D\uDD0A' : '\uD83C\uDF99'}
            </button>
          )}
          <textarea
            ref={inputRef}
            className="app-ai-textarea"
            placeholder={wsConnected ? 'Ask anything...' : 'Connecting...'}
            value={input}
            rows={1}
            onChange={autoResize}
            onKeyDown={handleKeyDown}
            disabled={!wsConnected}
          />
          {(isTyping || streaming) ? (
            <button className="stop-btn" onClick={onCancel} style={{width:32,height:32,flexShrink:0}}>{'\u25A0'}</button>
          ) : (
            <button className="app-ai-send" onClick={()=>onSend()} disabled={!input.trim()||!wsConnected}>{'\u25B6'}</button>
          )}
        </div>
      </div>
    </div>
  );
}

