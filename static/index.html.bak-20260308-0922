<script type="text/babel">
const { useState, useEffect, useRef, useCallback, useContext, createContext } = React;

// ── WebSocket Hook ──────────────────────────────────────────────────────────
function useWebSocket(url) {
  const [connected, setConnected] = useState(false);
  const [lastMessage, setLastMessage] = useState(null);
  const wsRef = useRef(null);
  const reconnectRef = useRef(null);

  const connect = useCallback(() => {
    try {
      const ws = new WebSocket(url);
      wsRef.current = ws;
      ws.onopen = () => setConnected(true);
      ws.onclose = () => {
        setConnected(false);
        reconnectRef.current = setTimeout(connect, 3000);
      };
      ws.onmessage = e => {
        try { setLastMessage(JSON.parse(e.data)); } catch {}
      };
      ws.onerror = () => {};
    } catch {}
  }, [url]);

  useEffect(() => { connect(); return () => { wsRef.current?.close(); clearTimeout(reconnectRef.current); }; }, [connect]);

  const send = useCallback(data => {
    if (wsRef.current?.readyState === 1) wsRef.current.send(JSON.stringify(data));
  }, []);

  return { connected, lastMessage, send };
}

// ── Toast System ────────────────────────────────────────────────────────────
const toastContext = createContext({ addToast: () => {} });

function ToastProvider({ children }) {
  const [toasts, setToasts] = useState([]);
  const addToast = useCallback((title, body, urgency = 'normal') => {
    const id = Date.now();
    setToasts(prev => [...prev, { id, title, body, urgency }]);
    if (Notification.permission === 'granted') {
      try { new Notification(title, { body, icon: '/icon-192.png' }); } catch {}
    }
    setTimeout(() => setToasts(prev => prev.filter(t => t.id !== id)), 5000);
  }, []);

  return (
    <toastContext.Provider value={{ addToast }}>
      {children}
      <div className="toast-container">
        {toasts.map(t => (
          <div key={t.id} className={`toast ${t.urgency === 'high' ? 'high' : ''}`}>
            <div className="toast-title">{t.title}</div>
            {t.body && <div className="toast-body">{t.body}</div>}
          </div>
        ))}
      </div>
    </toastContext.Provider>
  );
}

// ── Utilities ────────────────────────────────────────────────────────────────
function timeAgo(ts) {
  if (!ts) return '';
  const d = new Date(ts.includes('T') ? ts : ts + 'Z');
  const s = Math.floor((Date.now() - d.getTime()) / 1000);
  if (s < 60) return 'now';
  if (s < 3600) return `${Math.floor(s/60)}m`;
  if (s < 86400) return `${Math.floor(s/3600)}h`;
  return `${Math.floor(s/86400)}d`;
}

function fmtUptime(s) {
  const h = Math.floor(s / 3600);
  const m = Math.floor((s % 3600) / 60);
  if (h > 24) return `${Math.floor(h/24)}d ${h%24}h`;
  return `${h}h ${m}m`;
}

function scoreCategory(score) {
  if (score >= 75) return 'urgent';
  if (score >= 45) return 'important';
  return 'fyi';
}

// ── Voice Hook ──────────────────────────────────────────────────────────────
function useVoice() {
  const [recording, setRecording] = useState(false);
  const [speaking, setSpeaking] = useState(false);
  const [supported, setSupported] = useState(false);
  const recognitionRef = useRef(null);

  useEffect(() => {
    const SR = window.SpeechRecognition || window.webkitSpeechRecognition;
    setSupported(!!SR);
  }, []);

  const startRecording = useCallback((onResult) => {
    const SR = window.SpeechRecognition || window.webkitSpeechRecognition;
    if (!SR) return;
    const recognition = new SR();
    recognition.continuous = false;
    recognition.interimResults = false;
    recognition.lang = 'en-US';
    recognition.onresult = (e) => {
      const transcript = e.results[0][0].transcript;
      onResult(transcript);
      setRecording(false);
    };
    recognition.onerror = () => setRecording(false);
    recognition.onend = () => setRecording(false);
    recognitionRef.current = recognition;
    recognition.start();
    setRecording(true);
  }, []);

  const stopRecording = useCallback(() => {
    recognitionRef.current?.stop();
    setRecording(false);
  }, []);

  const speak = useCallback((text) => {
    if (!window.speechSynthesis) return;
    window.speechSynthesis.cancel();
    const utterance = new SpeechSynthesisUtterance(text);
    utterance.rate = 1;
    utterance.pitch = 1;
    utterance.onstart = () => setSpeaking(true);
    utterance.onend = () => setSpeaking(false);
    utterance.onerror = () => setSpeaking(false);
    const voices = window.speechSynthesis.getVoices();
    const preferred = voices.find(v => v.name.includes('Samantha') || v.name.includes('Google') || v.name.includes('Natural'));
    if (preferred) utterance.voice = preferred;
    window.speechSynthesis.speak(utterance);
  }, []);

  const stopSpeaking = useCallback(() => {
    window.speechSynthesis?.cancel();
    setSpeaking(false);
  }, []);

  return { recording, speaking, supported, startRecording, stopRecording, speak, stopSpeaking };
}

// ── Briefing Card Component ─────────────────────────────────────────────────
function BriefingCard({ data, onOpenInbox, onChipAction }) {
  if (!data) return null;
  const { greeting, date, urgent = [], important = [], fyi = [], total_messages = 0 } = data;

  function formatItem(item) {
    const text = item.subject || item.content || item.text || item.title || '';
    const sender = item.sender ? ` (${item.sender})` : '';
    return text.slice(0, 80) + sender;
  }

  return (
    <div className="briefing-card">
      <div className="briefing-greeting">
        <div className="briefing-greeting-name">{greeting || 'Good morning'}</div>
        <div className="briefing-greeting-date">{date || new Date().toLocaleDateString('en-US', { weekday: 'long', month: 'short', day: 'numeric' })}</div>
      </div>

      {urgent.length > 0 && (
        <div className="briefing-section urgent">
          <div className="briefing-section-title">&#9889; Urgent</div>
          {urgent.map((item, i) => (
            <div key={i} className="briefing-item">
              <div className="briefing-item-text">{formatItem(item)}</div>
              <div className="briefing-item-actions">
                <button className="briefing-action-btn" onClick={() => onChipAction(`This is urgent - help me handle: ${formatItem(item)}`)}>Handle</button>
                <button className="briefing-action-btn" onClick={() => onChipAction(`Draft a response for: ${formatItem(item)}`)}>Draft</button>
              </div>
            </div>
          ))}
        </div>
      )}

      {important.length > 0 && (
        <div className="briefing-section important">
          <div className="briefing-section-title">&#128204; Important</div>
          {important.map((item, i) => (
            <div key={i} className="briefing-item">
              <div className="briefing-item-text">{formatItem(item)}</div>
              <div className="briefing-item-actions">
                {item.source === 'calendar' && (
                  <button className="briefing-action-btn" onClick={() => onChipAction(`Give me a pre-meeting brief for: ${formatItem(item)}`)}>Brief me</button>
                )}
                <button className="briefing-action-btn" onClick={() => onChipAction(`Help me with: ${formatItem(item)}`)}>Handle</button>
              </div>
            </div>
          ))}
        </div>
      )}

      {fyi.length > 0 && (
        <div className="briefing-section fyi">
          <div className="briefing-section-title">&#8505;&#65039; FYI</div>
          {fyi.map((item, i) => (
            <div key={i} className="briefing-item">
              <div className="briefing-item-text" style={{ color: 'var(--muted)' }}>{formatItem(item)}</div>
            </div>
          ))}
        </div>
      )}

      <button className="briefing-inbox-btn" onClick={onOpenInbox}>
        Show full inbox ({total_messages} messages) &#8594;
      </button>
    </div>
  );
}

// ── Inbox Panel Component ───────────────────────────────────────────────────
function InboxPanel({ open, onClose, onHandleMessage, wsMsg, onOpenCompose }) {
  const [messages, setMessages] = useState([]);
  const [filter, setFilter] = useState('all');
  const [search, setSearch] = useState('');
  const [loading, setLoading] = useState(true);
  const [refreshing, setRefreshing] = useState(false);
  const [lastSync, setLastSync] = useState(null);
  const [expandedId, setExpandedId] = useState(null);

  const fetchMessages = useCallback(async () => {
    try {
      const params = new URLSearchParams({ limit: '50' });
      if (filter === 'spam') {
        params.set('source', 'spam');
      } else {
        if (filter !== 'all') params.set('source', filter);
      }
      if (search) params.set('search', search);
      const res = await fetch(`/api/messages?${params}`);
      const data = await res.json();
      setMessages(data.messages || []);
    } catch(e) {}
    setLoading(false);
  }, [filter, search]);

  useEffect(() => {
    if (!open) return;
    setLoading(true);
    fetchMessages();
  }, [open, fetchMessages]);

  useEffect(() => {
    if (!open) return;
    const i = setInterval(fetchMessages, 30000);
    return () => clearInterval(i);
  }, [open, fetchMessages]);

  useEffect(() => {
    if (wsMsg?.type === 'new_messages' && open) fetchMessages();
  }, [wsMsg, open, fetchMessages]);

  async function handleRefresh() {
    setRefreshing(true);
    try {
      const res = await fetch('/api/refresh', { method: 'POST' });
      const data = await res.json();
      setLastSync(new Date().toLocaleTimeString([], { hour: 'numeric', minute: '2-digit' }));
      if (data.ingested > 0) await fetchMessages();
    } catch(e) {}
    setRefreshing(false);
  }

  function toggleExpand(id) {
    setExpandedId(prev => prev === id ? null : id);
  }

  function handleReply(msg) {
    const context = `Reply to ${msg.sender} about: ${msg.subject || msg.content?.slice(0, 60) || 'their message'}`;
    onHandleMessage(context);
    onClose();
  }

  function handleHandle(msg) {
    const context = `Handle this message from ${msg.sender}: ${msg.subject || ''} - ${msg.content?.slice(0, 100) || ''}`;
    onHandleMessage(context);
    onClose();
  }

  async function handleSpam(msg) {
    try {
      await fetch(`/api/messages/${msg.id}/spam`, { method: 'POST' });
      setMessages(prev => prev.filter(m => m.id !== msg.id));
    } catch(e) {}
  }

  async function handleNotSpam(msg) {
    try {
      await fetch(`/api/messages/${msg.id}/not-spam`, { method: 'POST' });
      setMessages(prev => prev.filter(m => m.id !== msg.id));
    } catch(e) {}
  }

  async function handleUnsubscribe(msg) {
    try {
      await fetch(`/api/messages/${msg.id}/unsubscribe`, { method: 'POST' });
      setMessages(prev => prev.filter(m => m.id !== msg.id));
    } catch(e) {}
  }

  const filters = [
    { id: 'all', label: 'All' },
    { id: 'gmail', label: 'Gmail' },
    { id: 'imessage', label: 'iMessage' },
    { id: 'calendar', label: 'Calendar' },
    { id: 'teams', label: 'Teams' },
    { id: 'spam', label: '🚫 Spam' }
  ];

  if (!open) return null;

  return (
    <>
      <div className="panel-overlay" onClick={onClose}></div>
      <div className="inbox-panel">
        <div className="inbox-drag-handle"></div>
        <div className="inbox-header">
          <span className="inbox-title">Inbox</span>
          <span style={{ fontSize: 12, color: 'var(--muted)' }}>{messages.length} messages</span>
          <button onClick={handleRefresh} disabled={refreshing}
            style={{
              background: 'var(--accent)', color: '#000', border: 'none', borderRadius: 8,
              padding: '6px 12px', fontSize: 12, fontWeight: 700, cursor: 'pointer',
              opacity: refreshing ? 0.6 : 1
            }}>
            {refreshing ? '\u27F3' : '\u21BB'} Sync
          </button>
          <button className="inbox-close" onClick={onClose}>&times;</button>
          <div className="inbox-filters">
            {filters.map(f => (
              <button key={f.id} className={`filter-pill ${filter === f.id ? 'active' : ''}`} onClick={() => setFilter(f.id)}>{f.label}</button>
            ))}
          </div>
        </div>

        <div style={{ padding: '8px 16px' }}>
          <input className="search-input" placeholder="Search messages..." value={search}
            onChange={e => setSearch(e.target.value)}
            onKeyDown={e => e.key === 'Enter' && fetchMessages()} />
          {lastSync && <div style={{ fontSize: 11, color: 'var(--muted)', marginTop: 4 }}>Last synced: {lastSync}</div>}
        </div>

        <div className="inbox-content">
          {loading ? (
            <div className="loading"><div className="spinner"></div></div>
          ) : messages.length === 0 ? (
            <div className="empty">
              <div className="empty-icon">&#128237;</div>
              <div>No messages</div>
              <div style={{ marginTop: 8 }}>
                <button onClick={handleRefresh}
                  style={{ background: 'var(--accent)', color: '#000', border: 'none', borderRadius: 8, padding: '8px 20px', fontSize: 13, fontWeight: 700, cursor: 'pointer' }}>
                  Sync Now
                </button>
              </div>
            </div>
          ) : messages.map((m, i) => {
            const isExpanded = expandedId === (m.id || i);
            const cat = scoreCategory(m.score || (m.priority === 'HIGH' ? 80 : m.priority === 'MED' ? 55 : 25));
            return (
              <div key={m.id || i} className={`msg-item ${isExpanded ? 'expanded' : ''}`} onClick={() => toggleExpand(m.id || i)}>
                <div className="msg-row">
                  <div className={`msg-priority ${m.priority || ''}`}></div>
                  <div className="msg-body">
                    <div className="msg-top">
                      <div style={{ display: 'flex', gap: 6, alignItems: 'center' }}>
                        <span className="msg-sender">{m.sender}</span>
                        <span className="msg-source">{m.source}</span>
                        <span className={`msg-score ${cat}`}>{m.score ? m.score : m.priority || ''}</span>
                      </div>
                      <span className="msg-time">{timeAgo(m.timestamp)}</span>
                    </div>
                    {m.subject && <div className="msg-subject">{m.subject}</div>}
                    <div className="msg-content-preview">{m.content}</div>
                    <div className="msg-full-content">{m.content}</div>
                    <div className="msg-actions-row">
                      <button className="msg-action-btn" onClick={e => { e.stopPropagation(); handleReply(m); }}>Reply</button>
                      <button className="msg-action-btn" onClick={e => { e.stopPropagation(); handleHandle(m); }}>Handle this</button>
                      <button className="msg-action-btn" onClick={e => { e.stopPropagation(); if(onOpenCompose) onOpenCompose({to:m.sender||'',subject:m.subject||'',context:m.content||''}); }}>Draft Reply</button>
                      <button className="msg-action-btn" onClick={e => { e.stopPropagation(); fetch('/api/email/'+(m.id)+'/archive',{method:'POST'}).then(()=>setMessages(prev=>prev.filter(x=>x.id!==m.id))).catch(()=>{}); }} style={{color:'var(--muted)'}}>Archive</button>
                      <button className="msg-action-btn spam-btn" onClick={e => { e.stopPropagation(); fetch('/api/email/'+(m.id)+'/trash',{method:'POST'}).then(()=>setMessages(prev=>prev.filter(x=>x.id!==m.id))).catch(()=>{}); }}>Trash</button>
                      {filter !== 'spam' && (
                        <button className="msg-action-btn spam-btn" onClick={e => { e.stopPropagation(); handleSpam(m); }} title="Mark as spam">{'\uD83D\uDEAB'}</button>
                      )}
                      {filter !== 'spam' && m.source === 'gmail' && (
                        <button className="msg-action-btn unsub-btn" onClick={e => { e.stopPropagation(); handleUnsubscribe(m); }} title="Unsubscribe">{'\uD83D\uDCE7'} Unsub</button>
                      )}
                      {filter === 'spam' && (
                        <button className="msg-action-btn" onClick={e => { e.stopPropagation(); handleNotSpam(m); }}>Not spam</button>
                      )}
                    </div>
                  </div>
                </div>
              </div>
            );
          })}
        </div>
      </div>
    </>
  );
}

// ── Standing Orders Panel ────────────────────────────────────────────────────
function StandingOrdersPanel({ open, onClose }) {
  const [orders, setOrders] = React.useState([]);
  const [newRule, setNewRule] = React.useState('');
  const [autoExec, setAutoExec] = React.useState(false);
  const [priority, setPriority] = React.useState('MED');
  const [loading, setLoading] = React.useState(false);

  React.useEffect(() => {
    if (open) fetchOrders();
  }, [open]);

  const fetchOrders = async () => {
    try {
      const r = await fetch('/api/standing-orders');
      const d = await r.json();
      setOrders(d.orders || []);
    } catch(e) {}
  };

  const addOrder = async () => {
    if (!newRule.trim()) return;
    setLoading(true);
    try {
      await fetch('/api/standing-orders', {
        method: 'POST',
        headers: {'Content-Type':'application/json'},
        body: JSON.stringify({rule_text: newRule, auto_execute: autoExec ? 1 : 0, priority})
      });
      setNewRule('');
      await fetchOrders();
    } catch(e) {}
    setLoading(false);
  };

  const deleteOrder = async (id) => {
    try {
      await fetch(`/api/standing-orders/${id}`, {method: 'DELETE'});
      setOrders(o => o.filter(x => x.id !== id));
    } catch(e) {}
  };

  if (!open) return null;
  return (
    <div className="panel-overlay" onClick={onClose}>
      <div className="inbox-panel" onClick={e => e.stopPropagation()} style={{background:'var(--surface)'}}>
        <div className="inbox-drag-handle"></div>
        <div className="inbox-header">
          <span className="inbox-title">📋 Standing Orders</span>
          <button className="inbox-close" onClick={onClose}>&times;</button>
        </div>
        <div style={{padding:'12px 16px',borderBottom:'1px solid rgba(255,255,255,0.08)'}}>
          <p style={{color:'var(--muted)',fontSize:'12px',margin:'0 0 12px'}}>
            Rules that auto-evaluate every incoming message
          </p>
          <textarea
            value={newRule}
            onChange={e => setNewRule(e.target.value)}
            placeholder='e.g. "When I get an email from Hatco, alert me immediately"'
            rows={2}
            style={{width:'100%',background:'rgba(255,255,255,0.06)',border:'1px solid rgba(34,211,238,0.3)',
              borderRadius:'8px',color:'var(--text)',padding:'8px 10px',fontSize:'13px',resize:'none',
              fontFamily:'inherit',boxSizing:'border-box'}}
          />
          <div style={{display:'flex',gap:'8px',marginTop:'8px',alignItems:'center'}}>
            <select value={priority} onChange={e => setPriority(e.target.value)}
              style={{background:'rgba(255,255,255,0.06)',border:'1px solid rgba(255,255,255,0.1)',
                color:'var(--text)',borderRadius:'6px',padding:'6px 8px',fontSize:'12px'}}>
              <option value="HIGH">🔴 High</option>
              <option value="MED">🟡 Medium</option>
              <option value="LOW">🟢 Low</option>
            </select>
            <label style={{display:'flex',alignItems:'center',gap:'4px',fontSize:'12px',color:'var(--muted)',cursor:'pointer'}}>
              <input type="checkbox" checked={autoExec} onChange={e => setAutoExec(e.target.checked)} />
              Auto-execute
            </label>
            <button onClick={addOrder} disabled={loading || !newRule.trim()}
              style={{marginLeft:'auto',background:'var(--accent)',color:'#000',border:'none',
                borderRadius:'8px',padding:'7px 16px',fontSize:'13px',cursor:'pointer',
                opacity: (!newRule.trim() || loading) ? 0.5 : 1}}>
              {loading ? '...' : '+ Add Rule'}
            </button>
          </div>
        </div>
        <div style={{overflowY:'auto',flex:1}}>
          {orders.length === 0 && (
            <div style={{padding:'32px',textAlign:'center',color:'var(--muted)',fontSize:'13px'}}>
              No standing orders yet.<br/>Add your first rule above.
            </div>
          )}
          {orders.map(o => (
            <div key={o.id} style={{padding:'12px 16px',borderBottom:'1px solid rgba(255,255,255,0.05)',
              display:'flex',alignItems:'flex-start',gap:'10px'}}>
              <div style={{flex:1}}>
                <div style={{fontSize:'13px',color:'var(--text)',marginBottom:'4px'}}>{o.rule_text}</div>
                <div style={{fontSize:'11px',color:'var(--muted)',display:'flex',gap:'8px'}}>
                  <span style={{color: o.priority==='HIGH'?'#f87171':o.priority==='LOW'?'#34d399':'#fbbf24'}}>
                    {o.priority}
                  </span>
                  {o.auto_execute ? <span>⚡ auto</span> : <span>🔔 notify</span>}
                  {o.trigger_count > 0 && <span>triggered {o.trigger_count}×</span>}
                  {o.last_triggered && <span>last: {o.last_triggered?.slice(5,16)}</span>}
                </div>
              </div>
              <button onClick={() => deleteOrder(o.id)}
                style={{background:'none',border:'none',color:'var(--muted)',cursor:'pointer',
                  fontSize:'16px',padding:'0',lineHeight:'1'}}>✕</button>
            </div>
          ))}
        </div>
      </div>
    </div>
  );
}

// ── Notification Panel ──────────────────────────────────────────────────────
function NotifPanel({ open, onClose }) {
  const [notifs, setNotifs] = useState([]);

  useEffect(() => {
    if (!open) return;
    fetch('/api/notifications?unread_only=false&limit=30')
      .then(r => r.json())
      .then(d => setNotifs(d.notifications || []))
      .catch(() => {});
  }, [open]);

  function handleMarkRead() {
    fetch('/api/notifications/read', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: '{}' });
    setNotifs(prev => prev.map(n => ({ ...n, read: 1 })));
  }

  return (
    <>
      <div className={`notif-overlay ${open ? 'open' : ''}`} onClick={onClose}></div>
      <div className={`notif-panel ${open ? 'open' : ''}`}>
        <div className="notif-header">
          <span className="notif-title">Notifications</span>
          <div style={{ display: 'flex', gap: 12, alignItems: 'center' }}>
            <button style={{ background: 'none', border: 'none', color: 'var(--accent)', fontSize: 12, cursor: 'pointer' }} onClick={handleMarkRead}>Mark all read</button>
            <button className="notif-close" onClick={onClose}>&times;</button>
          </div>
        </div>
        <div className="notif-list">
          {notifs.length === 0 ? (
            <div className="empty" style={{ padding: 40 }}><div>No notifications</div></div>
          ) : notifs.map(n => (
            <div key={n.id} className={`notif-item ${n.read ? '' : 'unread'}`}>
              <div className="notif-item-title">{n.title}</div>
              <div className="notif-item-body">{n.body}</div>
              <div className="notif-item-time">{timeAgo(n.created_at)}</div>
            </div>
          ))}
        </div>
      </div>
    </>
  );
}

// ── Journal Panel ───────────────────────────────────────────────────────────
function JournalPanel({ open, onClose }) {
  const [entries, setEntries] = React.useState([]);
  const [loading, setLoading] = React.useState(true);
  const [filter, setFilter] = React.useState('all');

  React.useEffect(() => {
    if (!open) return;
    setLoading(true);
    fetch('/api/journal?limit=100')
      .then(r => r.json())
      .then(d => { setEntries(d.entries || []); setLoading(false); })
      .catch(() => setLoading(false));
  }, [open]);

  const sources = ['all', 'chat', 'heartbeat', 'ingestion', 'dashboard'];
  const sourceIcon = s => ({ chat:'💬', heartbeat:'💓', ingestion:'📥', dashboard:'⚡' }[s] || '📋');
  const filtered = filter === 'all' ? entries : entries.filter(e => e.source === filter || e.session_type === filter);

  if (!open) return null;
  return (
