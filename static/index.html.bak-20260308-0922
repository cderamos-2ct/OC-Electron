// ── Delegation Panel ────────────────────────────────────────────────────────
function DelegationPanel({ open, onClose }) {
  const [delegations, setDelegations] = React.useState([]);
  const [loading, setLoading] = React.useState(true);
  const [showAdd, setShowAdd] = React.useState(false);
  const [person, setPerson] = React.useState('');
  const [task, setTask] = React.useState('');
  const [dueDate, setDueDate] = React.useState('');
  const [notes, setNotes] = React.useState('');
  const [adding, setAdding] = React.useState(false);

  const load = React.useCallback(() => {
    setLoading(true);
    fetch('/api/delegations')
      .then(r => r.json())
      .then(d => { setDelegations(d.delegations || d.items || []); setLoading(false); })
      .catch(() => { setDelegations([]); setLoading(false); });
  }, []);

  React.useEffect(() => { if (open) load(); }, [open, load]);

  async function addDelegation() {
    if (!person.trim() || !task.trim()) return;
    setAdding(true);
    try {
      await fetch('/api/delegations', {
        method: 'POST', headers: {'Content-Type':'application/json'},
        body: JSON.stringify({ person, task, due_date: dueDate, notes })
      });
      setPerson(''); setTask(''); setDueDate(''); setNotes('');
      setShowAdd(false);
      load();
    } catch(e) {}
    setAdding(false);
  }

  async function toggleStatus(id, currentStatus) {
    const newStatus = currentStatus === 'done' ? 'pending' : 'done';
    try {
      await fetch('/api/delegations/' + id, {
        method: 'PUT', headers: {'Content-Type':'application/json'},
        body: JSON.stringify({ status: newStatus })
      });
      setDelegations(prev => prev.map(d => d.id === id ? { ...d, status: newStatus } : d));
    } catch(e) {}
  }

  async function deleteDelegation(id) {
    try {
      await fetch('/api/delegations/' + id, { method: 'DELETE' });
      setDelegations(prev => prev.filter(d => d.id !== id));
    } catch(e) {}
  }

  function isOverdue(due) {
    if (!due) return false;
    return new Date(due) < new Date() && new Date(due).toDateString() !== new Date().toDateString();
  }

  function getEffectiveStatus(d) {
    if (d.status === 'done') return 'done';
    if (isOverdue(d.due_date || d.due)) return 'overdue';
    return 'pending';
  }

  if (!open) return null;
  return (
    <>
      <div className="panel-overlay" onClick={onClose}></div>
      <div className="inbox-panel">
        <div className="inbox-drag-handle"></div>
        <div className="inbox-header">
          <span className="inbox-title">Delegations</span>
          <button onClick={() => setShowAdd(!showAdd)}
            style={{background:'var(--accent)',color:'#000',border:'none',borderRadius:8,padding:'6px 12px',fontSize:12,fontWeight:700,cursor:'pointer'}}>
            {showAdd ? 'Cancel' : '+ Add'}
          </button>
          <button className="inbox-close" onClick={onClose}>&times;</button>
        </div>
        {showAdd && (
          <div className="delegation-add-form">
            <div style={{display:'grid',gap:8}}>
              <input placeholder="Person name" value={person} onChange={e=>setPerson(e.target.value)}
                style={{background:'var(--bg)',border:'1px solid var(--border)',borderRadius:8,padding:'8px 10px',color:'var(--text)',fontSize:13,width:'100%'}} />
              <input placeholder="Task description" value={task} onChange={e=>setTask(e.target.value)}
                style={{background:'var(--bg)',border:'1px solid var(--border)',borderRadius:8,padding:'8px 10px',color:'var(--text)',fontSize:13,width:'100%'}} />
              <div style={{display:'flex',gap:8}}>
                <input type="date" value={dueDate} onChange={e=>setDueDate(e.target.value)}
                  style={{flex:1,background:'var(--bg)',border:'1px solid var(--border)',borderRadius:8,padding:'8px',color:'var(--text)',fontSize:13}} />
                <input placeholder="Notes (optional)" value={notes} onChange={e=>setNotes(e.target.value)}
                  style={{flex:2,background:'var(--bg)',border:'1px solid var(--border)',borderRadius:8,padding:'8px 10px',color:'var(--text)',fontSize:13}} />
              </div>
              <button onClick={addDelegation} disabled={adding || !person.trim() || !task.trim()}
                style={{background:'var(--accent)',color:'#000',border:'none',borderRadius:8,padding:'10px',fontSize:13,fontWeight:700,cursor:'pointer',opacity:(adding||!person.trim()||!task.trim())?0.5:1}}>
                {adding ? 'Adding...' : 'Add Delegation'}
              </button>
            </div>
          </div>
        )}
        <div className="inbox-content" style={{padding:12}}>
          {loading ? <div className="loading"><div className="spinner"></div></div>
          : delegations.length === 0 ? (
            <div className="empty">
              <div className="empty-icon">&#129309;</div>
              <div>No delegations tracked</div>
              <div style={{fontSize:12,color:'var(--muted)',marginTop:4}}>Tap + Add to track a delegated task</div>
            </div>
          ) : delegations.map((d, i) => {
            const es = getEffectiveStatus(d);
            const due = d.due_date || d.due || '';
            return (
              <div key={d.id || i} className="delegation-card" style={{opacity: d.status === 'done' ? 0.6 : 1}}>
                <div className="delegation-person">{d.person}</div>
                <div className="delegation-task">{d.task}</div>
                <div className="delegation-meta">
                  <button className={'delegation-status ' + es} onClick={() => toggleStatus(d.id, d.status)}>
                    {es === 'done' ? 'Done' : es === 'overdue' ? 'Overdue' : 'Pending'}
                  </button>
                  {due && <span style={{color: isOverdue(due) ? 'var(--red)' : 'var(--muted)'}}>Due: {due}</span>}
                  {d.notes && <span style={{color:'var(--muted)'}}>{d.notes}</span>}
                  <button onClick={() => deleteDelegation(d.id)} style={{background:'none',border:'none',color:'var(--red)',cursor:'pointer',fontSize:14,marginLeft:'auto'}}>&#128465;</button>
                </div>
              </div>
            );
          })}
        </div>
      </div>
    </>
  );
}

// ── Calendar Tab View Component (Week View) ─────────────────────────────────
function CalendarTabView({ onAskAbout }) {
  const [weekOffset, setWeekOffset] = React.useState(0);
  const [events, setEvents] = React.useState([]);
  const [loading, setLoading] = React.useState(true);
  const [selectedEvent, setSelectedEvent] = React.useState(null);
  const [showAddForm, setShowAddForm] = React.useState(false);
  const [newEvent, setNewEvent] = React.useState({title:'', date:'', start:'', end:''});
  const CELL_H = 52;

  // ── local date string (no UTC offset issues) ──────────────────────────────
  function localDateStr(d) {
    return d.getFullYear() + '-' +
      String(d.getMonth()+1).padStart(2,'0') + '-' +
      String(d.getDate()).padStart(2,'0');
  }

  const today = new Date();
  today.setHours(0,0,0,0);
  const todayStr = localDateStr(today);

  // ── robust parse of "Thu Feb 26" → local ISO string ──────────────────────
  const MONTHS = {Jan:0,Feb:1,Mar:2,Apr:3,May:4,Jun:5,Jul:6,Aug:7,Sep:8,Oct:9,Nov:10,Dec:11};
  function parseEventDate(evt) {
    if (evt.start && evt.start.includes('T')) return localDateStr(new Date(evt.start));
    if (evt.date) {
      const m = evt.date.match(/([A-Za-z]{3})\s+(\d{1,2})/);
      if (m && MONTHS[m[1]] !== undefined) {
        const yr = new Date().getFullYear();
        const d = new Date(yr, MONTHS[m[1]], parseInt(m[2]));
        // if more than 60 days in the past, it's next year (year boundary)
        if ((d - new Date()) < -60 * 86400000) d.setFullYear(yr + 1);
        return localDateStr(d);
      }
    }
    return todayStr;
  }

  // ── parse time range "09:00 AM-10:00 AM" → {startH,startM,endH,endM} ─────
  function parseTime(evt) {
    let startH=9, startM=0, endH=10, endM=0;
    try {
      if (evt.start && evt.start.includes('T')) {
        const sd = new Date(evt.start);
        startH=sd.getHours(); startM=sd.getMinutes();
        if (evt.end && evt.end.includes('T')) {
          const ed = new Date(evt.end);
          endH=ed.getHours(); endM=ed.getMinutes();
        } else { endH=startH+1; }
      } else if (evt.time) {
        const rm = evt.time.match(/(\d{1,2}):(\d{2})\s*(AM|PM)\s*[-–]\s*(\d{1,2}):(\d{2})\s*(AM|PM)/i);
        if (rm) {
          startH=parseInt(rm[1]); startM=parseInt(rm[2]);
          if (rm[3].toUpperCase()==='PM' && startH<12) startH+=12;
          if (rm[3].toUpperCase()==='AM' && startH===12) startH=0;
          endH=parseInt(rm[4]); endM=parseInt(rm[5]);
          if (rm[6].toUpperCase()==='PM' && endH<12) endH+=12;
          if (rm[6].toUpperCase()==='AM' && endH===12) endH=0;
        } else {
          const m = evt.time.match(/(\d{1,2}):(\d{2})\s*(AM|PM)?/i);
          if (m) {
            startH=parseInt(m[1]); startM=parseInt(m[2]);
            if (m[3]?.toUpperCase()==='PM' && startH<12) startH+=12;
            if (m[3]?.toUpperCase()==='AM' && startH===12) startH=0;
            endH=startH+1;
          }
        }
      }
    } catch(e) {}
    return {startH,startM,endH,endM};
  }

  function fmt12(h,m) {
    const ap = h>=12?'PM':'AM';
    const h12 = h===0?12:h>12?h-12:h;
    return `${h12}:${String(m).padStart(2,'0')} ${ap}`;
  }

  // ── overlap layout: assign columns to simultaneous events ─────────────────
  function layoutDay(evts) {
    if (!evts.length) return [];
    const items = evts.map(e => { const t=parseTime(e); return {...e, _s:t.startH*60+t.startM, _e:t.endH*60+t.endM}; });
    items.sort((a,b)=>a._s-b._s);
    // assign columns
    const colEnds = [];
    items.forEach(ev => {
      let col = colEnds.findIndex(end => end <= ev._s);
      if (col === -1) { col = colEnds.length; }
      colEnds[col] = ev._e;
      ev._col = col;
    });
    const totalCols = colEnds.length;
    // expand each event to fill unused adjacent columns
    items.forEach(ev => {
      let span = 1;
      while (ev._col + span < totalCols) {
        const blocked = items.some(o => o !== ev && o._col === ev._col + span && o._s < ev._e && o._e > ev._s);
        if (blocked) break;
        span++;
      }
      ev._span = span;
      ev._total = totalCols;
    });
    return items;
  }

  // ── meeting type detection ─────────────────────────────────────────────────
  function meetingInfo(evt) {
    const loc = (evt.location||'').toLowerCase();
    const isTeams = loc.includes('teams') || loc.includes('microsoft teams');
    const isZoom  = loc.includes('zoom');
    const isMeet  = loc.includes('meet.google') || loc.includes('google meet');
    const type    = isTeams?'teams':isZoom?'zoom':isMeet?'meet':null;
    const link    = (evt.location||'').startsWith('http') ? evt.location : null;
    const color   = type==='teams'?'#7B83EB':type==='zoom'?'#2D8CFF':type==='meet'?'#34A853':'#22d3ee';
    return {type, link, color};
  }

  // ── week days ─────────────────────────────────────────────────────────────
  function getWeekDays(offset) {
    const now = new Date(); now.setHours(0,0,0,0);
    const dow = now.getDay();
    const monday = new Date(now);
    monday.setDate(now.getDate() - (dow===0?6:dow-1) + offset*7);
    return Array.from({length:7}, (_,i) => {
      const d = new Date(monday); d.setDate(monday.getDate()+i); return d;
    });
  }
  const weekDays = getWeekDays(weekOffset);
  const MO = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
  const DN = ['SUN','MON','TUE','WED','THU','FRI','SAT'];
  const first=weekDays[0], last=weekDays[6];
  const weekLabel = first.getMonth()===last.getMonth()
    ? `${MO[first.getMonth()]} ${first.getDate()} – ${last.getDate()}, ${last.getFullYear()}`
    : `${MO[first.getMonth()]} ${first.getDate()} – ${MO[last.getMonth()]} ${last.getDate()}, ${last.getFullYear()}`;

  function eventsForDay(d) {
    const ds = localDateStr(d);
    return events.filter(e => parseEventDate(e) === ds);
  }

  // ── load events ───────────────────────────────────────────────────────────
  React.useEffect(() => {
    setLoading(true);
    // fetch the viewed week (supports past navigation)
    const start = localDateStr(weekDays[0]);
    const end   = localDateStr(weekDays[6]);
    fetch(`/api/calendar/range?start=${start}&end=${end}`)
      .then(r=>r.json())
      .then(d=>setEvents(d.events||[]))
      .catch(()=>{})
      .finally(()=>setLoading(false));
  }, [weekOffset]);

  const HOURS = Array.from({length:17}, (_,i)=>i+6); // 6 AM – 10 PM
  const todayEvts = eventsForDay(today);
  const weekTotal = weekDays.reduce((s,d)=>s+eventsForDay(d).length,0);

  // ── Event Detail Panel ────────────────────────────────────────────────────
  function EventDetail({evt}) {
    const {startH,startM,endH,endM} = parseTime(evt);
    const {type,link,color} = meetingInfo(evt);
    const dur = (endH*60+endM) - (startH*60+startM);
    const durLabel = dur>=60 ? `${Math.floor(dur/60)}h${dur%60?` ${dur%60}m`:''}` : `${dur}m`;
    const typeLabel = {teams:'Microsoft Teams',zoom:'Zoom',meet:'Google Meet'}[type]||null;
    return (
      <div style={{position:'absolute',top:0,right:0,bottom:0,width:270,background:'var(--surface)',
        borderLeft:'1px solid var(--border)',display:'flex',flexDirection:'column',zIndex:20,boxShadow:'-4px 0 16px rgba(0,0,0,0.3)'}}>
        {/* Header */}
        <div style={{padding:'14px 16px 12px',borderBottom:'1px solid var(--border)',display:'flex',justifyContent:'space-between',alignItems:'flex-start',gap:8}}>
          <div style={{fontSize:13,fontWeight:600,color:'var(--text)',lineHeight:1.4,flex:1}}>{evt.title||evt.summary}</div>
          <button onClick={()=>setSelectedEvent(null)} style={{background:'none',border:'none',color:'var(--muted)',fontSize:20,cursor:'pointer',lineHeight:1,padding:0,marginTop:-2}}>×</button>
        </div>
        {/* Body */}
        <div style={{flex:1,overflowY:'auto',padding:'14px 16px',display:'flex',flexDirection:'column',gap:12}}>
          {/* Time */}
          <div style={{display:'flex',gap:10,alignItems:'flex-start'}}>
            <span style={{fontSize:15,marginTop:1}}>🕐</span>
            <div>
              <div style={{fontSize:12,color:'var(--text)',fontWeight:500}}>{fmt12(startH,startM)} – {fmt12(endH,endM)}</div>
              <div style={{fontSize:11,color:'var(--muted)',marginTop:2}}>{evt.date} · {durLabel}</div>
            </div>
          </div>
          {/* Location */}
          {evt.location && !evt.location.startsWith('http') && (
            <div style={{display:'flex',gap:10,alignItems:'flex-start'}}>
              <span style={{fontSize:15,marginTop:1}}>📍</span>
              <div style={{fontSize:12,color:'var(--text)',lineHeight:1.5}}>{evt.location}</div>
            </div>
          )}
          {/* Meeting type badge */}
          {typeLabel && (
            <div style={{display:'flex',gap:10,alignItems:'center'}}>
              <span style={{fontSize:15}}>📹</span>
              <span style={{fontSize:12,color:color,fontWeight:500}}>{typeLabel}</span>
            </div>
          )}
          {/* Join button */}
          {link && (
            <a href={link} target="_blank" rel="noopener noreferrer" style={{
              display:'flex',alignItems:'center',justifyContent:'center',gap:8,
              padding:'10px 14px',borderRadius:8,textDecoration:'none',fontWeight:600,
              fontSize:13,border:`1px solid ${color}`,color:color,
              background:`${color}18`,marginTop:4
            }}>
              <span>🎥</span> Join {typeLabel||'Meeting'}
            </a>
          )}
          {/* AI prep button */}
          <button onClick={()=>{
            if(onAskAbout) onAskAbout(`I have "${evt.title||evt.summary}" at ${fmt12(startH,startM)}. Prep me — what should I know, what questions should I ask, and what are my key priorities for this meeting?`);
            setSelectedEvent(null);
          }} style={{
            display:'flex',alignItems:'center',gap:8,padding:'10px 14px',
            background:'rgba(34,211,238,0.1)',border:'1px solid var(--accent)',
            borderRadius:8,color:'var(--accent)',fontSize:13,fontWeight:600,
            cursor:'pointer',marginTop:4
          }}>✦ Prep me for this meeting</button>
        </div>
      </div>
    );
  }

  return (
    <div style={{display:'flex',flexDirection:'column',height:'100%'}}>
      {/* Toolbar */}
      <div style={{height:52,padding:'0 16px',display:'flex',alignItems:'center',
        justifyContent:'space-between',borderBottom:'1px solid var(--border)',flexShrink:0,background:'var(--surface)'}}>
        <div style={{display:'flex',gap:4,alignItems:'center'}}>
          <button onClick={()=>setWeekOffset(o=>o-1)} style={{width:32,height:32,borderRadius:8,background:'none',border:'none',color:'var(--muted)',fontSize:15,cursor:'pointer'}}>◀</button>
          <button onClick={()=>setWeekOffset(o=>o+1)} style={{width:32,height:32,borderRadius:8,background:'none',border:'none',color:'var(--muted)',fontSize:15,cursor:'pointer'}}>▶</button>
          <button onClick={()=>setWeekOffset(0)} style={{fontSize:11,padding:'4px 10px',border:'1px solid var(--border)',borderRadius:6,color:'var(--muted)',background:'none',cursor:'pointer',marginLeft:4}}>Today</button>
        </div>
        <span style={{fontSize:14,fontWeight:600,color:'var(--text)'}}>{weekLabel}</span>
        <button onClick={()=>{setShowAddForm(v=>!v);setSelectedEvent(null);}} style={{fontSize:12,padding:'5px 12px',background:'var(--accent)',color:'#000',border:'none',borderRadius:6,fontWeight:600,cursor:'pointer'}}>+ Event</button>
      </div>

      {/* Add event form */}
      {showAddForm && (
        <div style={{padding:'10px 16px',background:'var(--surface)',borderBottom:'1px solid var(--border)',display:'flex',gap:8,flexWrap:'wrap',flexShrink:0}}>
          <input placeholder="Event title" value={newEvent.title} onChange={e=>setNewEvent(p=>({...p,title:e.target.value}))} style={{flex:1,minWidth:140,background:'var(--bg)',border:'1px solid var(--border)',borderRadius:6,padding:'6px 10px',color:'var(--text)',fontSize:12}} />
          <input type="date" value={newEvent.date} onChange={e=>setNewEvent(p=>({...p,date:e.target.value}))} style={{background:'var(--bg)',border:'1px solid var(--border)',borderRadius:6,padding:'6px 8px',color:'var(--text)',fontSize:12}} />
          <input type="time" value={newEvent.start} onChange={e=>setNewEvent(p=>({...p,start:e.target.value}))} style={{background:'var(--bg)',border:'1px solid var(--border)',borderRadius:6,padding:'6px 8px',color:'var(--text)',fontSize:12}} />
          <input type="time" value={newEvent.end} onChange={e=>setNewEvent(p=>({...p,end:e.target.value}))} style={{background:'var(--bg)',border:'1px solid var(--border)',borderRadius:6,padding:'6px 8px',color:'var(--text)',fontSize:12}} />
          <button onClick={async()=>{
            if(!newEvent.title.trim()) return;
            await fetch('/api/calendar',{method:'POST',headers:{'Content-Type':'application/json'},
              body:JSON.stringify({title:newEvent.title,date:newEvent.date,start_time:newEvent.start,end_time:newEvent.end})});
            setShowAddForm(false); setNewEvent({title:'',date:'',start:'',end:''});
            fetch('/api/calendar?days=30').then(r=>r.json()).then(d=>setEvents(d.events||[]));
          }} style={{background:'var(--green)',color:'#000',border:'none',borderRadius:6,padding:'6px 12px',fontSize:12,fontWeight:600,cursor:'pointer'}}>Save</button>
          <button onClick={()=>setShowAddForm(false)} style={{background:'none',border:'1px solid var(--border)',borderRadius:6,padding:'6px 10px',fontSize:12,color:'var(--muted)',cursor:'pointer'}}>Cancel</button>
        </div>
      )}

      {loading ? (
        <div className="loading"><div className="spinner"></div></div>
      ) : (
        <div style={{flex:1,display:'flex',flexDirection:'column',overflow:'hidden',position:'relative'}}>
          {/* Day header row */}
          <div style={{display:'flex',borderBottom:'1px solid var(--border)',flexShrink:0,
            paddingRight:selectedEvent?270:0,transition:'padding-right 0.18s'}}>
            <div style={{width:54,flexShrink:0,borderRight:'1px solid var(--border)'}}></div>
            {weekDays.map((d,i) => {
              const isToday = localDateStr(d)===todayStr;
              const cnt = eventsForDay(d).length;
              return (
                <div key={i} style={{flex:1,borderRight:'1px solid var(--border)',padding:'5px 0',textAlign:'center'}}>
                  <div style={{fontSize:10,fontWeight:700,letterSpacing:'0.07em',textTransform:'uppercase',
                    color:isToday?'var(--accent)':'var(--muted)'}}>{DN[d.getDay()]}</div>
                  {isToday
                    ? <span style={{width:26,height:26,borderRadius:'50%',background:'var(--accent)',color:'#000',
                        fontWeight:700,display:'inline-flex',alignItems:'center',justifyContent:'center',fontSize:13}}>{d.getDate()}</span>
                    : <div style={{fontSize:17,fontWeight:300,color:'var(--text)'}}>{d.getDate()}</div>}
                  {cnt>0 && <div style={{fontSize:9,color:'var(--accent)',marginTop:1,fontWeight:600}}>{cnt}</div>}
                </div>
              );
            })}
          </div>

          {/* Scrollable grid */}
          <div style={{flex:1,overflowY:'auto',display:'flex',position:'relative'}}>
            <div style={{display:'flex',flex:1,paddingRight:selectedEvent?270:0,transition:'padding-right 0.18s',minWidth:0}}>
              {/* Time gutter */}
              <div style={{width:54,flexShrink:0}}>
                {HOURS.map(h=>(
                  <div key={h} style={{height:CELL_H,paddingRight:8,textAlign:'right',fontSize:10,
                    color:'var(--muted)',paddingTop:3,borderRight:'1px solid var(--border)',
                    borderBottom:'1px solid rgba(55,55,55,0.5)'}}>
                    {h===12?'12 PM':h>12?`${h-12} PM`:h===0?'12 AM':`${h} AM`}
                  </div>
                ))}
              </div>
              {/* Day columns */}
              {weekDays.map((d,di)=>{
                const isToday = localDateStr(d)===todayStr;
                const dayEvts = eventsForDay(d);
                return (
                  <div key={di} style={{flex:1,position:'relative',borderRight:'1px solid var(--border)',
                    background:isToday?'rgba(34,211,238,0.025)':'transparent'}}>
                    {HOURS.map(h=>(
                      <div key={h} style={{height:CELL_H,borderBottom:'1px solid rgba(55,55,55,0.5)'}}></div>
                    ))}
                    {layoutDay(dayEvts).map((evt,ei)=>{
                      const {startH,startM,endH,endM} = parseTime(evt);
                      const top = Math.max(0,(startH-6)*CELL_H + startM*(CELL_H/60));
                      const durMin = Math.max(15,(endH*60+endM)-(startH*60+startM));
                      const height = Math.max(22, Math.min(durMin*(CELL_H/60),(22-6)*CELL_H-top));
                      const {color} = meetingInfo(evt);
                      const isSelected = selectedEvent===evt;
                      const colW = 1 / evt._total;
                      const leftPct = evt._col * colW * 100;
                      const widthPct = evt._span * colW * 100;
                      return (
                        <div key={ei}
                          onClick={()=>setSelectedEvent(isSelected?null:evt)}
                          style={{
                            position:'absolute',
                            left:`calc(${leftPct}% + 2px)`,
                            width:`calc(${widthPct}% - 4px)`,
                            top,height,
                            borderRadius:5,padding:'3px 6px',fontSize:11,fontWeight:500,
                            background:isSelected?`${color}30`:`${color}18`,
                            borderLeft:`3px solid ${color}`,
                            overflow:'hidden',cursor:'pointer',zIndex:1,
                            boxShadow:isSelected?`0 0 0 1px ${color}`:'none',
                            transition:'background 0.12s'
                          }}>
                          <div style={{whiteSpace:'nowrap',overflow:'hidden',textOverflow:'ellipsis',
                            color:'var(--text)',lineHeight:1.3}}>{evt.title||evt.summary}</div>
                          {height>32 && <div style={{fontSize:9,color:'var(--muted)',marginTop:1}}>
                            {evt.time?.split('-')[0]?.trim()||''}</div>}
                        </div>
                      );
                    })}
                  </div>
                );
              })}
            </div>
            {/* Detail panel */}
            {selectedEvent && <EventDetail evt={selectedEvent} />}
          </div>

          {/* Status bar */}
          <div style={{fontSize:11,color:'var(--muted)',padding:'6px 16px',borderTop:'1px solid var(--border)',
            flexShrink:0,background:'var(--surface)',display:'flex',gap:16}}>
            <span>Today: <b style={{color:'var(--text)'}}>{todayEvts.length}</b> event{todayEvts.length!==1?'s':''}</span>
            <span style={{color:'var(--border)'}}>|</span>
            <span>This week: <b style={{color:'var(--text)'}}>{weekTotal}</b> events</span>
            <span style={{color:'var(--border)'}}>|</span>
            <span>Loaded: <b style={{color:'var(--text)'}}>{events.length}</b> total</span>
          </div>
        </div>
      )}
    </div>
  );
}

// ── Work Tab View Component (Tasks + Actions) ───────────────────────────────
function WorkTabView({ onAskAbout }) {
  const [actions, setActions] = React.useState([]);
  const [tasks, setTasks] = React.useState([]);
  const [reminders, setReminders] = React.useState([]);
  const [loading, setLoading] = React.useState(true);
  const [collapsed, setCollapsed] = React.useState({approval: false, today: false, upcoming: false});
  const [showAdd, setShowAdd] = React.useState(false);
  const [newTask, setNewTask] = React.useState({title: '', due: ''});
  const [completed, setCompleted] = React.useState({});

  React.useEffect(() => {
    Promise.all([
      fetch('/api/actions').then(r=>r.json()).catch(()=>({actions:[]})),
      fetch('/api/tasks').then(r=>r.json()).catch(()=>({tasks:[]})),
      fetch('/api/reminders/structured').then(r=>r.json()).catch(()=>({reminders:[]})),
    ]).then(([actData, taskData, remData]) => {
      setActions(actData.actions || []);
      setTasks(taskData.tasks || taskData.items || []);
      setReminders(remData.reminders || []);
      setLoading(false);
    });
  }, []);

  const todayStr = new Date().toISOString().split('T')[0];

  const pendingActions = actions.filter(a => a.status === 'pending' || !a.status);

  function getAllItems() {
    const taskItems = tasks.map(t => ({...t, _type:'task', _done: t.completed || t.status === 'completed' || !!completed[t.id]}));
    const remItems = reminders.map(r => ({...r, _type:'reminder', title: r.title || r.content, _done: !!completed['r_'+r.id]}));
    return [...taskItems, ...remItems];
  }

  const allItems = getAllItems();
  const todayItems = allItems.filter(it => {
    if (it._done) return false;
    const due = it.due_date || it.due || '';
    return due <= todayStr || !due;
  });
  const upcomingItems = allItems.filter(it => {
    if (it._done) return false;
    const due = it.due_date || it.due || '';
    return due > todayStr;
  });

  async function approveAction(id) {
    try {
      await fetch('/api/actions/' + id + '/approve', { method: 'POST', headers:{'Content-Type':'application/json'}, body: '{}' });
      setActions(prev => prev.filter(a => a.id !== id));
    } catch(e) {}
  }

  async function rejectAction(id) {
    try {
      await fetch('/api/actions/' + id + '/reject', { method: 'POST', headers:{'Content-Type':'application/json'}, body: '{}' });
      setActions(prev => prev.filter(a => a.id !== id));
    } catch(e) {}
  }

  async function completeItem(item) {
    const key = item._type === 'reminder' ? 'r_' + item.id : item.id;
    setCompleted(prev => ({...prev, [key]: true}));
    try {
      if (item._type === 'task') {
        await fetch('/api/tasks/' + item.id, { method: 'PUT', headers:{'Content-Type':'application/json'}, body: JSON.stringify({completed: true}) });
      } else {
        await fetch('/api/reminders/' + item.id + '/complete', { method: 'POST' });
      }
    } catch(e) {}
  }

  async function handleAddTask() {
    if (!newTask.title.trim()) return;
    try {
      await fetch('/api/tasks', {
        method: 'POST', headers:{'Content-Type':'application/json'},
        body: JSON.stringify({ title: newTask.title, due_date: newTask.due || undefined })
      });
      setShowAdd(false);
      setNewTask({title:'', due:''});
      fetch('/api/tasks').then(r=>r.json()).then(d=>setTasks(d.tasks||d.items||[])).catch(()=>{});
    } catch(e) {}
  }

  function formatDueDate(d) {
    if (!d) return '';
    try {
      const dt = new Date(d + (d.includes('T') ? '' : 'T00:00:00'));
      const days = ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];
      const mos = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
      return days[dt.getDay()] + ' ' + mos[dt.getMonth()] + ' ' + dt.getDate();
    } catch(e) { return d; }
  }

  function toggleSection(key) {
    setCollapsed(prev => ({...prev, [key]: !prev[key]}));
  }

  if (loading) return <div className="loading"><div className="spinner"></div></div>;

  return (
    <div style={{display:'flex',flexDirection:'column',height:'100%'}}>
      {/* Header */}
      <div style={{height:52,padding:'0 16px',display:'flex',alignItems:'center',justifyContent:'space-between',borderBottom:'1px solid var(--border)',flexShrink:0,background:'var(--surface)'}}>
        <span style={{fontSize:15,fontWeight:600,color:'var(--text)'}}>Work</span>
        <button onClick={()=>setShowAdd(v=>!v)} style={{fontSize:12,color:'var(--accent)',fontWeight:500,padding:'4px 8px',borderRadius:6,background:'rgba(34,211,238,0.08)',border:'none',cursor:'pointer'}}>+ Add Task</button>
      </div>

      {/* Quick-add form */}
      {showAdd && (
        <div style={{padding:'10px 16px',borderBottom:'1px solid var(--border)',background:'var(--surface)',display:'flex',gap:8}}>
          <input placeholder="Task title" value={newTask.title} onChange={e=>setNewTask(p=>({...p,title:e.target.value}))} onKeyDown={e=>{if(e.key==='Enter')handleAddTask();}} style={{flex:1,background:'var(--bg)',border:'1px solid var(--border)',borderRadius:6,padding:'6px 10px',color:'var(--text)',fontSize:12}} />
          <input type="date" value={newTask.due} onChange={e=>setNewTask(p=>({...p,due:e.target.value}))} style={{background:'var(--bg)',border:'1px solid var(--border)',borderRadius:6,padding:'6px 8px',color:'var(--text)',fontSize:12}} />
          <button onClick={handleAddTask} style={{background:'var(--accent)',color:'#000',border:'none',borderRadius:6,padding:'6px 12px',fontSize:12,fontWeight:600,cursor:'pointer'}}>Add</button>
        </div>
      )}

      <div style={{flex:1,overflowY:'auto'}}>
        {/* Section: For Approval */}
        {pendingActions.length > 0 && (
          <>
            <div onClick={()=>toggleSection('approval')} style={{height:36,padding:'0 16px',display:'flex',alignItems:'center',gap:8,background:'var(--surface)',borderBottom:'1px solid var(--border)',cursor:'pointer'}}>
              <span style={{fontSize:10,color:'var(--muted)'}}>{collapsed.approval ? '\u25B6' : '\u25BC'}</span>
              <span style={{fontSize:11,fontWeight:700,letterSpacing:'0.08em',color:'var(--orange)',textTransform:'uppercase'}}>For Approval</span>
              <span style={{fontSize:11,color:'var(--muted)',background:'var(--surface2)',borderRadius:10,padding:'1px 6px'}}>{pendingActions.length}</span>
            </div>
            {!collapsed.approval && pendingActions.map((a,i) => (
              <div key={a.id||i} style={{padding:'12px 16px',borderBottom:'1px solid var(--border)',display:'flex',alignItems:'center',gap:12}}>
                <div style={{width:3,height:32,borderRadius:2,background:'var(--orange)',flexShrink:0}}></div>
                <div style={{flex:1}}>
                  <div style={{fontSize:13,fontWeight:500,color:'var(--text)'}}>{a.title || a.subject || 'Action needed'}</div>
                  <div style={{fontSize:11,color:'var(--muted)'}}>{a.description || a.content || a.body || ''}</div>
                </div>
                <button onClick={()=>approveAction(a.id)} style={{background:'rgba(52,211,153,0.15)',color:'var(--green)',border:'1px solid rgba(52,211,153,0.25)',borderRadius:6,padding:'4px 10px',fontSize:12,fontWeight:500,cursor:'pointer'}}>Approve</button>
                <button onClick={()=>rejectAction(a.id)} style={{background:'rgba(248,113,113,0.12)',color:'var(--red)',border:'1px solid rgba(248,113,113,0.2)',borderRadius:6,padding:'4px 10px',fontSize:12,fontWeight:500,cursor:'pointer',marginLeft:4}}>Deny</button>
              </div>
            ))}
          </>
        )}

        {/* Section: Today */}
        <div onClick={()=>toggleSection('today')} style={{height:36,padding:'0 16px',display:'flex',alignItems:'center',gap:8,background:'var(--surface)',borderBottom:'1px solid var(--border)',cursor:'pointer'}}>
          <span style={{fontSize:10,color:'var(--muted)'}}>{collapsed.today ? '\u25B6' : '\u25BC'}</span>
          <span style={{fontSize:11,fontWeight:700,letterSpacing:'0.08em',color:'var(--text)',textTransform:'uppercase'}}>Today</span>
          <span style={{fontSize:11,color:'var(--muted)',background:'var(--surface2)',borderRadius:10,padding:'1px 6px'}}>{todayItems.length}</span>
        </div>
        {!collapsed.today && (
          todayItems.length === 0 ? (
            <div style={{padding:'16px',textAlign:'center',fontSize:13,color:'var(--muted)'}}>All caught up for today</div>
          ) : todayItems.map((it,i) => {
            const key = it._type === 'reminder' ? 'r_' + it.id : it.id;
            const isDone = !!completed[key];
            const due = it.due_date || it.due || '';
            const isOverdue = due && due < todayStr;
            return (
              <div key={key || i} style={{padding:'12px 16px',borderBottom:'1px solid var(--border)',display:'flex',alignItems:'center',gap:12}}>
                <div onClick={()=>!isDone && completeItem(it)} style={{
                  width:18,height:18,borderRadius:'50%',border: isDone ? 'none' : '1.5px solid var(--border)',flexShrink:0,cursor:'pointer',
                  display:'flex',alignItems:'center',justifyContent:'center',
                  background: isDone ? 'var(--green)' : 'transparent', borderColor: isDone ? 'var(--green)' : 'var(--border)'
                }}>
                  {isDone && <span style={{color:'#000',fontSize:11}}>{'\u2713'}</span>}
                </div>
                <span style={{fontSize:13,color: isDone ? 'var(--muted)' : 'var(--text)',flex:1,textDecoration: isDone ? 'line-through' : 'none',opacity: isDone ? 0.6 : 1}}>{it.title || it.name || it.content}</span>
                {isOverdue && <span style={{fontSize:11,color:'var(--red)'}}>Overdue</span>}
                {!isOverdue && due && <span style={{fontSize:11,color:'var(--muted)'}}>{formatDueDate(due)}</span>}
              </div>
            );
          })
        )}

        {/* Section: Upcoming */}
        <div onClick={()=>toggleSection('upcoming')} style={{height:36,padding:'0 16px',display:'flex',alignItems:'center',gap:8,background:'var(--surface)',borderBottom:'1px solid var(--border)',cursor:'pointer'}}>
          <span style={{fontSize:10,color:'var(--muted)'}}>{collapsed.upcoming ? '\u25B6' : '\u25BC'}</span>
          <span style={{fontSize:11,fontWeight:700,letterSpacing:'0.08em',color:'var(--text)',textTransform:'uppercase'}}>Upcoming</span>
          <span style={{fontSize:11,color:'var(--muted)',background:'var(--surface2)',borderRadius:10,padding:'1px 6px'}}>{upcomingItems.length}</span>
        </div>
        {!collapsed.upcoming && (
          upcomingItems.length === 0 ? (
            <div style={{padding:'16px',textAlign:'center',fontSize:13,color:'var(--muted)'}}>No upcoming tasks</div>
          ) : upcomingItems.map((it,i) => {
            const key = it._type === 'reminder' ? 'r_' + it.id : it.id;
            const isDone = !!completed[key];
            const due = it.due_date || it.due || '';
            return (
              <div key={key || i} style={{padding:'12px 16px',borderBottom:'1px solid var(--border)',display:'flex',alignItems:'center',gap:12,opacity:0.85}}>
                <div onClick={()=>!isDone && completeItem(it)} style={{
                  width:18,height:18,borderRadius:'50%',border: isDone ? 'none' : '1.5px solid var(--border)',flexShrink:0,cursor:'pointer',
                  display:'flex',alignItems:'center',justifyContent:'center',
                  background: isDone ? 'var(--green)' : 'transparent', borderColor: isDone ? 'var(--green)' : 'var(--border)'
                }}>
                  {isDone && <span style={{color:'#000',fontSize:11}}>{'\u2713'}</span>}
                </div>
                <span style={{fontSize:13,color: isDone ? 'var(--muted)' : 'var(--text)',flex:1,textDecoration: isDone ? 'line-through' : 'none',opacity: isDone ? 0.6 : 1}}>{it.title || it.name || it.content}</span>
                {due && <span style={{fontSize:11,color:'var(--muted)'}}>{formatDueDate(due)}</span>}
              </div>
            );
          })
        )}
        <div style={{height:20}}></div>
      </div>
    </div>
  );
}

