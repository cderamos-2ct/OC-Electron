  }

  // -- Reading pane --
  function renderReadingPane() {
    if (!selectedMsg) {
      return React.createElement('div', {style:{flex:1,display:'flex',alignItems:'center',justifyContent:'center',color:'var(--muted)',fontSize:13}}, '\u2190 Select a message');
