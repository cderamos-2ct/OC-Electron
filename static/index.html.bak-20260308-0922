// ── NotesModuleView ──────────────────────────────────────────────────────────
function NotesModuleView({ onAskAbout }) {
  const [notes, setNotes] = React.useState([]);
  const [selected, setSelected] = React.useState(null);
  const [editTitle, setEditTitle] = React.useState('');
  const [editContent, setEditContent] = React.useState('');
  const [saving, setSaving] = React.useState(false);
  const [search, setSearch] = React.useState('');
  const [isMobile, setIsMobile] = React.useState(window.innerWidth < 768);
  const saveTimer = React.useRef(null);

  React.useEffect(() => {
    const onResize = () => setIsMobile(window.innerWidth < 768);
    window.addEventListener('resize', onResize);
    return () => window.removeEventListener('resize', onResize);
  }, []);

  React.useEffect(() => {
    fetch('/api/notes').then(r=>r.json()).then(d=>setNotes(d.notes||[])).catch(()=>{});
  }, []);

  function selectNote(note) {
    setSelected(note);
    setEditTitle(note.title || '');
    setEditContent(note.content || '');
  }

  function autoSave(title, content) {
    clearTimeout(saveTimer.current);
    saveTimer.current = setTimeout(() => {
      if (!selected) return;
      setSaving(true);
      fetch(`/api/notes/${selected.id}`, {
        method: 'PUT',
        headers: {'Content-Type':'application/json'},
        body: JSON.stringify({ title, content })
      }).then(()=>{
        setNotes(prev => prev.map(n => n.id===selected.id ? {...n, title, content} : n));
      }).finally(()=>setSaving(false));
    }, 800);
  }

  function createNote() {
    fetch('/api/notes', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({title:'Untitled', content:''}) })
      .then(r=>r.json()).then(n => { setNotes(prev=>[n,...prev]); selectNote(n); }).catch(()=>{});
  }

  const filtered = notes.filter(n => !search || (n.title||'').toLowerCase().includes(search.toLowerCase()) || (n.content||'').toLowerCase().includes(search.toLowerCase()));

  const listPane = (
    <div style={{width: isMobile?'100%':'280px', flexShrink:0, borderRight: isMobile?'none':'1px solid var(--border)', display:'flex', flexDirection:'column', background:'var(--surface)', height:'100%'}}>
      <div style={{padding:'12px', borderBottom:'1px solid var(--border)', flexShrink:0}}>
        <div style={{display:'flex', gap:8, marginBottom:8}}>
          <span style={{fontWeight:600, fontSize:14, flex:1}}>Notes</span>
          <button onClick={createNote} style={{background:'var(--accent)',color:'#000',border:'none',borderRadius:6,width:26,height:26,cursor:'pointer',fontSize:18,lineHeight:'26px',textAlign:'center'}}>+</button>
        </div>
        <input value={search} onChange={e=>setSearch(e.target.value)} placeholder="Search..." style={{width:'100%',background:'var(--surface2)',border:'1px solid var(--border)',borderRadius:8,padding:'6px 10px',color:'var(--text)',fontSize:12,outline:'none'}} />
      </div>
      <div style={{flex:1, overflowY:'auto'}}>
        {filtered.length === 0 && <div style={{color:'var(--muted)',fontSize:12,padding:'20px',textAlign:'center'}}>No notes yet</div>}
        {filtered.map(note => (
          <div key={note.id} onClick={()=>selectNote(note)} style={{padding:'12px 14px', borderBottom:'1px solid var(--border)', cursor:'pointer', background: selected?.id===note.id ? 'var(--surface2)' : 'transparent', borderLeft: selected?.id===note.id ? '3px solid var(--accent)' : '3px solid transparent'}}>
            <div style={{fontSize:13, fontWeight:500, color:'var(--text)', whiteSpace:'nowrap', overflow:'hidden', textOverflow:'ellipsis'}}>{note.title || 'Untitled'}</div>
            <div style={{fontSize:11, color:'var(--muted)', marginTop:2, whiteSpace:'nowrap', overflow:'hidden', textOverflow:'ellipsis'}}>{(note.content||'').slice(0,80)}</div>
            <div style={{fontSize:10, color:'var(--border)', marginTop:4}}>{note.updated_at ? new Date(note.updated_at).toLocaleDateString() : ''}</div>
          </div>
        ))}
      </div>
    </div>
  );

  const editorPane = (
    <div style={{flex:1, display:'flex', flexDirection:'column', background:'var(--bg)', height:'100%', overflow:'hidden'}}>
      {!selected ? (
        <div style={{flex:1,display:'flex',alignItems:'center',justifyContent:'center',color:'var(--muted)',fontSize:13}}>{'\u2190'} Select a note or create one</div>
      ) : (
        <>
          <div style={{padding:'16px 24px 8px', borderBottom:'1px solid var(--border)', flexShrink:0}}>
            {isMobile && <button onClick={()=>setSelected(null)} style={{background:'none',border:'none',color:'var(--accent)',cursor:'pointer',fontSize:13,marginBottom:8,padding:0}}>{'\u2039'} Notes</button>}
            <input value={editTitle} onChange={e=>{setEditTitle(e.target.value);autoSave(e.target.value,editContent);}} placeholder="Title" style={{width:'100%',background:'transparent',border:'none',fontSize:20,fontWeight:700,color:'var(--text)',outline:'none'}} />
            <div style={{fontSize:10,color:'var(--muted)',marginTop:4}}>{saving?'Saving...':'Auto-saved'}</div>
          </div>
          <textarea value={editContent} onChange={e=>{setEditContent(e.target.value);autoSave(editTitle,e.target.value);}} placeholder="Start writing..." style={{flex:1,background:'transparent',border:'none',padding:'16px 24px',color:'var(--text)',fontSize:14,lineHeight:1.7,resize:'none',outline:'none',fontFamily:'inherit'}} />
          <div style={{padding:'8px 24px',borderTop:'1px solid var(--border)',display:'flex',justifyContent:'space-between',alignItems:'center',flexShrink:0}}>
            <span style={{fontSize:11,color:'var(--muted)'}}>{editContent.split(/\s+/).filter(Boolean).length} words</span>
            <button onClick={()=>onAskAbout('Summarize this note: '+editTitle)} style={{fontSize:11,color:'var(--accent)',background:'rgba(34,211,238,0.08)',border:'none',borderRadius:6,padding:'4px 8px',cursor:'pointer'}}>{'\u2726'} Summarize</button>
          </div>
        </>
      )}
    </div>
  );

  return (
    <div style={{display:'flex',flexDirection:'row',height:'100%',overflow:'hidden'}}>
      {(!isMobile || !selected) && listPane}
      {(!isMobile || selected) && editorPane}
    </div>
  );
}

// ── DelegationsModuleView ────────────────────────────────────────────────────
function DelegationsModuleView({ onAskAbout }) {
  const [items, setItems] = React.useState([]);
  const [showAdd, setShowAdd] = React.useState(false);
  const [form, setForm] = React.useState({person:'',task:'',due:'',notes:''});

  React.useEffect(() => {
    fetch('/api/delegations').then(r=>r.json()).then(d=>setItems(d.delegations||d||[])).catch(()=>{});
  }, []);

  const todayStr = new Date().toISOString().split('T')[0];

  async function addItem() {
    if (!form.person || !form.task) return;
    const res = await fetch('/api/delegations', {method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(form)});
    const n = await res.json();
    setItems(prev=>[n,...prev]);
    setForm({person:'',task:'',due:'',notes:''});
    setShowAdd(false);
  }

  async function toggleDone(item) {
    const newStatus = item.status==='done' ? 'pending' : 'done';
    await fetch(`/api/delegations/${item.id}`, {method:'PUT',headers:{'Content-Type':'application/json'},body:JSON.stringify({status:newStatus})});
    setItems(prev=>prev.map(i=>i.id===item.id?{...i,status:newStatus}:i));
  }

  async function deleteItem(id) {
    await fetch(`/api/delegations/${id}`,{method:'DELETE'});
    setItems(prev=>prev.filter(i=>i.id!==id));
  }

  const pending = items.filter(i=>i.status!=='done');
  const done = items.filter(i=>i.status==='done');

  return (
    <div style={{flex:1,overflowY:'auto',padding:'0'}}>
      <div style={{padding:'14px 20px',borderBottom:'1px solid var(--border)',display:'flex',justifyContent:'space-between',alignItems:'center',background:'var(--surface)'}}>
        <span style={{fontSize:12,color:'var(--muted)'}}>{pending.length} pending {'\u00B7'} {done.length} done</span>
        <div style={{display:'flex',gap:8}}>
          <button onClick={()=>onAskAbout('Follow up on all my delegations and tell me what needs attention')} style={{fontSize:11,color:'var(--accent)',background:'rgba(34,211,238,0.08)',border:'1px solid rgba(34,211,238,0.2)',borderRadius:6,padding:'4px 8px',cursor:'pointer'}}>{'\u2726'} Follow up</button>
          <button onClick={()=>setShowAdd(s=>!s)} style={{fontSize:12,background:'var(--accent)',color:'#000',border:'none',borderRadius:6,padding:'5px 10px',cursor:'pointer',fontWeight:600}}>+ Add</button>
        </div>
      </div>
      {showAdd && (
        <div style={{padding:'14px 20px',borderBottom:'1px solid var(--border)',background:'var(--surface2)',display:'flex',flexWrap:'wrap',gap:8}}>
          <input value={form.person} onChange={e=>setForm(f=>({...f,person:e.target.value}))} placeholder="Person" style={{flex:'1 1 140px',background:'var(--surface)',border:'1px solid var(--border)',borderRadius:8,padding:'7px 10px',color:'var(--text)',fontSize:12,outline:'none'}} />
          <input value={form.task} onChange={e=>setForm(f=>({...f,task:e.target.value}))} placeholder="Task / what you delegated" style={{flex:'2 1 200px',background:'var(--surface)',border:'1px solid var(--border)',borderRadius:8,padding:'7px 10px',color:'var(--text)',fontSize:12,outline:'none'}} />
          <input type="date" value={form.due} onChange={e=>setForm(f=>({...f,due:e.target.value}))} style={{flex:'0 1 140px',background:'var(--surface)',border:'1px solid var(--border)',borderRadius:8,padding:'7px 10px',color:'var(--text)',fontSize:12,outline:'none'}} />
          <button onClick={addItem} style={{background:'var(--accent)',color:'#000',border:'none',borderRadius:8,padding:'7px 14px',cursor:'pointer',fontWeight:600,fontSize:12}}>Save</button>
          <button onClick={()=>setShowAdd(false)} style={{background:'none',border:'1px solid var(--border)',borderRadius:8,padding:'7px 10px',cursor:'pointer',color:'var(--muted)',fontSize:12}}>Cancel</button>
        </div>
      )}
      <div>
        {items.length === 0 && <div style={{color:'var(--muted)',fontSize:13,padding:'40px',textAlign:'center'}}>No delegations yet. Add one to track what you've handed off.</div>}
        {items.map(item => {
          const isOverdue = item.due && item.due < todayStr && item.status !== 'done';
          return (
            <div key={item.id} style={{padding:'14px 20px',borderBottom:'1px solid var(--border)',display:'flex',alignItems:'center',gap:12,opacity:item.status==='done'?0.5:1}}>
              <input type="checkbox" checked={item.status==='done'} onChange={()=>toggleDone(item)} style={{width:16,height:16,accentColor:'var(--green)',flexShrink:0,cursor:'pointer'}} />
              <div style={{flex:1,minWidth:0}}>
                <div style={{fontSize:13,fontWeight:500,color:'var(--text)',textDecoration:item.status==='done'?'line-through':'none'}}>{item.task}</div>
                <div style={{fontSize:11,color:'var(--muted)',marginTop:2}}>
                  <span style={{color:'var(--accent)'}}>{item.person}</span>
                  {item.due && <span style={{marginLeft:8,color:isOverdue?'var(--red)':'var(--muted)'}}>{isOverdue?'\u26A0 Overdue: ':''}{item.due}</span>}
                </div>
                {item.notes && <div style={{fontSize:11,color:'var(--muted)',marginTop:4,fontStyle:'italic'}}>{item.notes}</div>}
              </div>
              <button onClick={()=>deleteItem(item.id)} style={{background:'none',border:'none',color:'var(--muted)',cursor:'pointer',fontSize:14,padding:4}}>{'\uD83D\uDDD1'}</button>
            </div>
          );
        })}
      </div>
    </div>
  );
}

// ── JournalModuleView ────────────────────────────────────────────────────────
function JournalModuleView({ onAskAbout }) {
  const [entries, setEntries] = React.useState([]);
  const [newEntry, setNewEntry] = React.useState('');
