// ── Main: ChatOS ────────────────────────────────────────────────────────────
function ChatOS() {
  // -- State --
  const [messages, setMessages] = useState([]);
  const [input, setInput] = useState('');
  const [streaming, setStreaming] = useState('');
  const [statusMsg, setStatusMsg] = useState('');
  const [isTyping, setIsTyping] = useState(false);
  const [chips, setChips] = useState([]);
  const [inboxOpen, setInboxOpen] = useState(false);
  const [notifsOpen, setNotifsOpen] = useState(false);
  const [menuOpen, setMenuOpen] = useState(false);
  const [ordersOpen, setOrdersOpen] = useState(false);
  const [journalOpen, setJournalOpen] = React.useState(false);
  const [statsOpen, setStatsOpen] = React.useState(false);
  const [actionsOpen, setActionsOpen] = React.useState(false);
  const [toolsOpen, setToolsOpen] = React.useState(false);
  const [calendarOpen, setCalendarOpen] = React.useState(false);
  const [tasksOpen, setTasksOpen] = React.useState(false);
  const [notesOpen, setNotesOpen] = React.useState(false);
  const [knowledgeOpen, setKnowledgeOpen] = React.useState(false);
  const [docsOpen, setDocsOpen] = React.useState(false);
  const [briefOpen, setBriefOpen] = React.useState(false);
  const [briefData, setBriefData] = React.useState(null);
  const [briefLoading, setBriefLoading] = React.useState(true);
  const [composeOpen, setComposeOpen] = React.useState(false);
  const [composeReplyTo, setComposeReplyTo] = React.useState(null);
  const [projectsOpen, setProjectsOpen] = React.useState(false);
  const [delegationsOpen, setDelegationsOpen] = React.useState(false);
  const [mobileAiOpen, setMobileAiOpen] = React.useState(false);
  const [chatSearch, setChatSearch] = React.useState(false);
  const [searchQuery, setSearchQuery] = React.useState('');
  const [searchResults, setSearchResults] = React.useState([]);
  const [searchLoading, setSearchLoading] = React.useState(false);
  const [dragOver, setDragOver] = React.useState(false);
  const [attachedFile, setAttachedFile] = React.useState(null);
  const [activeTab, setActiveTab] = useState('chat');
  const [todayCount, setTodayCount] = useState(0);
  const [unreadNotifs, setUnreadNotifs] = useState(0);
  const [wsConnected, setWsConnected] = useState(false);
  const [briefingShown, setBriefingShown] = useState(false);

  const { addToast } = useContext(toastContext);
  const messagesEndRef = useRef(null);
  const inputRef = useRef(null);
  const streamingRef = useRef('');
  const lastVoiceRef = useRef(false);

  const { recording, speaking, supported, startRecording, stopRecording, speak, stopSpeaking } = useVoice();

  const wsUrl = `${location.protocol === 'https:' ? 'wss' : 'ws'}://${location.host}/ws`;
  const { connected, lastMessage, send } = useWebSocket(wsUrl);

  // Sync connected state
  useEffect(() => { setWsConnected(connected); }, [connected]);

  // Keep a ref to streaming for finalization
  useEffect(() => { streamingRef.current = streaming; }, [streaming]);

  // -- Scroll to bottom --
  function scrollToBottom() {
    requestAnimationFrame(() => {
      messagesEndRef.current?.scrollIntoView({ behavior: 'smooth' });
    });
  }

  // -- Load suggested action chips --
  function loadChips() {
    fetch('/api/suggested-actions')
      .then(r => r.json())
      .then(data => {
        const actions = data.actions || data.suggestions || data.chips || [];
        if (Array.isArray(actions) && actions.length > 0) {
          setChips(actions.slice(0, 3).map(a => ({
            icon: a.icon || '\u2728',
            label: a.label || a.text || a.title || '',
            prompt: a.prompt || a.message || a.label || a.text || ''
          })));
        }
      })
      .catch(() => {});
  }

  // -- Load today count --
  function loadTodayCount() {
    fetch('/api/messages/filtered?limit=12')
      .then(r => r.json())
      .then(d => setTodayCount(d.filtered || d.count || 0))
      .catch(() => {});
  }

  // -- Load unread notification count --
  function loadUnreadNotifs() {
    fetch('/api/stats')
      .then(r => r.json())
      .then(d => setUnreadNotifs(d.unread_notifications || 0))
      .catch(() => {});
  }

  // -- Auto-show morning brief --
  useEffect(() => {
    const now = new Date();
    const hour = now.getHours();
    const today = now.toDateString();
    const lastBrief = localStorage.getItem('ag_brief_date');
    if (hour >= 5 && hour < 13 && lastBrief !== today) {
      const t = setTimeout(() => {
        setBriefOpen(true);
        localStorage.setItem('ag_brief_date', today);
      }, 1200);
      return () => clearTimeout(t);
    }
  }, []);

  // -- Initial load --
  useEffect(() => {
    // 1. Load conversation history
    fetch('/api/conversations?limit=30')
      .then(r => r.json())
      .then(data => {
        const convos = data.conversations || data.messages || [];
        const history = convos.map(c => ({
          id: c.id,
          role: c.role,
          content: c.content,
          type: (() => {
            try {
              const meta = JSON.parse(c.metadata || '{}');
              if (meta.source === 'heartbeat') return 'proactive';
            } catch {}
            return undefined;
          })(),
          time: c.timestamp ? timeAgo(c.timestamp) : ''
        }));
        setMessages(history);
      })
      .catch(() => {});

    // 2. Load morning briefing
    fetch('/api/briefing')
      .then(r => r.json())
      .then(data => {
        if (data && (data.greeting || data.urgent || data.important || data.fyi)) {
          setMessages(prev => [{
            id: 'briefing-' + Date.now(),
            role: 'assistant',
            type: 'briefing',
            data: data
          }, ...prev]);
          setBriefingShown(true);
        }
      })
      .catch(() => {});

    // 3. Load today count
    loadTodayCount();

    // 4. Load suggested actions
    loadChips();

    // 5. Load unread notifications
    loadUnreadNotifs();

    // 6. Request notification permission
    if ('Notification' in window && Notification.permission === 'default') {
      setTimeout(() => Notification.requestPermission(), 2000);
    }

    // 7. Register service worker
    if ('serviceWorker' in navigator) {
      navigator.serviceWorker.register('/sw.js').catch(() => {});
    }

    // 8. Pre-fetch morning brief in background so it's instant when opened
    setBriefLoading(true);
    fetch('/api/morning-brief')
      .then(r => r.json())
      .then(d => { setBriefData(d); setBriefLoading(false); })
      .catch(() => setBriefLoading(false));
  }, []);

  // -- WebSocket message handler --
  useEffect(() => {
    if (!lastMessage) return;
    const msg = lastMessage;

    if (msg.type === 'heartbeat') {
      setWsConnected(true);
    }

    if (msg.type === 'toast') {
      addToast(msg.title, msg.body, msg.urgency);
      if (msg.urgency === 'high') {
        setMessages(prev => [...prev, {
          id: 'proactive-' + Date.now(),
          role: 'assistant',
          type: 'proactive',
          content: `\u26A1 ${msg.title}${msg.body ? '\n' + msg.body : ''}`
        }]);
        scrollToBottom();
      }
    }

    if (msg.type === 'proactive_message') {
      const isMeetingPrep = msg.urgency === 'meeting_prep' ||
        msg.message?.includes('PRE-MEETING') ||
        msg.message?.includes('meeting prep') ||
        msg.message?.includes('Meeting Prep');
      setMessages(prev => [...prev, {
        id: Date.now(),
        role: 'assistant',
        content: msg.message,
        metadata: JSON.stringify({
          source: 'heartbeat',
          urgency: msg.urgency,
          type: isMeetingPrep ? 'meeting_prep' : 'proactive'
        })
      }]);
      scrollToBottom();
    }

    if (msg.type === 'standing_order_triggered') {
      setMessages(prev => [...prev, {
        id: Date.now(),
        role: 'assistant',
        content: msg.message,
        metadata: JSON.stringify({source: 'standing_order'})
      }]);
      scrollToBottom();
    }

    if (msg.type === 'new_messages') {
      loadTodayCount();
    }

    if (msg.type === 'new_actions' || msg.type === 'action_resolved') {
      loadUnreadNotifs();
    }

    if (msg.type === 'chat_cancelled') {
      const partial = streamingRef.current;
      if (partial) {
        setMessages(prev => [...prev, {
          id: Date.now(),
          role: 'assistant',
          content: partial + ' *(cancelled)*',
          time: new Date().toLocaleTimeString([], { hour: 'numeric', minute: '2-digit' })
        }]);
      }
      setStreaming('');
      setStatusMsg('');
      setIsTyping(false);
      scrollToBottom();
    }

    if (msg.type === 'chat_stream') {
      setStreaming(prev => prev + msg.delta);
      setIsTyping(false);
      scrollToBottom();
    }

    if (msg.type === 'chat_status') {
      setStatusMsg(msg.message);
    }

    if (msg.type === 'chat_response' || msg.type === 'voice_response') {
      const finalText = streamingRef.current + (msg.text || msg.response || msg.message || '');
      setMessages(prev => [...prev, {
        id: Date.now(),
        role: 'assistant',
        content: finalText,
        time: new Date().toLocaleTimeString([], { hour: 'numeric', minute: '2-digit' })
      }]);
      setStreaming('');
      setStatusMsg('');
      setIsTyping(false);
      loadChips();
      scrollToBottom();

      // TTS for voice responses
      if (msg.type === 'voice_response' || lastVoiceRef.current) {
        speak(finalText);
        lastVoiceRef.current = false;
      }
    }
  }, [lastMessage, addToast, speak]);

  // Auto-scroll when messages change
  useEffect(() => { scrollToBottom(); }, [messages, streaming, isTyping]);

  // -- Send handler --
  async function handleSend(text, isVoice = false) {
    let msg = (text || input).trim();
    if (!msg || isTyping) return;
    setInput('');

    // Web search intercept
    if (interceptWebSearch(msg)) return;

    // Prepend attached file context
    if (attachedFile) {
      msg = '[Attached: ' + attachedFile.name + ']\n' + attachedFile.content + '\n\n' + msg;
      setAttachedFile(null);
    }

    setMessages(prev => [...prev, {
      id: Date.now(),
      role: 'user',
      content: msg,
      time: new Date().toLocaleTimeString([], { hour: 'numeric', minute: '2-digit' }),
      voice: isVoice
    }]);
    setIsTyping(true);
    setStreaming('');
    setStatusMsg('');
    lastVoiceRef.current = isVoice;
    scrollToBottom();

    // Save to conversations API
    try {
      await fetch('/api/conversations', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ role: 'user', content: msg })
      });
    } catch(e) {}

    // Send via WebSocket
    send({ type: isVoice ? 'voice_chat' : 'chat', message: msg, transcript: msg });
    inputRef.current?.focus();
  }

  // -- Cancel active response --
  async function handleCancel() {
    try { await fetch('/api/cancel', { method: 'POST' }); } catch(e) {}
    setIsTyping(false);
    setStreaming('');
    setStatusMsg('');
  }

  // -- Voice toggle --
  function handleVoiceToggle() {
    if (speaking) { stopSpeaking(); return; }
    if (recording) { stopRecording(); return; }
    startRecording((transcript) => {
      handleSend(transcript, true);
    });
  }

  // -- Chip action --
  function handleChipAction(prompt) {
    handleSend(prompt);
  }

  // -- Auto-resize textarea --
  function handleTextareaChange(e) {
    setInput(e.target.value);
    const el = e.target;
    el.style.height = 'auto';
    el.style.height = Math.min(el.scrollHeight, 120) + 'px';
  }

  // -- Open compose with optional pre-fill --
  function openCompose(replyData) {
    setComposeReplyTo(replyData || null);
    setComposeOpen(true);
  }

  // -- Chat search --
  async function handleChatSearch() {
    if (!searchQuery.trim()) return;
    setSearchLoading(true);
    try {
      const res = await fetch('/api/conversations/search?q=' + encodeURIComponent(searchQuery));
      const d = await res.json();
      setSearchResults(d.results || d.conversations || d.messages || []);
    } catch(e) { setSearchResults([]); }
    setSearchLoading(false);
  }

  // -- File drop handlers --
  function handleDragOver(e) {
    e.preventDefault();
    e.stopPropagation();
    setDragOver(true);
  }
  function handleDragLeave(e) {
    e.preventDefault();
    e.stopPropagation();
    setDragOver(false);
  }
  async function handleFileDrop(e) {
    e.preventDefault();
    e.stopPropagation();
    setDragOver(false);
    const file = e.dataTransfer?.files?.[0];
    if (!file) return;
    const allowed = ['pdf','txt','md','csv','docx'];
    const ext = file.name.split('.').pop().toLowerCase();
    if (!allowed.includes(ext)) {
      addToast('Unsupported file', 'Supported: PDF, TXT, MD, CSV, DOCX', 'high');
      return;
    }
    const form = new FormData();
    form.append('file', file);
    try {
      const res = await fetch('/api/chat/upload', { method: 'POST', body: form });
      const d = await res.json();
      setAttachedFile({ name: file.name, content: d.text || d.content || '' });
      addToast('File attached', file.name, 'normal');
    } catch(err) {
      addToast('Upload failed', err.message, 'high');
    }
  }

  // -- Web search intercept --
  function interceptWebSearch(text) {
    const searchMatch = text.match(/^(?:search|web):\s*(.+)$/i);
    if (!searchMatch) return false;
    const query = searchMatch[1].trim();
    setMessages(prev => [...prev, {
      id: Date.now(),
      role: 'user',
      content: text,
      time: new Date().toLocaleTimeString([], { hour: 'numeric', minute: '2-digit' })
    }]);
    setIsTyping(true);
    scrollToBottom();
    fetch('/api/search/web', {
      method: 'POST', headers: {'Content-Type':'application/json'},
      body: JSON.stringify({ query })
    })
      .then(r => r.json())
      .then(d => {
        const results = d.results || d.items || [];
        let formatted = '**Web Search Results for "' + query + '"**\n\n';
        if (results.length === 0) {
          formatted += 'No results found.';
        } else {
          results.forEach((r, i) => {
            formatted += (i+1) + '. **' + (r.title || 'Result') + '**\n';
            if (r.url) formatted += '   ' + r.url + '\n';
            if (r.snippet || r.description) formatted += '   ' + (r.snippet || r.description) + '\n';
            formatted += '\n';
          });
          formatted += '\n*Want me to analyze these results?*';
        }
        setMessages(prev => [...prev, {
          id: Date.now(),
          role: 'assistant',
          content: formatted,
          time: new Date().toLocaleTimeString([], { hour: 'numeric', minute: '2-digit' })
        }]);
        setIsTyping(false);
        scrollToBottom();
      })
      .catch(() => {
        setMessages(prev => [...prev, {
          id: Date.now(), role: 'assistant', content: 'Web search failed. Please try again.',
          time: new Date().toLocaleTimeString([], { hour: 'numeric', minute: '2-digit' })
        }]);
        setIsTyping(false);
      });
    return true;
  }

  // -- Render messages --
  function renderMessage(msg, idx) {
    // Briefing card
    if (msg.type === 'briefing') {
      return (
        <div key={msg.id || idx} style={{ marginBottom: 8 }}>
          <BriefingCard
            data={msg.data}
            onOpenInbox={() => setInboxOpen(true)}
            onChipAction={handleChipAction}
          />
        </div>
      );
    }

    // Proactive message
    if (msg.type === 'proactive') {
      return (
        <div key={msg.id || idx} style={{ marginBottom: 6 }}>
          <div className="chat-bubble proactive">
            <div className="proactive-label">Proactive Alert</div>
            {msg.content}
          </div>
        </div>
      );
    }

    // System message
    if (msg.role === 'system') {
      return (
        <div key={msg.id || idx} style={{ marginBottom: 6 }}>
          <div className="chat-bubble system">{msg.content}</div>
        </div>
      );
    }

    // User message
    if (msg.role === 'user') {
      return (
        <div key={msg.id || idx} style={{ marginBottom: 6 }}>
          <div className="chat-bubble user">
            {msg.voice && <span style={{ fontSize: 11, opacity: 0.7 }}>&#127908; </span>}
            {msg.content}
          </div>
          {msg.time && <div className="chat-time" style={{ textAlign: 'right' }}>{msg.time}</div>}
        </div>
      );
    }

    // Assistant message
    const meta = (() => { try { return JSON.parse(msg.metadata || '{}'); } catch { return {}; } })();
    const isMeetingPrep = meta.type === 'meeting_prep';
    const isProactive = meta.source === 'heartbeat' || meta.source === 'standing_order';
    const renderedHtml = (typeof marked !== 'undefined' && msg.content)
      ? marked.parse(msg.content)
      : (msg.content || '');
    return (
      <div key={msg.id || idx} style={{ marginBottom: 6 }}>
        <div
          className={`chat-bubble assistant${isProactive ? ' proactive-msg' : ''}${isMeetingPrep ? ' meeting-prep-msg' : ''}`}
          dangerouslySetInnerHTML={{ __html: renderedHtml }}
        />
        {msg.time && <div className="chat-time" style={{ textAlign: 'left' }}>{msg.time}</div>}
      </div>
    );
  }

  // Active module (replaces activeTab for main content)
  const activeModule = (activeTab === 'chat') ? 'inbox' : activeTab;
  function setActiveModule(mod) { setActiveTab(mod); }

  function handleAskAbout(prompt) {
    handleChipAction(prompt);
    setMobileAiOpen(true);
  }

  function handleOpenCompose(replyTo) {
    setComposeReplyTo(replyTo || null);
    setComposeOpen(true);
  }

  return (
    <div className="app-shell">

      {/* ── Left Navigation (desktop/tablet) ── */}
      <AppNav
        activeModule={activeModule}
        onNavigate={setActiveModule}
        todayCount={todayCount}
        wsConnected={wsConnected}
        onOpenBrief={() => setBriefOpen(true)}
      />

      {/* ── Main Content ── */}
      <div className="app-content">
        <ModuleRouter
          module={activeModule}
          onAskAbout={handleAskAbout}
          onOpenCompose={handleOpenCompose}
          wsMsg={lastMessage}
          todayCount={todayCount}
        />
      </div>

      {/* ── AI Sidebar (desktop/tablet, always visible) ── */}
      <AISidebar
        messages={messages}
        streaming={streaming}
        isTyping={isTyping}
        statusMsg={statusMsg}
        input={input}
        setInput={setInput}
        onSend={(forcedPrompt) => {
          if (forcedPrompt && typeof forcedPrompt === 'string') {
            setInput(forcedPrompt);
            setTimeout(() => handleSend(forcedPrompt), 80);
          } else {
            handleSend();
          }
        }}
        wsConnected={wsConnected}
        activeModule={activeModule}
        messagesEndRef={messagesEndRef}
        inputRef={inputRef}
        recording={recording}
        speaking={speaking}
        supported={supported}
        onVoiceToggle={handleVoiceToggle}
        onCancel={handleCancel}
        attachedFile={attachedFile}
        onClearFile={() => setAttachedFile(null)}
      />

      {/* ── Mobile Bottom Nav ── */}
      <div className="mobile-nav-bar">
        <div className="mobile-nav-bar-items">
          {[
            {id:'inbox',    icon:'\uD83D\uDCEC', label:'Inbox',    badge: todayCount},
            {id:'calendar', icon:'\uD83D\uDCC5', label:'Calendar'},
            {id:'work',     icon:'\u2713',  label:'Work'},
            {id:'notes',    icon:'\uD83D\uDCDD', label:'Notes'},
          ].map(t => (
            <button key={t.id} className={`mobile-nav-btn ${activeModule===t.id?'active':''}`} onClick={()=>setActiveModule(t.id)}>
              {t.badge > 0 && <span className="mobile-nav-badge">{t.badge}</span>}
              <span className="mobile-nav-btn-icon">{t.icon}</span>
              <span className="mobile-nav-btn-label">{t.label}</span>
            </button>
          ))}
          <button className="mobile-nav-btn" onClick={()=>setMenuOpen(true)}>
            <span className="mobile-nav-btn-icon">{'\u22EF'}</span>
            <span className="mobile-nav-btn-label">More</span>
          </button>
        </div>
      </div>

      {/* ── Mobile AI Floating Button ── */}
      <button className="mobile-ai-fab" onClick={()=>setMobileAiOpen(true)} title="Ask AI">{'\u2726'}</button>

      {/* ── Mobile AI Sheet ── */}
      <div className={`app-ai-mobile-sheet ${mobileAiOpen?'open':''}`} onClick={e=>{if(e.target.classList.contains('app-ai-mobile-sheet'))setMobileAiOpen(false);}}>
        <div className="app-ai-mobile-content">
          <AISidebar
            messages={messages}
            streaming={streaming}
            isTyping={isTyping}
            statusMsg={statusMsg}
            input={input}
            setInput={setInput}
            onSend={(forcedPrompt) => {
              if (forcedPrompt && typeof forcedPrompt === 'string') {
                setInput(forcedPrompt);
                setTimeout(() => handleSend(forcedPrompt), 80);
              } else {
                handleSend();
              }
            }}
            wsConnected={wsConnected}
            activeModule={activeModule}
            messagesEndRef={messagesEndRef}
            inputRef={null}
            recording={recording}
            speaking={speaking}
            supported={supported}
            onVoiceToggle={handleVoiceToggle}
            onCancel={handleCancel}
            attachedFile={attachedFile}
            onClearFile={() => setAttachedFile(null)}
          />
        </div>
      </div>

      {/* ── Overlay Panels (modals, keep all existing ones) ── */}
      <InboxPanel open={inboxOpen} onClose={()=>setInboxOpen(false)} onHandleMessage={handleAskAbout} wsMsg={lastMessage} onOpenCompose={(rt)=>{setComposeReplyTo(rt||null);setInboxOpen(false);setComposeOpen(true);}} />
      <StandingOrdersPanel open={ordersOpen} onClose={()=>setOrdersOpen(false)} />
      <NotifPanel open={notifsOpen} onClose={()=>setNotifsOpen(false)} />
      <JournalPanel open={journalOpen} onClose={()=>setJournalOpen(false)} />
      <StatsPanel open={statsOpen} onClose={()=>setStatsOpen(false)} />
      <ActionsPanel open={actionsOpen} onClose={()=>setActionsOpen(false)} onHandleMessage={handleAskAbout} />
      <ToolsPanel open={toolsOpen} onClose={()=>setToolsOpen(false)} />
      <CalendarPanel open={calendarOpen} onClose={()=>setCalendarOpen(false)} />
      <TasksPanel open={tasksOpen} onClose={()=>setTasksOpen(false)} />
      <KnowledgePanel open={knowledgeOpen} onClose={()=>setKnowledgeOpen(false)} />
      <DocumentsPanel open={docsOpen} onClose={()=>setDocsOpen(false)} />
      <MorningBriefPanel open={briefOpen} onClose={()=>setBriefOpen(false)} preloadedData={briefData} preloadedLoading={briefLoading} />
      <ComposeEmailPanel open={composeOpen} onClose={()=>setComposeOpen(false)} replyTo={composeReplyTo} />
      <ProjectsPanel open={projectsOpen} onClose={()=>setProjectsOpen(false)} onAskAbout={handleAskAbout} />
      <DelegationPanel open={delegationsOpen} onClose={()=>setDelegationsOpen(false)} />
      <MenuPanel
        open={menuOpen}
        onClose={()=>setMenuOpen(false)}
        onOpenOrders={()=>{setMenuOpen(false);setOrdersOpen(true);}}
        onOpenJournal={()=>setJournalOpen(true)}
        onOpenStats={()=>setStatsOpen(true)}
        onOpenActions={()=>setActionsOpen(true)}
        onOpenTools={()=>setToolsOpen(true)}
        onOpenCalendar={()=>setCalendarOpen(true)}
        onOpenTasks={()=>setTasksOpen(true)}
        onOpenNotes={()=>{setMenuOpen(false);setActiveModule('notes');}}
        onOpenKnowledge={()=>setKnowledgeOpen(true)}
        onOpenDocs={()=>setDocsOpen(true)}
        onOpenBrief={()=>setBriefOpen(true)}
        onOpenProjects={()=>{setMenuOpen(false);setActiveModule('projects');}}
        onOpenDelegations={()=>{setMenuOpen(false);setActiveModule('delegations');}}
        onOpenCompose={()=>{setMenuOpen(false);setComposeOpen(true);}}
      />
    </div>
  );
}

// ── Root ─────────────────────────────────────────────────────────────────────
function Root() {
  return (
    <ToastProvider>
      <ChatOS />
    </ToastProvider>
  );
}

ReactDOM.createRoot(document.getElementById('root')).render(<Root />);
</script>
</body>
</html>
