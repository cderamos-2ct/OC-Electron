      React.createElement('div', {style:{padding:'24px 28px 16px',borderBottom:'1px solid var(--border)',flexShrink:0}},
        React.createElement('div', {style:{fontSize:18,fontWeight:700,color:'var(--text)',marginBottom:10}}, selectedMsg.subject || '(no subject)'),
        React.createElement('div', {style:{fontSize:13,color:'var(--muted)'}}, 'From ', React.createElement('strong', {style:{color:'var(--text)'}}, sender)),
        selectedMsg.timestamp && React.createElement('div', {style:{fontSize:13,color:'var(--muted)',marginTop:2}}, 'Date: ', timeAgo(selectedMsg.timestamp))
      ),
      // Action toolbar
      React.createElement('div', {style:{height:44,padding:'0 28px',display:'flex',gap:8,alignItems:'center',borderBottom:'1px solid var(--border)',background:'var(--surface)',flexShrink:0}},
