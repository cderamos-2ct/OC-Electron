    fetch('/api/knowledge/search', {method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({query})})
      .then(r=>r.json()).then(d=>setResults(d.results||[])).catch(()=>{});
  }
  return (
    <div style={{flex:1,overflowY:'auto',padding:'20px'}}>
      <div style={{display:'flex',gap:8,marginBottom:16}}>
        <input value={query} onChange={e=>setQuery(e.target.value)} onKeyDown={e=>e.key==='Enter'&&search()} placeholder="Search knowledge base..." style={{flex:1,background:'var(--surface2)',border:'1px solid var(--border)',borderRadius:8,padding:'8px 12px',color:'var(--text)',fontSize:13,outline:'none'}} />
        <button onClick={search} style={{background:'var(--accent)',color:'#000',border:'none',borderRadius:8,padding:'8px 14px',cursor:'pointer',fontWeight:600,fontSize:12}}>Search</button>
        <button onClick={()=>onAskAbout('Search knowledge base for: '+query)} style={{background:'rgba(34,211,238,0.1)',color:'var(--accent)',border:'1px solid rgba(34,211,238,0.3)',borderRadius:8,padding:'8px 10px',cursor:'pointer',fontSize:12}}>{'\u2726'} Ask AI</button>
      </div>
      {results.length > 0 ? results.map((r,i) => (
        <div key={i} style={{padding:'12px 16px',background:'var(--surface)',borderRadius:10,marginBottom:8,border:'1px solid var(--border)'}}>
          <div style={{fontSize:12,fontWeight:600,color:'var(--text)',marginBottom:4}}>{r.document||r.title}</div>
          <div style={{fontSize:12,color:'var(--muted)',lineHeight:1.6}}>{r.content||r.snippet}</div>
        </div>
      )) : (
        <div style={{color:'var(--muted)',fontSize:13}}>Enter a search query to search your knowledge base, or ask AI to synthesize an answer.</div>
      )}
    </div>
  );
}

