                <button onClick={()=>deleteReminder(r.id)} style={{background:'none',border:'none',color:'var(--red)',cursor:'pointer',fontSize:14,flexShrink:0}}>{'\uD83D\uDDD1'}</button>
              </div>
            ))
          )}
        </div>
      </div>
    </>
  );
}

// ── Notes Panel ──────────────────────────────────────────────────────────────
function NotesPanel({ open, onClose }) {
  const [notes, setNotes] = React.useState([]);
  const [loading, setLoading] = React.useState(true);
  const [search, setSearch] = React.useState('');
  const [editing, setEditing] = React.useState(null); // null = list, {id?,title,content,tags} = edit
  const [saving, setSaving] = React.useState(false);

  const load = React.useCallback(() => {
    setLoading(true);
    const params = search ? `?search=${encodeURIComponent(search)}` : '';
    fetch(`/api/notes${params}`)
      .then(r=>r.json())
      .then(d=>{ setNotes(d.notes||[]); setLoading(false); })
      .catch(()=>setLoading(false));
  }, [search]);

  React.useEffect(()=>{ if(open) load(); }, [open, load]);

  async function saveNote() {
    if(!editing?.content?.trim() && !editing?.title?.trim()) return;
    setSaving(true);
    try {
      if(editing.id) {
        await fetch(`/api/notes/${editing.id}`, {
          method:'PUT', headers:{'Content-Type':'application/json'},
          body: JSON.stringify({ title:editing.title, content:editing.content, tags:editing.tags })
        });
      } else {
        await fetch('/api/notes', {
          method:'POST', headers:{'Content-Type':'application/json'},
          body: JSON.stringify({ title:editing.title, content:editing.content, tags:editing.tags||'' })
        });
      }
      setEditing(null);
      load();
    } catch(e){}
    setSaving(false);
  }

  async function deleteNote(id) {
    try {
      await fetch(`/api/notes/${id}`, { method:'DELETE' });
      setNotes(prev => prev.filter(n=>n.id!==id));
    } catch(e){}
  }

  async function togglePin(note) {
    try {
      await fetch(`/api/notes/${note.id}`, {
        method:'PUT', headers:{'Content-Type':'application/json'},
        body: JSON.stringify({ pinned: note.pinned ? 0 : 1 })
      });
      setNotes(prev => prev.map(n => n.id===note.id ? {...n, pinned: note.pinned?0:1} : n));
    } catch(e){}
  }

  const [notesMobile, setNotesMobile] = React.useState(window.innerWidth < 768);
  React.useEffect(() => {
    const onResize = () => setNotesMobile(window.innerWidth < 768);
    window.addEventListener('resize', onResize);
    return () => window.removeEventListener('resize', onResize);
  }, []);

  if (!open) return null;

  // Shared: notes list renderer
  function renderNotesList(onSelectNote) {
    return (
      <>
        <div style={{padding:'8px 16px'}}>
          <input className="search-input" placeholder="Search notes..." value={search}
            onChange={e=>setSearch(e.target.value)} onKeyDown={e=>e.key==='Enter'&&load()} />
        </div>
        <div style={{flex:1,overflowY:'auto'}}>
          {loading ? <div className="loading"><div className="spinner"></div></div>
          : notes.length === 0 ? <div className="empty"><div className="empty-icon">{'\uD83D\uDCDD'}</div><div>No notes yet</div><div style={{marginTop:8,fontSize:12,color:'var(--muted)'}}>Tap + New to create one</div></div>
          : notes.map(n => (
            <div key={n.id} style={{padding:'12px 16px',borderBottom:'1px solid var(--border)',cursor:'pointer',background: editing && editing.id === n.id ? 'var(--surface2)' : 'transparent'}} onClick={()=>onSelectNote({...n})}>
              <div style={{display:'flex',alignItems:'flex-start',gap:8}}>
                <div style={{flex:1}}>
                  {n.title && <div style={{fontSize:13,fontWeight:600,color:'var(--text)',marginBottom:2}}>{n.title}</div>}
                  <div style={{fontSize:12,color:'var(--muted)',overflow:'hidden',display:'-webkit-box',WebkitLineClamp:2,WebkitBoxOrient:'vertical'}}>{n.content}</div>
                  <div style={{display:'flex',gap:6,marginTop:4,alignItems:'center'}}>
                    <span style={{fontSize:10,color:'var(--muted)'}}>{n.updated_at?new Date(n.updated_at).toLocaleDateString():''}</span>
                    {n.apple_synced && <span className="apple-badge">{'\uD83C\uDF4E'}</span>}
                    {n.tags && n.tags.split(',').map((t,i)=>(
                      <span key={i} style={{fontSize:10,background:'var(--surface2)',border:'1px solid var(--border)',borderRadius:4,padding:'1px 5px',color:'var(--accent2)'}}>{t.trim()}</span>
                    ))}
                  </div>
                </div>
                <div style={{display:'flex',flexDirection:'column',gap:4}}>
                  <button onClick={e=>{e.stopPropagation();togglePin(n);}} style={{background:'none',border:'none',cursor:'pointer',fontSize:14,opacity:n.pinned?1:0.3}} title={n.pinned?'Unpin':'Pin'}>{'\uD83D\uDCCC'}</button>
                  <button onClick={e=>{e.stopPropagation();deleteNote(n.id);}} style={{background:'none',border:'none',cursor:'pointer',fontSize:14,color:'var(--red)'}} title="Delete">{'\uD83D\uDDD1'}</button>
                </div>
              </div>
            </div>
          ))}
        </div>
      </>
    );
  }

  // Shared: editor renderer
  function renderEditor() {
    if (!editing) {
      return <div style={{flex:1,display:'flex',alignItems:'center',justifyContent:'center',color:'var(--muted)',fontSize:13}}>{'\u2190'} Select a note</div>;
    }
    return (
      <div style={{flex:1,display:'flex',flexDirection:'column',padding:16,gap:10,overflow:'auto'}}>
        <div style={{display:'flex',justifyContent:'space-between',alignItems:'center'}}>
          <span style={{fontSize:11,color:'var(--muted)',fontWeight:600}}>EDITING</span>
          <div style={{display:'flex',gap:6}}>
            <button onClick={saveNote} disabled={saving} style={{background:'var(--green)',color:'#000',border:'none',borderRadius:6,padding:'5px 12px',fontSize:12,fontWeight:700,cursor:'pointer',opacity:saving?0.6:1}}>Save</button>
            <button onClick={()=>setEditing(null)} style={{background:'var(--surface2)',border:'1px solid var(--border)',borderRadius:6,padding:'5px 10px',fontSize:12,color:'var(--muted)',cursor:'pointer'}}>Cancel</button>
          </div>
        </div>
        <input style={{background:'var(--bg)',border:'1px solid var(--border)',borderRadius:8,padding:'10px 12px',color:'var(--text)',fontSize:15,fontWeight:600}}
          placeholder="Title (optional)" value={editing.title} onChange={e=>setEditing(p=>({...p,title:e.target.value}))} />
        <textarea style={{flex:1,background:'var(--bg)',border:'1px solid var(--border)',borderRadius:8,padding:'10px 12px',color:'var(--text)',fontSize:13,resize:'none',minHeight:200,lineHeight:1.6}}
          placeholder="Write your note..." value={editing.content} onChange={e=>setEditing(p=>({...p,content:e.target.value}))} />
        <input style={{background:'var(--bg)',border:'1px solid var(--border)',borderRadius:8,padding:'8px 12px',color:'var(--muted)',fontSize:12}}
          placeholder="Tags (comma separated)" value={editing.tags||''} onChange={e=>setEditing(p=>({...p,tags:e.target.value}))} />
      </div>
    );
  }

  // Desktop: full-screen two-column layout
  if (!notesMobile) {
    return (
      <>
        <div className="panel-overlay" onClick={()=>{ if(!editing) onClose(); else setEditing(null); }}></div>
        <div style={{position:'fixed',inset:0,zIndex:500,display:'flex',flexDirection:'row',height:'100%'}}>
          {/* Left column: notes list */}
          <div style={{width:280,flexShrink:0,borderRight:'1px solid var(--border)',display:'flex',flexDirection:'column',background:'var(--surface)',height:'100%'}}>
            <div style={{padding:'12px 16px',display:'flex',alignItems:'center',gap:8,borderBottom:'1px solid var(--border)',flexShrink:0}}>
              <span style={{fontSize:15,fontWeight:700,flex:1}}>{'\uD83D\uDCDD'} Notes</span>
              <button onClick={()=>setEditing({title:'',content:'',tags:''})} style={{background:'var(--accent)',color:'#000',border:'none',borderRadius:6,padding:'4px 10px',fontSize:12,fontWeight:600,cursor:'pointer'}}>+ New</button>
              <button onClick={onClose} style={{background:'none',border:'none',color:'var(--muted)',fontSize:20,cursor:'pointer',lineHeight:1}}>{'\u00D7'}</button>
            </div>
            {renderNotesList(n => setEditing(n))}
          </div>
          {/* Right column: editor */}
          <div style={{flex:1,display:'flex',flexDirection:'column',background:'var(--bg)',height:'100%'}}>
            {renderEditor()}
          </div>
        </div>
      </>
    );
  }

  // Mobile: existing bottom-sheet behavior
  return (
    <>
      <div className="panel-overlay" onClick={()=>{ if(!editing) onClose(); else setEditing(null); }}></div>
      <div className="inbox-panel">
        <div className="inbox-drag-handle"></div>
        <div className="inbox-header">
          <span className="inbox-title">{'\uD83D\uDCDD'} Notes</span>
          {!editing && <button onClick={()=>setEditing({title:'',content:'',tags:''})} style={{background:'var(--accent)',color:'#000',border:'none',borderRadius:8,padding:'6px 12px',fontSize:12,fontWeight:700,cursor:'pointer'}}>+ New</button>}
          {!editing && <button onClick={async()=>{try{const r=await fetch('/api/notes/import-apple',{method:'POST'});const d=await r.json();load();alert('Imported '+(d.count||0)+' notes from Apple Notes');}catch(e){alert('Import failed');}}} style={{background:'var(--surface2)',border:'1px solid var(--border)',borderRadius:8,padding:'6px 10px',fontSize:11,cursor:'pointer',color:'var(--text)'}}>{'\u2B07'} Apple Notes</button>}
          {editing && <button onClick={saveNote} disabled={saving} style={{background:'var(--green)',color:'#000',border:'none',borderRadius:8,padding:'6px 12px',fontSize:12,fontWeight:700,cursor:'pointer',opacity:saving?0.6:1}}>Save</button>}
          <button className="inbox-close" onClick={()=>editing?setEditing(null):onClose()}>{editing?'\u2190':'\u00D7'}</button>
        </div>

        {editing ? (
          <div style={{flex:1,display:'flex',flexDirection:'column',padding:16,gap:10,overflow:'auto'}}>
            <input style={{background:'var(--bg)',border:'1px solid var(--border)',borderRadius:8,padding:'10px 12px',color:'var(--text)',fontSize:15,fontWeight:600}}
              placeholder="Title (optional)" value={editing.title} onChange={e=>setEditing(p=>({...p,title:e.target.value}))} />
            <textarea style={{flex:1,background:'var(--bg)',border:'1px solid var(--border)',borderRadius:8,padding:'10px 12px',color:'var(--text)',fontSize:13,resize:'none',minHeight:200,lineHeight:1.6}}
              placeholder="Write your note..." value={editing.content} onChange={e=>setEditing(p=>({...p,content:e.target.value}))} />
            <input style={{background:'var(--bg)',border:'1px solid var(--border)',borderRadius:8,padding:'8px 12px',color:'var(--muted)',fontSize:12}}
              placeholder="Tags (comma separated)" value={editing.tags||''} onChange={e=>setEditing(p=>({...p,tags:e.target.value}))} />
          </div>
        ) : (
          <>
            {renderNotesList(n => setEditing(n))}
          </>
        )}
      </div>
    </>
  );
}

// ── Knowledge Panel ─────────────────────────────────────────────────────────
function KnowledgePanel({ open, onClose }) {
  const [memories, setMemories] = React.useState([]);
  const [loading, setLoading] = React.useState(false);
  const [filter, setFilter] = React.useState('All');
  const [editingKey, setEditingKey] = React.useState(null);
  const [editValue, setEditValue] = React.useState('');
  const [newKey, setNewKey] = React.useState('');
  const [newValue, setNewValue] = React.useState('');
  const [showAdd, setShowAdd] = React.useState(false);
  const [saving, setSaving] = React.useState(false);

  const CATEGORY_MAP = [
    { prefix: 'conversation_summary_', label: 'History' },
    { prefix: 'user_', label: 'Personal' },
    { prefix: 'sleep_', label: 'Personal' },
    { prefix: 'availability_', label: 'Personal' },
    { prefix: 'wife_', label: 'Family' },
    { prefix: 'son_', label: 'Family' },
    { prefix: 'daughter_', label: 'Family' },
    { prefix: 'family_', label: 'Family' },
    { prefix: 'business_', label: 'Professional' },
    { prefix: 'company_', label: 'Professional' },
    { prefix: 'project_', label: 'Professional' },
    { prefix: 'telegram_', label: 'Preferences' },
    { prefix: 'preference_', label: 'Preferences' },
    { prefix: 'relationship_', label: 'Relationships' },
  ];

  function getCategory(key) {
    for (const { prefix, label } of CATEGORY_MAP) {
      if (key.startsWith(prefix)) return label;
    }
    return 'General';
  }

  const CATEGORIES = ['All', 'Personal', 'Family', 'Professional', 'Preferences', 'Relationships', 'History', 'General'];

  React.useEffect(() => {
    if (open) loadMemories();
  }, [open]);

  async function loadMemories() {
    setLoading(true);
    try {
      const r = await fetch('/api/memories');
      const d = await r.json();
      setMemories(d.memories || []);
    } catch(e) {}
    setLoading(false);
  }

  async function saveEdit(key) {
    if (!editValue.trim()) return;
    setSaving(true);
    try {
      await fetch(`/api/memories/${encodeURIComponent(key)}`, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ value: editValue })
      });
      setEditingKey(null);
      await loadMemories();
    } catch(e) {}
    setSaving(false);
  }

  async function deleteMemory(key) {
    if (!confirm(`Delete memory: "${key}"?`)) return;
    try {
      await fetch(`/api/memories/${encodeURIComponent(key)}`, { method: 'DELETE' });
      await loadMemories();
    } catch(e) {}
  }

  async function addMemory() {
    if (!newKey.trim() || !newValue.trim()) return;
    setSaving(true);
    try {
      await fetch('/api/memories', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ key: newKey.trim(), value: newValue.trim() })
      });
      setNewKey(''); setNewValue(''); setShowAdd(false);
      await loadMemories();
    } catch(e) {}
    setSaving(false);
  }

  const filtered = filter === 'All' ? memories : memories.filter(m => getCategory(m.key) === filter);

  function formatKey(key) {
    return key.replace(/_/g, ' ').replace(/\b\w/g, c => c.toUpperCase());
  }

  if (!open) return null;
  return (
    <div className="panel-overlay" onClick={onClose}>
      <div className="inbox-panel" onClick={e => e.stopPropagation()} style={{ maxHeight: '92vh', overflowY: 'auto' }}>
        <div className="panel-header">
          <span>🧠 Knowledge</span>
          <div style={{ display: 'flex', gap: 8 }}>
            <button className="chip" onClick={() => setShowAdd(v => !v)} style={{ fontSize: 12, padding: '4px 10px' }}>+ Add</button>
            <button className="panel-close" onClick={onClose}>✕</button>
          </div>
        </div>

        {/* Add form */}
        {showAdd && (
          <div style={{ padding: '8px 16px', background: 'var(--surface2)', borderBottom: '1px solid var(--border)' }}>
            <input
              placeholder="Key (e.g. user_hobby)"
              value={newKey}
              onChange={e => setNewKey(e.target.value)}
              style={{ width: '100%', marginBottom: 6, padding: '6px 8px', background: 'var(--surface)', border: '1px solid var(--border)', borderRadius: 6, color: 'var(--text)', fontSize: 13 }}
            />
            <textarea
              placeholder="Value"
              value={newValue}
              onChange={e => setNewValue(e.target.value)}
              rows={2}
              style={{ width: '100%', marginBottom: 6, padding: '6px 8px', background: 'var(--surface)', border: '1px solid var(--border)', borderRadius: 6, color: 'var(--text)', fontSize: 13, resize: 'vertical' }}
            />
            <button onClick={addMemory} disabled={saving} style={{ background: 'var(--accent)', color: '#000', border: 'none', borderRadius: 6, padding: '6px 14px', cursor: 'pointer', fontSize: 13 }}>
              {saving ? 'Saving\u2026' : 'Save'}
            </button>
          </div>
        )}

        {/* Category filter pills */}
        <div style={{ display: 'flex', gap: 6, padding: '8px 12px', overflowX: 'auto', borderBottom: '1px solid var(--border)' }}>
          {CATEGORIES.filter(c => c === 'All' || memories.some(m => getCategory(m.key) === c)).map(cat => (
            <button key={cat}
              onClick={() => setFilter(cat)}
              style={{
                padding: '4px 10px', borderRadius: 20, border: 'none', cursor: 'pointer', fontSize: 12, whiteSpace: 'nowrap',
                background: filter === cat ? 'var(--accent)' : 'var(--surface2)',
                color: filter === cat ? '#000' : 'var(--muted)'
              }}>
              {cat} {cat === 'All' ? `(${memories.length})` : `(${memories.filter(m => getCategory(m.key) === cat).length})`}
            </button>
          ))}
        </div>

        {/* Memory list */}
        <div style={{ padding: 12 }}>
          {loading && <div style={{ color: 'var(--muted)', textAlign: 'center', padding: 24 }}>Loading\u2026</div>}
          {!loading && filtered.length === 0 && (
            <div style={{ color: 'var(--muted)', textAlign: 'center', padding: 24 }}>No memories in this category</div>
          )}
          {filtered.map(mem => (
            <div key={mem.key} style={{ background: 'var(--surface)', borderRadius: 8, padding: '10px 12px', marginBottom: 8, border: '1px solid var(--border)' }}>
              <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'flex-start', gap: 8 }}>
                <div style={{ flex: 1, minWidth: 0 }}>
                  <div style={{ display: 'flex', alignItems: 'center', gap: 6, marginBottom: 4 }}>
                    <span style={{ fontSize: 11, color: 'var(--accent)', background: 'rgba(34,211,238,0.1)', padding: '2px 6px', borderRadius: 4 }}>
                      {getCategory(mem.key)}
                    </span>
                    <span style={{ fontSize: 12, color: 'var(--muted)', fontFamily: 'monospace' }}>{mem.key}</span>
                  </div>
                  {editingKey === mem.key ? (
                    <div>
                      <textarea
                        value={editValue}
                        onChange={e => setEditValue(e.target.value)}
                        rows={3}
                        style={{ width: '100%', padding: '6px 8px', background: 'var(--surface2)', border: '1px solid var(--accent)', borderRadius: 6, color: 'var(--text)', fontSize: 13, resize: 'vertical' }}
                      />
                      <div style={{ display: 'flex', gap: 6, marginTop: 4 }}>
                        <button onClick={() => saveEdit(mem.key)} disabled={saving}
                          style={{ background: 'var(--accent)', color: '#000', border: 'none', borderRadius: 6, padding: '4px 12px', cursor: 'pointer', fontSize: 12 }}>
                          {saving ? '\u2026' : 'Save'}
                        </button>
                        <button onClick={() => setEditingKey(null)}
                          style={{ background: 'var(--surface2)', color: 'var(--muted)', border: '1px solid var(--border)', borderRadius: 6, padding: '4px 12px', cursor: 'pointer', fontSize: 12 }}>
                          Cancel
                        </button>
                      </div>
                    </div>
                  ) : (
                    <div style={{ fontSize: 13, color: 'var(--text)', wordBreak: 'break-word', maxHeight: 80, overflow: 'hidden', cursor: 'pointer' }}
                      onClick={() => { setEditingKey(mem.key); setEditValue(mem.value); }}>
                      {mem.value.length > 200 ? mem.value.substring(0, 200) + '\u2026' : mem.value}
                    </div>
                  )}
                </div>
                {editingKey !== mem.key && (
                  <div style={{ display: 'flex', gap: 4, flexShrink: 0 }}>
                    <button onClick={() => { setEditingKey(mem.key); setEditValue(mem.value); }}
                      style={{ background: 'none', border: 'none', cursor: 'pointer', fontSize: 14, color: 'var(--muted)', padding: '2px 4px' }}>\u270f\ufe0f</button>
                    <button onClick={() => deleteMemory(mem.key)}
                      style={{ background: 'none', border: 'none', cursor: 'pointer', fontSize: 14, color: 'var(--red)', padding: '2px 4px' }}>🗑</button>
                  </div>
                )}
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  );
}

// ── Documents Panel ──────────────────────────────────────────────────────────
function DocumentsPanel({ open, onClose }) {
  const [docs, setDocs] = React.useState([]);
  const [loading, setLoading] = React.useState(false);
  const [uploading, setUploading] = React.useState(false);
  const [searchQ, setSearchQ] = React.useState('');
  const [searchResults, setSearchResults] = React.useState(null);
  const [error, setError] = React.useState('');
  const fileRef = React.useRef();

  React.useEffect(() => {
    if (open) loadDocs();
  }, [open]);

  async function loadDocs() {
    setLoading(true);
    try {
      const r = await fetch('/api/documents');
      const d = await r.json();
      setDocs(d.documents || []);
    } catch(e) {}
    setLoading(false);
  }

  async function handleUpload(e) {
    const file = e.target.files?.[0];
    if (!file) return;
    setUploading(true); setError('');
    const form = new FormData();
    form.append('file', file);
    try {
      const r = await fetch('/api/documents', { method: 'POST', body: form });
      const d = await r.json();
      if (!r.ok) { setError(d.detail || 'Upload failed'); }
      else { await loadDocs(); }
    } catch(e) { setError('Upload failed: ' + e.message); }
    setUploading(false);
    if (fileRef.current) fileRef.current.value = '';
  }

  async function deleteDoc(id, filename) {
    if (!confirm(`Delete "${filename}"?`)) return;
    try {
      await fetch(`/api/documents/${id}`, { method: 'DELETE' });
      await loadDocs();
    } catch(e) {}
  }

  async function handleSearch(e) {
    e.preventDefault();
    if (!searchQ.trim()) return;
    try {
      const r = await fetch(`/api/documents/search?q=${encodeURIComponent(searchQ)}&limit=5`);
      const d = await r.json();
      setSearchResults(d.results || []);
    } catch(e) {}
  }

  function fmtSize(bytes) {
    if (bytes < 1024) return bytes + 'B';
    if (bytes < 1024*1024) return (bytes/1024).toFixed(1) + 'KB';
    return (bytes/1024/1024).toFixed(1) + 'MB';
  }

  if (!open) return null;
  return (
    <div className="panel-overlay" onClick={onClose}>
      <div className="inbox-panel" onClick={e => e.stopPropagation()} style={{ maxHeight: '92vh', overflowY: 'auto' }}>
        <div className="panel-header">
          <span>📄 Documents</span>
          <button className="panel-close" onClick={onClose}>✕</button>
        </div>

        {/* Upload area */}
        <div style={{ padding: '12px 16px', borderBottom: '1px solid var(--border)' }}>
          <div style={{ display: 'flex', gap: 8, alignItems: 'center', flexWrap: 'wrap' }}>
            <input ref={fileRef} type="file" accept=".pdf,.txt,.md,.csv,.json" onChange={handleUpload}
              style={{ display: 'none' }} id="doc-upload" />
            <label htmlFor="doc-upload"
              style={{ background: 'var(--accent)', color: '#000', padding: '7px 14px', borderRadius: 8, cursor: 'pointer', fontSize: 13, fontWeight: 600 }}>
              {uploading ? '\u23f3 Uploading\u2026' : '\u2b06 Upload Document'}
            </label>
            <span style={{ fontSize: 11, color: 'var(--muted)' }}>PDF, TXT, MD, CSV \u2022 Max 10MB</span>
          </div>
          {error && <div style={{ color: 'var(--red)', fontSize: 12, marginTop: 6 }}>{error}</div>}
        </div>

        {/* Search */}
        <div style={{ padding: '10px 16px', borderBottom: '1px solid var(--border)' }}>
          <form onSubmit={handleSearch} style={{ display: 'flex', gap: 8 }}>
            <input
              value={searchQ} onChange={e => setSearchQ(e.target.value)}
              placeholder="Search document content\u2026"
              style={{ flex: 1, padding: '7px 10px', background: 'var(--surface)', border: '1px solid var(--border)', borderRadius: 8, color: 'var(--text)', fontSize: 13 }}
            />
            <button type="submit"
              style={{ background: 'var(--surface2)', border: '1px solid var(--border)', borderRadius: 8, padding: '7px 12px', color: 'var(--text)', cursor: 'pointer', fontSize: 13 }}>
              🔍
            </button>
            {searchResults !== null && (
              <button type="button" onClick={() => { setSearchResults(null); setSearchQ(''); }}
                style={{ background: 'none', border: 'none', color: 'var(--muted)', cursor: 'pointer', fontSize: 13 }}>✕</button>
            )}
          </form>
        </div>

        {/* Search results */}
        {searchResults !== null && (
          <div style={{ padding: '10px 16px', borderBottom: '1px solid var(--border)' }}>
            <div style={{ fontSize: 12, color: 'var(--muted)', marginBottom: 8 }}>
              {searchResults.length} result{searchResults.length !== 1 ? 's' : ''} for "{searchQ}"
            </div>
            {searchResults.length === 0 && <div style={{ color: 'var(--muted)', fontSize: 13 }}>No matches found</div>}
            {searchResults.map((r, i) => (
              <div key={i} style={{ background: 'var(--surface)', borderRadius: 8, padding: 10, marginBottom: 8, border: '1px solid var(--border)' }}>
                <div style={{ fontSize: 11, color: 'var(--accent)', marginBottom: 4 }}>{r.filename} \u00b7 chunk {r.chunk_index + 1}</div>
                <div style={{ fontSize: 12, color: 'var(--text)', lineHeight: 1.5 }}>{r.content.substring(0, 300)}{r.content.length > 300 ? '\u2026' : ''}</div>
              </div>
            ))}
          </div>
        )}

        {/* Document list */}
        <div style={{ padding: 12 }}>
          {loading && <div style={{ color: 'var(--muted)', textAlign: 'center', padding: 24 }}>Loading\u2026</div>}
          {!loading && docs.length === 0 && (
            <div style={{ color: 'var(--muted)', textAlign: 'center', padding: 32 }}>
              <div style={{ fontSize: 32, marginBottom: 8 }}>📄</div>
              <div>No documents uploaded yet</div>
              <div style={{ fontSize: 12, marginTop: 4 }}>Upload PDFs or text files for the assistant to reference</div>
            </div>
          )}
          {docs.map(doc => (
            <div key={doc.id} style={{ background: 'var(--surface)', borderRadius: 8, padding: '10px 12px', marginBottom: 8, border: '1px solid var(--border)', display: 'flex', alignItems: 'center', gap: 10 }}>
              <div style={{ fontSize: 24, flexShrink: 0 }}>
                {doc.mime_type === 'application/pdf' ? '📕' : doc.filename.endsWith('.md') ? '📝' : '📄'}
              </div>
              <div style={{ flex: 1, minWidth: 0 }}>
                <div style={{ fontSize: 14, color: 'var(--text)', fontWeight: 500, overflow: 'hidden', textOverflow: 'ellipsis', whiteSpace: 'nowrap' }}>{doc.filename}</div>
                <div style={{ fontSize: 11, color: 'var(--muted)', marginTop: 2 }}>
                  {fmtSize(doc.file_size || 0)} \u00b7 {doc.chunk_count} chunk{doc.chunk_count !== 1 ? 's' : ''} \u00b7 {doc.created_at?.substring(0, 10)}
                </div>
              </div>
              <button onClick={() => deleteDoc(doc.id, doc.filename)}
                style={{ background: 'none', border: 'none', color: 'var(--red)', cursor: 'pointer', fontSize: 16, padding: '4px 6px', flexShrink: 0 }}>🗑</button>
            </div>
          ))}
        </div>
      </div>
    </div>
  );
}

