  // Mobile layout
  if (isMobile) {
    return React.createElement('div', {style:{display:'flex',flexDirection:'column',height:'100%',overflow:'hidden'}},
      selectedId ? renderMobileDetail() : renderMessageList(true)
    );
  }

  // Desktop layout
  return React.createElement('div', {style:{display:'flex',flexDirection:'row',height:'100%',overflow:'hidden'}},
    renderMessageList(false),
    renderReadingPane()
  );
}

// ── Today Tab View Component ────────────────────────────────────────────────
function TodayTabView({ onAskAbout }) {
  const [events, setEvents] = React.useState([]);
  const [tasks, setTasks] = React.useState([]);
  const [loading, setLoading] = React.useState(true);

  React.useEffect(() => {
    setLoading(true);
    Promise.all([
      fetch('/api/calendar?days=3').then(r=>r.json()).catch(()=>({events:[]})),
      fetch('/api/tasks').then(r=>r.json()).catch(()=>({tasks:[]}))
    ]).then(([cal, tsk]) => {
      setEvents(cal.events || []);
      setTasks(tsk.tasks || tsk.items || []);
      setLoading(false);
    });
  }, []);

  async function toggleTask(id, done) {
    try {
      await fetch('/api/tasks/' + id, {
        method: 'PUT',
        headers: {'Content-Type':'application/json'},
        body: JSON.stringify({completed: !done})
      });
      setTasks(prev => prev.map(t => t.id===id ? {...t, completed: !done, status: !done ? 'completed' : 'active'} : t));
    } catch(e) {}
  }

  const grouped = events.reduce((acc, e) => {
    const d = e.date || 'Today';
    if (!acc[d]) acc[d] = [];
    acc[d].push(e);
    return acc;
  }, {});
  const dateKeys = Object.keys(grouped).slice(0, 3);

  const pendingTasks = tasks.filter(t => !t.completed && t.status !== 'completed').slice(0, 10);
  const doneTasks = tasks.filter(t => t.completed || t.status === 'completed').slice(0, 5);

  return (
    <div className="tab-view">
      <div className="tab-view-header">
        <span className="tab-view-title">Today</span>
        <button onClick={()=>onAskAbout("What's on my calendar and task list today? Give me a quick briefing.")}
                style={{background:'var(--accent)',color:'#000',border:'none',borderRadius:8,padding:'5px 12px',fontSize:12,fontWeight:700,cursor:'pointer'}}>
          Brief Me
        </button>
      </div>
      <div className="tab-view-body">
        {loading ? <div className="loading"><div className="spinner"></div></div> : (
          <>
            {dateKeys.length > 0 && (
              <div className="tab-view-section">
                <div className="tab-view-section-title">📅 Calendar</div>
                {dateKeys.map(date => (
                  <div key={date}>
                    <div style={{fontSize:11,color:'var(--muted)',fontWeight:700,marginBottom:6,marginTop:date!==dateKeys[0]?12:0}}>{date}</div>
                    {grouped[date].map((e,i) => (
                      <div key={i} className="event-card">
                        <div className="event-time-col">{e.time || 'All day'}</div>
                        <div className="event-info">
                          <div className="event-title">{e.title || e.summary}</div>
                          {e.location && <div className="event-detail">📍 {e.location}</div>}
                          {e.attendees && e.attendees.length > 0 && <div className="event-detail">👥 {e.attendees.slice(0,2).join(', ')}{e.attendees.length>2 ? ' +' + (e.attendees.length-2) : ''}</div>}
                        </div>
                      </div>
                    ))}
                  </div>
                ))}
              </div>
            )}
            {events.length === 0 && (
              <div className="tab-view-section">
                <div className="tab-view-section-title">📅 Calendar</div>
                <div style={{fontSize:13,color:'var(--muted)',padding:'4px 0 12px'}}>No upcoming events</div>
              </div>
            )}
            <div style={{height:1,background:'var(--border)',margin:'4px 0'}}></div>
            <div className="tab-view-section">
              <div className="tab-view-section-title">✅ Tasks ({pendingTasks.length} pending)</div>
            </div>
            {pendingTasks.length === 0 && <div style={{padding:'4px 16px 12px',fontSize:13,color:'var(--muted)'}}>All tasks complete 🎉</div>}
            {pendingTasks.map((t,i) => (
              <div key={t.id||i} className="task-row" onClick={()=>toggleTask(t.id, false)}>
                <div className="task-check"></div>
                <div className="task-text">{t.title || t.name || t.content}</div>
                {t.due_date && <div style={{fontSize:11,color:'var(--muted)',flexShrink:0}}>{t.due_date}</div>}
              </div>
            ))}
            {doneTasks.length > 0 && (
              <>
                <div style={{padding:'8px 16px 4px',fontSize:10,fontWeight:700,textTransform:'uppercase',letterSpacing:1,color:'var(--muted)'}}>Done Today</div>
                {doneTasks.map((t,i) => (
                  <div key={t.id||i} className="task-row" onClick={()=>toggleTask(t.id, true)}>
                    <div className="task-check done">✓</div>
                    <div className="task-text done">{t.title || t.name || t.content}</div>
                  </div>
                ))}
              </>
            )}
            <div style={{height:20}}></div>
          </>
        )}
      </div>
    </div>
  );
}

// ── Actions Tab View Component ──────────────────────────────────────────────
function ActionsTabView({ onAskAbout }) {
  const [actions, setActions] = React.useState([]);
  const [loading, setLoading] = React.useState(true);
  const [filter, setFilter] = React.useState('pending');

  const load = React.useCallback(() => {
    setLoading(true);
    fetch('/api/actions?status=' + filter + '&limit=30')
      .then(r=>r.json())
      .then(d=>{ setActions(d.actions||d.items||[]); setLoading(false); })
      .catch(()=>setLoading(false));
  }, [filter]);

  React.useEffect(load, [load]);

  async function resolve(id, status) {
    const endpoint = status === 'approved' ? 'approve' : 'reject';
    try {
      await fetch('/api/actions/' + id + '/' + endpoint, {
        method: 'POST', headers:{'Content-Type':'application/json'},
        body: JSON.stringify({})
      });
      setActions(prev => prev.filter(a => a.id !== id));
    } catch(e) {}
  }

  const priorityClass = function(p) { return (p||'').toLowerCase() === 'high' ? 'high' : (p||'').toLowerCase() === 'medium' ? 'medium' : 'low'; };

  return (
    <div className="tab-view">
      <div className="tab-view-header">
        <span className="tab-view-title">Actions</span>
        <span style={{fontSize:13,color:'var(--accent)',fontWeight:700}}>{actions.length} pending</span>
      </div>
      <div style={{padding:'8px 12px',borderBottom:'1px solid var(--border)',display:'flex',gap:6,flexShrink:0}}>
        {[{id:'pending',label:'Pending'},{id:'approved',label:'Approved'},{id:'rejected',label:'Rejected'}].map(f=>(
          <button key={f.id} className={`filter-pill ${filter===f.id?'active':''}`} style={{fontSize:11,padding:'5px 12px'}} onClick={()=>setFilter(f.id)}>{f.label}</button>
        ))}
      </div>
      <div className="tab-view-body">
        {loading ? <div className="loading"><div className="spinner"></div></div>
        : actions.length === 0 ? <div className="empty"><div className="empty-icon">⚡</div><div>{filter==='pending'?'No pending actions':'Nothing here'}</div></div>
        : actions.map((a,i) => (
          <div key={a.id||i} className={'action-card ' + priorityClass(a.priority)}>
            <div className="action-card-title">{a.title || a.subject || 'Action needed'}</div>
            <div className="action-card-body">{a.description || a.content || a.body || ''}</div>
            {a.source && <div style={{fontSize:10,color:'var(--muted)',marginBottom:8}}>Source: {a.source}</div>}
            {filter === 'pending' && (
              <div className="action-card-buttons">
                <button className="action-btn approve" onClick={()=>resolve(a.id,'approved')}>✓ Approve</button>
                <button className="action-btn reject" onClick={()=>resolve(a.id,'rejected')}>✗ Reject</button>
                <button className="action-btn delegate" onClick={()=>onAskAbout('Help me respond to this action item: ' + a.title)}>Ask AI</button>
              </div>
            )}
          </div>
        ))}
      </div>
    </div>
  );
}

