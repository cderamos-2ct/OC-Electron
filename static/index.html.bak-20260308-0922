              <button onClick={addReminder} disabled={addingRem||!newRemTitle.trim()} style={{background:'var(--accent)',color:'#000',border:'none',borderRadius:8,padding:'8px 14px',fontSize:13,fontWeight:700,cursor:'pointer',opacity:addingRem?0.6:1}}>+</button>
