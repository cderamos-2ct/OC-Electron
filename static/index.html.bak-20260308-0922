<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover, user-scalable=no">
<meta name="mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="theme-color" content="#0a0a0a">
<link rel="manifest" href="/manifest.json">
<link rel="apple-touch-icon" href="/icon-192.png">
<title>AntiGravity</title>
<script src="https://cdn.jsdelivr.net/npm/marked@9/marked.min.js"></script>
<style>
/* ── Design Tokens ──────────────────────────────────────────────────────── */
:root {
  --bg: #0a0a0a; --surface: #141414; --surface2: #1c1c1c; --border: #2a2a2a;
  --text: #e4e4e7; --muted: #71717a; --accent: #22d3ee; --accent2: #818cf8;
  --green: #34d399; --red: #f87171; --orange: #fb923c; --yellow: #fbbf24;
  --high: #f87171; --med: #fb923c; --low: #71717a;
  --radius: 12px; --safe-top: env(safe-area-inset-top, 20px);
  --safe-bottom: env(safe-area-inset-bottom, 0px);
}
* { margin: 0; padding: 0; box-sizing: border-box; }
body { font-family: -apple-system, 'SF Pro', 'Inter', system-ui, sans-serif; background: var(--bg); color: var(--text); min-height: 100dvh; overflow: hidden; -webkit-font-smoothing: antialiased; }
#root { height: 100dvh; display: flex; flex-direction: column; }

/* ── Chat OS Layout ─────────────────────────────────────────────────────── */
.chat-os { display: flex; flex-direction: column; height: 100dvh; background: var(--bg); }

/* Header */
.chat-os-header {
  display: flex; align-items: center; justify-content: space-between;
  padding: calc(var(--safe-top) + 8px) 16px 10px;
  background: var(--surface); border-bottom: 1px solid var(--border); flex-shrink: 0;
}
.logo { display: flex; align-items: center; gap: 10px; }
.logo-mark { background: linear-gradient(135deg, var(--accent), var(--accent2)); color: #000; font-weight: 800; font-size: 14px; width: 32px; height: 32px; border-radius: 8px; display: flex; align-items: center; justify-content: center; }
.logo-text { font-size: 18px; font-weight: 700; letter-spacing: -0.5px; }
.header-right { display: flex; align-items: center; gap: 10px; }

.status-dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; position: relative; }
.status-dot.connected { background: var(--green); box-shadow: 0 0 6px var(--green); }
.status-dot.connected::after { content:''; position: absolute; inset: -3px; border-radius: 50%; border: 1.5px solid var(--green); opacity: 0; animation: pulse 2s ease infinite; }
.status-dot.disconnected { background: var(--red); box-shadow: 0 0 6px var(--red); }
.status-dot.degraded { background: var(--orange); box-shadow: 0 0 6px var(--orange); }
@keyframes pulse { 0% { opacity: 0.6; transform: scale(1); } 100% { opacity: 0; transform: scale(1.8); } }

.today-badge {
  display: flex; align-items: center; gap: 5px; padding: 5px 10px;
  background: var(--surface2); border: 1px solid var(--border); border-radius: 20px;
  cursor: pointer; font-size: 12px; font-weight: 600; color: var(--accent);
  transition: all 0.15s; user-select: none;
}
.today-badge:active { background: var(--accent); color: #000; border-color: var(--accent); }
.today-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--accent); }

.notif-btn { position: relative; background: none; border: none; color: var(--muted); font-size: 20px; cursor: pointer; padding: 6px; }
.notif-btn.has-notifs { color: var(--accent); }
.notif-badge { position: absolute; top: 0; right: 0; background: var(--red); color: #fff; font-size: 10px; font-weight: 700; min-width: 16px; height: 16px; border-radius: 8px; display: flex; align-items: center; justify-content: center; padding: 0 4px; }

.menu-btn { background: none; border: none; color: var(--muted); font-size: 22px; cursor: pointer; padding: 4px; line-height: 1; }

/* ── Chat Messages Area ─────────────────────────────────────────────────── */
.chat-messages-area {
  flex: 1; overflow-y: auto; padding: 12px 16px 8px;
  -webkit-overflow-scrolling: touch; scroll-behavior: smooth;
}

/* Chat Bubbles */
.chat-bubble { max-width: 88%; padding: 10px 14px; border-radius: 16px; margin-bottom: 6px; font-size: 14px; line-height: 1.5; white-space: pre-wrap; word-break: break-word; }
.chat-bubble.user { background: var(--accent); color: #000; margin-left: auto; border-bottom-right-radius: 4px; }
.chat-bubble.assistant { background: var(--surface2); border: 1px solid var(--border); border-bottom-left-radius: 4px; white-space: normal; }
/* Markdown rendering inside assistant bubbles */
.chat-bubble.assistant p { margin: 0 0 7px; }
.chat-bubble.assistant p:last-child { margin-bottom: 0; }
.chat-bubble.assistant h1,.chat-bubble.assistant h2,.chat-bubble.assistant h3 { font-weight: 700; margin: 10px 0 4px; color: var(--accent); line-height: 1.3; }
.chat-bubble.assistant h1 { font-size: 1.05em; }
.chat-bubble.assistant h2 { font-size: 1em; }
.chat-bubble.assistant h3 { font-size: 0.95em; color: var(--accent2); }
.chat-bubble.assistant ul,.chat-bubble.assistant ol { padding-left: 18px; margin: 4px 0 8px; }
.chat-bubble.assistant li { margin-bottom: 3px; }
.chat-bubble.assistant code { background: rgba(255,255,255,0.08); padding: 1px 5px; border-radius: 4px; font-family: 'SF Mono',monospace; font-size: 12px; }
.chat-bubble.assistant pre { background: rgba(0,0,0,0.5); border: 1px solid var(--border); border-radius: 8px; padding: 10px 12px; margin: 8px 0; overflow-x: auto; }
.chat-bubble.assistant pre code { background: none; padding: 0; }
.chat-bubble.assistant strong { font-weight: 700; color: var(--text); }
.chat-bubble.assistant em { color: var(--muted); }
.chat-bubble.assistant a { color: var(--accent); text-decoration: underline; }
.chat-bubble.assistant blockquote { border-left: 3px solid var(--accent2); padding: 2px 0 2px 10px; color: var(--muted); margin: 6px 0; }
.chat-bubble.assistant table { width: 100%; border-collapse: collapse; font-size: 12px; margin: 8px 0; }
.chat-bubble.assistant th,.chat-bubble.assistant td { border: 1px solid var(--border); padding: 5px 8px; text-align: left; }
.chat-bubble.assistant th { background: var(--surface); font-weight: 700; }
.chat-bubble.assistant hr { border: none; border-top: 1px solid var(--border); margin: 8px 0; }
.chat-bubble.system { background: transparent; border: 1px solid var(--border); color: var(--muted); font-size: 12px; text-align: center; margin: 0 auto 12px; max-width: 100%; }
.chat-time { font-size: 10px; color: var(--muted); margin-bottom: 8px; padding: 0 4px; }

/* Proactive message (from heartbeat / alerts) */
.chat-bubble.proactive {
  background: rgba(34,211,238,0.06); border: 1px solid rgba(34,211,238,0.18);
  color: var(--text); margin: 4px 0; border-radius: 12px; font-size: 13px;
  max-width: 100%; padding: 10px 14px;
}
.proactive-label { font-size: 10px; text-transform: uppercase; letter-spacing: 0.5px; color: var(--accent); font-weight: 700; margin-bottom: 4px; }

/* Streaming cursor */
.stream-cursor { display: inline-block; width: 2px; height: 1em; background: var(--accent); margin-left: 2px; vertical-align: text-bottom; animation: blink 1s step-end infinite; }

/* Status message below streaming */
.status-msg { font-size: 12px; color: var(--muted); padding: 2px 14px 6px; display: flex; align-items: center; gap: 6px; }

/* Typing indicator */
.typing-indicator { display: flex; gap: 4px; padding: 10px 14px; background: var(--surface2); border: 1px solid var(--border); border-radius: 16px; border-bottom-left-radius: 4px; width: fit-content; margin-bottom: 6px; }
.typing-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--muted); animation: bounce 1.4s infinite; }
.typing-dot:nth-child(2) { animation-delay: 0.2s; }
.typing-dot:nth-child(3) { animation-delay: 0.4s; }
@keyframes bounce { 0%,60%,100% { transform: translateY(0); } 30% { transform: translateY(-5px); } }

/* Stop / cancel button */
.stop-btn { width: 36px; height: 36px; border-radius: 50%; border: none; background: var(--red); color: #fff; font-size: 14px; cursor: pointer; display: flex; align-items: center; justify-content: center; flex-shrink: 0; transition: opacity .15s; }
.stop-btn:hover { opacity: .8; }
@keyframes blink { 0%,100% { opacity: 1; } 50% { opacity: 0; } }

/* ── Suggested Chips ────────────────────────────────────────────────────── */
.suggested-chips {
  display: flex; gap: 8px; padding: 8px 16px; overflow-x: auto; flex-shrink: 0;
  border-top: 1px solid var(--border); background: var(--surface);
  -ms-overflow-style: none; scrollbar-width: none;
}
.suggested-chips:empty { display: none; }
.suggested-chips::-webkit-scrollbar { display: none; }
.chip {
  display: flex; align-items: center; gap: 6px; padding: 8px 14px;
  background: var(--surface2); border: 1px solid var(--border); border-radius: 20px;
  color: var(--text); font-size: 13px; font-weight: 500; cursor: pointer;
  white-space: nowrap; flex-shrink: 0; transition: all 0.15s; user-select: none;
}
.chip:active { background: var(--accent); color: #000; border-color: var(--accent); transform: scale(0.97); }

/* ── Input Row ──────────────────────────────────────────────────────────── */
.chat-input-row {
  display: flex; gap: 8px; padding: 10px 16px;
  padding-bottom: calc(10px + var(--safe-bottom));
  background: var(--surface); border-top: 1px solid var(--border);
  align-items: flex-end; flex-shrink: 0;
}
.chat-textarea {
  flex: 1; background: var(--surface2); border: 1px solid var(--border); border-radius: 20px;
  padding: 10px 16px; color: var(--text); font-size: 14px; resize: none; outline: none;
  font-family: inherit; max-height: 120px; overflow-y: auto; line-height: 1.4;
}
.chat-textarea::placeholder { color: var(--muted); }
.send-btn {
  width: 40px; height: 40px; min-width: 40px; border-radius: 50%;
  background: var(--accent); color: #000; border: none; font-size: 18px; cursor: pointer;
  display: flex; align-items: center; justify-content: center; transition: all 0.15s;
}
.send-btn:disabled { opacity: 0.3; cursor: default; }
.mic-btn {
  width: 40px; height: 40px; min-width: 40px; border-radius: 50%;
  border: 1.5px solid var(--border); background: var(--surface2); color: var(--muted);
  font-size: 18px; cursor: pointer; display: flex; align-items: center; justify-content: center;
  transition: all 0.2s;
}
.mic-btn.recording { background: var(--red); color: #fff; border-color: var(--red); animation: mic-pulse 1s ease infinite; }
.mic-btn.speaking { background: var(--accent); color: #000; border-color: var(--accent); }
@keyframes mic-pulse { 0%,100% { box-shadow: 0 0 0 0 rgba(248,113,113,0.4); } 50% { box-shadow: 0 0 0 8px rgba(248,113,113,0); } }

/* ── Briefing Card ──────────────────────────────────────────────────────── */
.briefing-card { background: var(--surface); border: 1px solid var(--border); border-radius: 16px; overflow: hidden; margin-bottom: 8px; max-width: 100%; }
.briefing-greeting { padding: 14px 16px 10px; border-bottom: 1px solid var(--border); }
.briefing-greeting-name { font-size: 18px; font-weight: 700; color: var(--text); }
.briefing-greeting-date { font-size: 12px; color: var(--muted); margin-top: 2px; }
.briefing-section { padding: 10px 16px; border-bottom: 1px solid var(--border); }
.briefing-section:last-of-type { border-bottom: none; }
.briefing-section.urgent { border-left: 3px solid var(--red); }
.briefing-section.important { border-left: 3px solid var(--orange); }
.briefing-section.fyi { border-left: 3px solid var(--border); }
.briefing-section-title { font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 8px; }
.briefing-section.urgent .briefing-section-title { color: var(--red); }
.briefing-section.important .briefing-section-title { color: var(--orange); }
.briefing-section.fyi .briefing-section-title { color: var(--muted); }
.briefing-item { margin-bottom: 8px; }
.briefing-item:last-child { margin-bottom: 0; }
.briefing-item-text { font-size: 13px; color: var(--text); line-height: 1.4; margin-bottom: 4px; }
.briefing-item-actions { display: flex; gap: 6px; flex-wrap: wrap; }
.briefing-action-btn {
  padding: 4px 10px; border-radius: 6px; border: 1px solid var(--border);
  background: var(--surface2); color: var(--accent); font-size: 11px; font-weight: 600;
  cursor: pointer; transition: all 0.15s;
}
.briefing-action-btn:active { background: var(--accent); color: #000; }
.briefing-inbox-btn {
  width: 100%; padding: 10px; background: transparent; border: none;
  border-top: 1px solid var(--border); color: var(--muted); font-size: 12px;
  cursor: pointer; text-align: center; transition: color 0.15s;
}
.briefing-inbox-btn:active { color: var(--accent); }

/* ── Inbox Panel (slide-up) ─────────────────────────────────────────────── */
.panel-overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.6); z-index: 50; }
.inbox-panel {
  position: fixed; bottom: 0; left: 0; right: 0; height: 92dvh;
  background: var(--bg); border-top-left-radius: 20px; border-top-right-radius: 20px;
  border-top: 1px solid var(--border); z-index: 51;
  display: flex; flex-direction: column; animation: slide-up 0.3s ease;
}
@keyframes slide-up { from { transform: translateY(100%); } to { transform: translateY(0); } }
.inbox-drag-handle { width: 36px; height: 4px; background: var(--border); border-radius: 2px; margin: 8px auto 4px; flex-shrink: 0; }
.inbox-header {
  padding: 8px 16px 10px; display: flex; align-items: center; gap: 12px;
  border-bottom: 1px solid var(--border); flex-shrink: 0; flex-wrap: wrap;
}
.inbox-title { font-size: 18px; font-weight: 700; flex: 1; }
.inbox-close { background: none; border: none; color: var(--muted); font-size: 24px; cursor: pointer; line-height: 1; }
.inbox-filters { display: flex; gap: 6px; width: 100%; overflow-x: auto; padding-top: 4px; }
.inbox-content { flex: 1; overflow-y: auto; -webkit-overflow-scrolling: touch; }

/* Messages in inbox with expand */
.msg-item { padding: 12px 16px; border-bottom: 1px solid var(--border); cursor: pointer; transition: background 0.15s; }
.msg-item:active { background: var(--surface); }
.msg-priority { width: 4px; border-radius: 2px; flex-shrink: 0; align-self: stretch; }
.msg-priority.HIGH { background: var(--high); }
.msg-priority.MED { background: var(--med); }
.msg-priority.LOW { background: var(--low); }
.msg-row { display: flex; gap: 12px; }
.msg-body { flex: 1; min-width: 0; }
.msg-top { display: flex; justify-content: space-between; margin-bottom: 4px; }
.msg-sender { font-weight: 600; font-size: 14px; }
.msg-source { font-size: 11px; color: var(--muted); background: var(--surface2); padding: 1px 6px; border-radius: 4px; }
.msg-time { font-size: 11px; color: var(--muted); }
.msg-subject { font-size: 13px; font-weight: 500; margin-bottom: 2px; }
.msg-content-preview { font-size: 12px; color: var(--muted); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.msg-full-content {
  display: none; font-size: 13px; color: var(--text); line-height: 1.5;
  margin-top: 8px; white-space: pre-wrap; padding: 10px; background: var(--surface2); border-radius: 8px;
}
.msg-item.expanded .msg-full-content { display: block; }
.msg-item.expanded .msg-content-preview { display: none; }
.msg-actions-row { display: none; gap: 6px; margin-top: 8px; }
.msg-item.expanded .msg-actions-row { display: flex; }
.msg-action-btn {
  padding: 6px 12px; border-radius: 6px; border: 1px solid var(--border);
  background: var(--surface2); color: var(--accent); font-size: 12px; font-weight: 600; cursor: pointer;
  transition: all 0.15s;
}
.msg-action-btn:active { background: var(--accent); color: #000; }
.spam-btn { color: var(--red) !important; }
.unsub-btn { color: var(--orange) !important; }

/* Scoring indicator on inbox messages */
.msg-score { font-size: 10px; font-weight: 700; padding: 1px 6px; border-radius: 4px; }
.msg-score.urgent { background: rgba(248,113,113,0.15); color: var(--red); }
.msg-score.important { background: rgba(251,146,60,0.15); color: var(--orange); }
.msg-score.fyi { background: rgba(113,113,122,0.15); color: var(--muted); }

/* ── Notification Panel (slide from right) ──────────────────────────────── */
.notif-panel { position: fixed; top: 0; right: -100%; width: 100%; max-width: 360px; height: 100%; background: var(--bg); border-left: 1px solid var(--border); z-index: 100; transition: right 0.3s ease; display: flex; flex-direction: column; }
.notif-panel.open { right: 0; }
.notif-overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.5); z-index: 99; display: none; }
.notif-overlay.open { display: block; }
.notif-header { padding: calc(var(--safe-top) + 12px) 16px 12px; display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid var(--border); }
.notif-title { font-size: 18px; font-weight: 700; }
.notif-close { background: none; border: none; color: var(--muted); font-size: 24px; cursor: pointer; }
.notif-list { flex: 1; overflow-y: auto; }
.notif-item { padding: 12px 16px; border-bottom: 1px solid var(--border); }
.notif-item.unread { border-left: 3px solid var(--accent); }
.notif-item-title { font-size: 14px; font-weight: 600; margin-bottom: 2px; }
.notif-item-body { font-size: 12px; color: var(--muted); }
.notif-item-time { font-size: 10px; color: var(--muted); margin-top: 4px; }

/* ── Toast ──────────────────────────────────────────────────────────────── */
.toast-container { position: fixed; top: calc(var(--safe-top) + 60px); right: 16px; z-index: 300; display: flex; flex-direction: column; gap: 8px; pointer-events: none; }
.toast { background: var(--surface); border: 1px solid var(--border); border-radius: 12px; padding: 12px 16px; min-width: 260px; max-width: 340px; box-shadow: 0 8px 24px rgba(0,0,0,0.4); animation: toast-in 0.3s ease; pointer-events: all; }
.toast.high { border-left: 3px solid var(--red); }
.toast-title { font-size: 13px; font-weight: 700; margin-bottom: 2px; }
.toast-body { font-size: 12px; color: var(--muted); }
@keyframes toast-in { from { opacity: 0; transform: translateX(80px); } to { opacity: 1; transform: translateX(0); } }

/* ── Filter / Search (reused in inbox) ──────────────────────────────────── */
.filter-pill { padding: 6px 14px; border-radius: 20px; border: 1px solid var(--border); background: none; color: var(--muted); font-size: 12px; font-weight: 600; cursor: pointer; white-space: nowrap; transition: all 0.15s; }
.filter-pill.active { background: var(--accent); color: #000; border-color: var(--accent); }
.search-input { width: 100%; background: var(--surface2); border: 1px solid var(--border); border-radius: 10px; padding: 10px 16px; color: var(--text); font-size: 14px; outline: none; font-family: inherit; }
.search-input::placeholder { color: var(--muted); }

/* ── Modal ──────────────────────────────────────────────────────────────── */
.modal-overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.6); z-index: 200; display: flex; align-items: center; justify-content: center; padding: 20px; }
.modal { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); padding: 20px; width: 100%; max-width: 500px; }
.modal h3 { font-size: 16px; margin-bottom: 12px; }

/* ── Loading / Empty ────────────────────────────────────────────────────── */
.loading { display: flex; align-items: center; justify-content: center; padding: 40px; gap: 8px; }
.spinner { width: 20px; height: 20px; border: 2px solid var(--border); border-top-color: var(--accent); border-radius: 50%; animation: spin 0.6s linear infinite; }
@keyframes spin { to { transform: rotate(360deg); } }
.empty { text-align: center; padding: 60px 20px; color: var(--muted); }
.empty-icon { font-size: 40px; margin-bottom: 8px; }

/* ── Menu Panel ─────────────────────────────────────────────────────────── */
.menu-panel { position: fixed; top: 0; right: -100%; width: 100%; max-width: 300px; height: 100%; background: var(--bg); border-left: 1px solid var(--border); z-index: 100; transition: right 0.3s ease; display: flex; flex-direction: column; }
.menu-panel.open { right: 0; }
.menu-header { padding: calc(var(--safe-top) + 12px) 16px 12px; display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid var(--border); }
.menu-item { padding: 14px 16px; border-bottom: 1px solid var(--border); font-size: 14px; font-weight: 500; cursor: pointer; display: flex; align-items: center; gap: 10px; color: var(--text); transition: background 0.15s; }
.menu-item:active { background: var(--surface); }
.menu-item-icon { font-size: 18px; width: 24px; text-align: center; }
.menu-item-label { flex: 1; }

/* ── Meeting Prep & Proactive Message Styles ────────────────────────────── */
.proactive-msg {
  border-left: 3px solid #ffd43b;
  background: rgba(255, 212, 59, 0.05);
}
.meeting-prep-msg {
  border-left: 3px solid var(--accent) !important;
  background: rgba(34, 211, 238, 0.08) !important;
}
.meeting-prep-msg::before {
  content: '📅 Meeting Prep';
  display: block;
  font-size: 10px;
  font-weight: 600;
  color: var(--accent);
  text-transform: uppercase;
  letter-spacing: 0.5px;
  margin-bottom: 6px;
}

/* ── Bottom Tab Bar ─────────────────────────────────────────────────────── */
.tab-bar {
  display: flex; flex-shrink: 0;
  background: var(--surface); border-top: 1px solid var(--border);
  padding-bottom: var(--safe-bottom);
}
.tab-item {
  flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: center;
  padding: 8px 4px 6px; cursor: pointer; gap: 3px; transition: color 0.15s;
  border: none; background: none; color: var(--muted); font-family: inherit;
  position: relative; min-height: 52px;
}
.tab-item.active { color: var(--accent); }
.tab-icon { font-size: 20px; line-height: 1; }
.tab-label { font-size: 10px; font-weight: 600; letter-spacing: 0.3px; }
.tab-badge {
  position: absolute; top: 4px; right: calc(50% - 18px);
  background: var(--red); color: #fff; font-size: 9px; font-weight: 700;
  min-width: 14px; height: 14px; border-radius: 7px; display: flex;
  align-items: center; justify-content: center; padding: 0 3px;
}

/* ── Widget Strip ───────────────────────────────────────────────────────── */
.widget-strip {
  display: flex; gap: 8px; padding: 8px 12px; flex-shrink: 0;
  background: var(--bg); border-bottom: 1px solid var(--border);
  overflow-x: auto; -webkit-overflow-scrolling: touch;
  scrollbar-width: none;
}
.widget-strip::-webkit-scrollbar { display: none; }
.widget-card {
  display: flex; align-items: center; gap: 7px;
  background: var(--surface); border: 1px solid var(--border); border-radius: 10px;
  padding: 7px 12px; cursor: pointer; flex-shrink: 0;
  transition: border-color 0.15s, background 0.15s;
  min-width: 0; white-space: nowrap;
}
.widget-card:active { background: var(--surface2); border-color: var(--accent); }
.widget-card.alert { border-color: rgba(248,113,113,0.4); }
.widget-card.ok { border-color: rgba(52,211,153,0.3); }
.widget-icon { font-size: 14px; }
.widget-value { font-size: 14px; font-weight: 700; color: var(--text); }
.widget-label { font-size: 11px; color: var(--muted); }
.widget-sub { font-size: 11px; color: var(--muted); max-width: 120px; overflow: hidden; text-overflow: ellipsis; }

/* ── Inline Tab Views ───────────────────────────────────────────────────── */
.tab-view { flex: 1; display: flex; flex-direction: column; overflow: hidden; }
.tab-view-header {
  padding: 12px 16px 8px; display: flex; align-items: center; justify-content: space-between;
  border-bottom: 1px solid var(--border); flex-shrink: 0;
}
.tab-view-title { font-size: 17px; font-weight: 700; }
.tab-view-body { flex: 1; overflow-y: auto; -webkit-overflow-scrolling: touch; }
.tab-view-section { padding: 12px 16px 0; }
.tab-view-section-title {
  font-size: 10px; font-weight: 700; text-transform: uppercase;
  letter-spacing: 1px; color: var(--muted); margin-bottom: 8px;
}

/* Inline event card */
.event-card {
  background: var(--surface); border: 1px solid var(--border); border-radius: 10px;
  padding: 10px 12px; margin-bottom: 8px; display: flex; gap: 10px; align-items: center;
}
.event-time-col { font-size: 12px; color: var(--accent); font-weight: 700; min-width: 52px; text-align: right; }
.event-info { flex: 1; min-width: 0; }
.event-title { font-size: 13px; font-weight: 600; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.event-detail { font-size: 11px; color: var(--muted); margin-top: 2px; }

/* Inline task row */
.task-row {
  display: flex; align-items: center; gap: 10px;
  padding: 9px 16px; border-bottom: 1px solid var(--border); cursor: pointer;
}
.task-check {
  width: 18px; height: 18px; border-radius: 50%; border: 2px solid var(--border);
  flex-shrink: 0; display: flex; align-items: center; justify-content: center;
  transition: all 0.15s;
}
.task-check.done { background: var(--green); border-color: var(--green); color: #000; font-size: 11px; }
.task-text { font-size: 13px; flex: 1; }
.task-text.done { text-decoration: line-through; color: var(--muted); }

/* Inline action card */
.action-card {
  background: var(--surface); border: 1px solid var(--border); border-radius: 10px;
  padding: 12px; margin: 8px 16px;
}
.action-card.high { border-left: 3px solid var(--red); }
.action-card.medium { border-left: 3px solid var(--orange); }
.action-card.low { border-left: 3px solid var(--border); }
.action-card-title { font-size: 13px; font-weight: 600; margin-bottom: 4px; }
.action-card-body { font-size: 12px; color: var(--muted); margin-bottom: 10px; line-height: 1.4; }
.action-card-buttons { display: flex; gap: 6px; }
.action-btn {
  flex: 1; padding: 7px 0; border-radius: 8px; border: 1px solid var(--border);
  font-size: 12px; font-weight: 700; cursor: pointer; transition: all 0.15s;
  background: transparent; color: var(--text); font-family: inherit;
}
.action-btn.approve { background: var(--green); color: #000; border-color: var(--green); }
.action-btn.reject { background: transparent; color: var(--red); border-color: rgba(248,113,113,0.4); }
.action-btn.delegate { color: var(--muted); }

/* Inline message row (for inbox tab) */
.inline-msg {
  padding: 11px 16px; border-bottom: 1px solid var(--border); display: flex; gap: 10px;
  cursor: pointer; transition: background 0.15s;
}
.inline-msg:active { background: var(--surface); }
.inline-msg-dot { width: 8px; height: 8px; border-radius: 50%; margin-top: 4px; flex-shrink: 0; }
.inline-msg-dot.HIGH { background: var(--red); }
.inline-msg-dot.MED { background: var(--orange); }
.inline-msg-dot.LOW { background: var(--border); }
.inline-msg-body { flex: 1; min-width: 0; }
.inline-msg-top { display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 2px; }
.inline-msg-sender { font-size: 13px; font-weight: 600; }
.inline-msg-time { font-size: 10px; color: var(--muted); }
.inline-msg-subject { font-size: 12px; color: var(--muted); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.inline-msg-source { font-size: 10px; background: var(--surface2); padding: 1px 5px; border-radius: 3px; color: var(--muted); }

/* ── Desktop 3-col layout ────────────────────────────────────────────────── */
@media (min-width: 768px) {
  .chat-os { flex-direction: row; overflow: hidden; }
  .desktop-sidebar-left {
    width: 200px; flex-shrink: 0; display: flex; flex-direction: column;
    border-right: 1px solid var(--border); background: var(--surface);
    padding-top: calc(var(--safe-top) + 8px);
  }
  .desktop-sidebar-right {
    width: 280px; flex-shrink: 0; display: flex; flex-direction: column;
    border-left: 1px solid var(--border); background: var(--surface);
    overflow-y: auto;
  }
  .desktop-center { flex: 1; display: flex; flex-direction: column; overflow: hidden; min-width: 0; }
  /* Hide mobile-only elements on desktop */
  .tab-bar { display: none; }
  .chat-os-header { display: none; }
  .widget-strip { display: none; }
  /* Desktop left nav items */
  .desktop-nav-logo { padding: 12px 16px 20px; }
  .desktop-nav-item {
    display: flex; align-items: center; gap: 10px; padding: 11px 16px;
    cursor: pointer; font-size: 13px; font-weight: 500; color: var(--muted);
    border-radius: 0; transition: all 0.15s; border: none; background: none;
    font-family: inherit; width: 100%; text-align: left;
  }
  .desktop-nav-item.active { color: var(--accent); background: rgba(34,211,238,0.08); }
  .desktop-nav-item:hover { color: var(--text); background: var(--surface2); }
  .desktop-nav-icon { font-size: 16px; width: 20px; text-align: center; flex-shrink: 0; }
  .desktop-nav-badge {
    margin-left: auto; background: var(--red); color: #fff; font-size: 10px;
    font-weight: 700; padding: 1px 6px; border-radius: 8px;
  }
  .desktop-sys-stats { margin-top: auto; padding: 12px 16px; border-top: 1px solid var(--border); }
  .desktop-stat-row { display: flex; justify-content: space-between; font-size: 11px; color: var(--muted); margin-bottom: 4px; }
  .desktop-stat-val { color: var(--text); font-weight: 600; }
  /* Desktop right sidebar widgets */
  .desktop-widget-section { padding: 12px 14px 0; }
  .desktop-widget-title { font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; color: var(--muted); margin-bottom: 8px; }
  .desktop-widget-divider { height: 1px; background: var(--border); margin: 12px 0; }
}
@media (max-width: 767px) {
  .desktop-sidebar-left, .desktop-sidebar-right { display: none !important; }
  .desktop-center { display: contents; }
}

/* ── Compose Email Panel ───────────────────────────────────────────────── */
.compose-field { margin-bottom: 10px; }
.compose-field label { display: block; font-size: 11px; font-weight: 700; color: var(--muted); text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 4px; }
.compose-textarea { width: 100%; min-height: 150px; background: var(--bg); border: 1px solid var(--border); border-radius: 8px; padding: 10px 12px; color: var(--text); font-size: 13px; resize: vertical; font-family: inherit; line-height: 1.5; }
.compose-textarea:focus { border-color: var(--accent); outline: none; }
.compose-actions { display: flex; gap: 8px; justify-content: flex-end; margin-top: 12px; }
.compose-success { text-align: center; padding: 40px 20px; }
.compose-success-icon { font-size: 48px; margin-bottom: 12px; }
.compose-success-text { font-size: 16px; font-weight: 600; color: var(--green); }

/* ── Project Status Board ──────────────────────────────────────────────── */
.project-card { background: var(--surface); border: 1px solid var(--border); border-radius: 12px; padding: 14px; margin-bottom: 10px; }
.project-card-header { display: flex; align-items: center; gap: 10px; margin-bottom: 8px; }
.project-card-icon { font-size: 22px; }
.project-card-name { font-size: 14px; font-weight: 700; flex: 1; }
.project-card-owner { font-size: 10px; background: var(--surface2); border: 1px solid var(--border); border-radius: 4px; padding: 2px 6px; color: var(--muted); }
.project-status-chip { font-size: 11px; font-weight: 700; padding: 3px 10px; border-radius: 12px; cursor: pointer; border: none; transition: all 0.15s; }
.project-status-chip.on-track { background: rgba(52,211,153,0.15); color: var(--green); }
.project-status-chip.at-risk { background: rgba(251,146,60,0.15); color: var(--orange); }
.project-status-chip.blocked { background: rgba(248,113,113,0.15); color: var(--red); }
.project-status-chip.active { background: rgba(34,211,238,0.15); color: var(--accent); }
.project-progress-bar { height: 6px; background: var(--border); border-radius: 3px; margin: 8px 0 6px; overflow: hidden; }
.project-progress-fill { height: 100%; border-radius: 3px; transition: width 0.4s ease; }
.project-milestone { font-size: 12px; color: var(--muted); }
.project-card-actions { display: flex; gap: 6px; margin-top: 8px; }

/* ── Delegation Tracker ────────────────────────────────────────────────── */
.delegation-card { background: var(--surface); border: 1px solid var(--border); border-radius: 10px; padding: 12px; margin-bottom: 8px; }
.delegation-person { font-size: 13px; font-weight: 700; color: var(--accent); margin-bottom: 4px; }
.delegation-task { font-size: 13px; color: var(--text); margin-bottom: 4px; }
.delegation-meta { display: flex; gap: 8px; align-items: center; font-size: 11px; }
.delegation-status { padding: 2px 8px; border-radius: 10px; font-weight: 700; font-size: 11px; cursor: pointer; border: none; }
.delegation-status.pending { background: rgba(251,146,60,0.15); color: var(--orange); }
.delegation-status.done { background: rgba(52,211,153,0.15); color: var(--green); }
.delegation-status.overdue { background: rgba(248,113,113,0.15); color: var(--red); }
.delegation-add-form { padding: 12px 16px; background: var(--surface2); border-bottom: 1px solid var(--border); }

/* ── Chat Search Mode ──────────────────────────────────────────────────── */
.search-mode-bar { display: flex; gap: 8px; padding: 10px 16px; padding-bottom: calc(10px + var(--safe-bottom)); background: var(--surface); border-top: 1px solid var(--border); align-items: center; flex-shrink: 0; }
.search-mode-input { flex: 1; background: var(--surface2); border: 1px solid var(--accent); border-radius: 20px; padding: 10px 16px; color: var(--text); font-size: 14px; outline: none; font-family: inherit; }
.search-mode-input::placeholder { color: var(--muted); }
.search-result-bubble { max-width: 100%; padding: 10px 14px; border-radius: 12px; margin-bottom: 6px; font-size: 13px; line-height: 1.5; background: var(--surface2); border: 1px solid var(--border); }
.search-result-date { font-size: 10px; color: var(--muted); margin-bottom: 4px; }
.search-result-role { font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 2px; }
.search-result-role.user { color: var(--accent); }
.search-result-role.assistant { color: var(--accent2); }

/* ── File Drop Zone ────────────────────────────────────────────────────── */
.file-drop-overlay { position: absolute; inset: 0; background: rgba(34,211,238,0.08); border: 2px dashed var(--accent); border-radius: 12px; display: flex; align-items: center; justify-content: center; z-index: 10; pointer-events: none; }
.file-drop-text { font-size: 16px; font-weight: 700; color: var(--accent); }
.attached-file-badge { display: flex; align-items: center; gap: 6px; padding: 4px 10px; background: rgba(34,211,238,0.1); border: 1px solid rgba(34,211,238,0.3); border-radius: 8px; font-size: 12px; color: var(--accent); margin-bottom: 6px; }
.attached-file-remove { background: none; border: none; color: var(--red); cursor: pointer; font-size: 14px; padding: 0 2px; }

/* ── Contact Intel Accordion ───────────────────────────────────────────── */
.contact-intel { margin-top: 8px; background: var(--surface); border: 1px solid var(--border); border-radius: 8px; overflow: hidden; }
.contact-intel-header { display: flex; align-items: center; gap: 6px; padding: 8px 10px; cursor: pointer; font-size: 12px; font-weight: 600; color: var(--muted); transition: background 0.15s; }
.contact-intel-header:hover { background: var(--surface2); }
.contact-intel-body { padding: 8px 10px; border-top: 1px solid var(--border); font-size: 12px; color: var(--text); }
.contact-intel-row { display: flex; justify-content: space-between; margin-bottom: 4px; }
.contact-intel-label { color: var(--muted); }

/* ── Draft Reply Loading ───────────────────────────────────────────────── */
.draft-loading { display: flex; align-items: center; gap: 6px; padding: 8px 10px; font-size: 12px; color: var(--muted); }
.draft-textarea { width: 100%; min-height: 80px; background: var(--bg); border: 1px solid var(--border); border-radius: 8px; padding: 8px 10px; color: var(--text); font-size: 12px; resize: vertical; font-family: inherit; margin-top: 6px; }

/* ── Reminder Item ─────────────────────────────────────────────────────── */
.reminder-item { display: flex; align-items: flex-start; gap: 10px; padding: 10px 16px; border-bottom: 1px solid var(--border); }
.reminder-item-body { flex: 1; }
.reminder-title { font-size: 13px; color: var(--text); }
.reminder-due { font-size: 11px; margin-top: 2px; }
.reminder-due.overdue { color: var(--red); }
.reminder-due.upcoming { color: var(--orange); }
.reminder-list-badge { font-size: 10px; background: var(--surface2); border: 1px solid var(--border); border-radius: 4px; padding: 1px 5px; color: var(--muted); margin-top: 2px; display: inline-block; }

/* ── Apple Notes Sync ──────────────────────────────────────────────────── */
.apple-badge { font-size: 10px; margin-left: 4px; }

/* ── AI Floating Button Pulse ─────────────────────────────────────────── */
@keyframes ai-pulse {
  0%   { box-shadow: 0 0 0 0 rgba(34,211,238,0.4); }
  60%  { box-shadow: 0 0 0 8px rgba(34,211,238,0); }
  100% { box-shadow: 0 0 0 0 rgba(34,211,238,0); }
}

/* ── Executive Dashboard Shell ─────────────────────────────────────── */
.app-shell {
  display: flex; flex-direction: row; height: 100dvh; overflow: hidden;
  background: var(--bg);
}

/* Left Navigation */
.app-nav {
  width: 220px; flex-shrink: 0;
  background: var(--surface); border-right: 1px solid var(--border);
  display: flex; flex-direction: column; overflow: hidden;
  transition: width 200ms ease;
}
.app-nav-header {
  padding: calc(var(--safe-top) + 12px) 16px 12px;
  display: flex; align-items: center; gap: 10px;
  border-bottom: 1px solid var(--border); flex-shrink: 0;
}
.app-nav-logo { background: linear-gradient(135deg, var(--accent), var(--accent2)); color: #000; font-weight: 800; font-size: 13px; width: 30px; height: 30px; border-radius: 8px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
.app-nav-title { font-size: 16px; font-weight: 700; letter-spacing: -0.5px; white-space: nowrap; overflow: hidden; }
.app-nav-items { flex: 1; overflow-y: auto; padding: 8px 0; scrollbar-width: none; }
.app-nav-divider { height: 1px; background: var(--border); margin: 6px 12px; }
.nav-item {
  width: 100%; display: flex; align-items: center; gap: 10px;
  padding: 9px 14px; border: none; background: transparent;
  color: var(--muted); font-size: 13px; font-weight: 500;
  cursor: pointer; border-radius: 8px; margin: 1px 6px; width: calc(100% - 12px);
  text-align: left; transition: background 120ms, color 120ms; position: relative;
}
.nav-item:hover { background: var(--surface2); color: var(--text); }
.nav-item.active { background: rgba(34,211,238,0.1); color: var(--accent); }
.nav-item.active .nav-item-icon { color: var(--accent); }
.nav-item-icon { font-size: 16px; flex-shrink: 0; width: 20px; text-align: center; }
.nav-item-label { flex: 1; }
.nav-item-badge { background: var(--accent); color: #000; font-size: 10px; font-weight: 700; padding: 1px 5px; border-radius: 8px; min-width: 16px; text-align: center; }
.app-nav-footer { padding: 12px; border-top: 1px solid var(--border); flex-shrink: 0; }
.nav-status-row { display: flex; align-items: center; gap: 6px; font-size: 11px; color: var(--muted); }

/* Main Content Area */
.app-content {
  flex: 1; min-width: 0; overflow: hidden;
  display: flex; flex-direction: column;
  background: var(--bg);
}
.app-content-header {
  height: 52px; display: flex; align-items: center; justify-content: space-between;
  padding: 0 20px; border-bottom: 1px solid var(--border);
  background: var(--surface); flex-shrink: 0;
}
.app-content-title { font-size: 15px; font-weight: 600; color: var(--text); }
.app-content-actions { display: flex; align-items: center; gap: 8px; }
.app-content-body { flex: 1; overflow: hidden; display: flex; flex-direction: column; }

/* AI Sidebar */
.app-ai-sidebar {
  width: 320px; flex-shrink: 0;
  background: var(--surface); border-left: 1px solid var(--border);
  display: flex; flex-direction: column; overflow: hidden;
}
.app-ai-header {
  height: 52px; display: flex; align-items: center; gap: 8px;
  padding: 0 16px; border-bottom: 1px solid var(--border); flex-shrink: 0;
}
.app-ai-title { font-size: 13px; font-weight: 600; color: var(--text); flex: 1; }
.app-ai-context-badge {
  font-size: 10px; color: var(--accent); background: rgba(34,211,238,0.1);
  padding: 2px 8px; border-radius: 10px; font-weight: 500;
}
.app-ai-messages { flex: 1; overflow-y: auto; padding: 12px 14px; scroll-behavior: smooth; }
.app-ai-messages .chat-bubble { max-width: 100%; font-size: 13px; }
.app-ai-chips { padding: 8px 12px; display: flex; flex-direction: column; gap: 4px; border-top: 1px solid var(--border); }
.app-ai-chip {
  width: 100%; padding: 7px 10px; border: 1px solid var(--border);
  background: var(--surface2); color: var(--muted); font-size: 11px;
  border-radius: 8px; cursor: pointer; text-align: left;
  transition: border-color 120ms, color 120ms;
}
.app-ai-chip:hover { border-color: var(--accent); color: var(--accent); }
.app-ai-input-zone { padding: 10px 12px; border-top: 1px solid var(--border); flex-shrink: 0; }
.app-ai-input-row { display: flex; gap: 6px; align-items: flex-end; }
.app-ai-textarea {
  flex: 1; background: var(--surface2); border: 1px solid var(--border);
  border-radius: 10px; padding: 8px 12px; color: var(--text); font-size: 13px;
  font-family: inherit; resize: none; outline: none; max-height: 100px;
  overflow-y: auto; line-height: 1.4;
}
.app-ai-textarea:focus { border-color: var(--accent); }
.app-ai-send { width: 32px; height: 32px; border-radius: 8px; background: var(--accent); border: none; color: #000; cursor: pointer; font-size: 14px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
.app-ai-send:disabled { background: var(--surface2); color: var(--muted); cursor: default; }

/* Mobile nav bar (replaces tab-bar on mobile, hidden on desktop) */
.mobile-nav-bar {
  display: none; /* shown via media query */
  background: var(--surface); border-top: 1px solid var(--border);
  padding-bottom: var(--safe-bottom); flex-shrink: 0;
}
.mobile-nav-bar-items { display: flex; height: 56px; }
.mobile-nav-btn {
  flex: 1; display: flex; flex-direction: column; align-items: center;
  justify-content: center; gap: 2px; background: none; border: none;
  color: var(--muted); font-size: 11px; cursor: pointer; position: relative;
}
.mobile-nav-btn.active { color: var(--accent); }
.mobile-nav-btn-icon { font-size: 20px; line-height: 1; }
.mobile-nav-btn-label { font-size: 10px; font-weight: 500; }
.mobile-nav-badge { position: absolute; top: 6px; right: calc(50% - 18px); background: var(--accent); color: #000; font-size: 9px; font-weight: 700; padding: 1px 4px; border-radius: 6px; }

/* Mobile AI floating button */
.mobile-ai-fab {
  display: none; /* shown via media query */
  position: fixed; bottom: 72px; right: 16px; z-index: 900;
  width: 48px; height: 48px; border-radius: 50%;
  background: var(--bg); border: 1.5px solid var(--accent);
  color: var(--accent); font-size: 20px; cursor: pointer;
  align-items: center; justify-content: center;
  box-shadow: 0 4px 20px rgba(34,211,238,0.25);
  animation: ai-pulse 3s ease-in-out infinite;
}

/* Mobile: AI sidebar becomes a bottom sheet */
.app-ai-mobile-sheet {
  position: fixed; inset: 0; z-index: 800;
  background: rgba(0,0,0,0.5); display: none;
}
.app-ai-mobile-sheet.open { display: block; }
.app-ai-mobile-content {
  position: absolute; bottom: 0; left: 0; right: 0;
  height: 70dvh; background: var(--surface);
  border-radius: 16px 16px 0 0;
  display: flex; flex-direction: column;
}

/* Module view fills app-content-body */
.module-view { flex: 1; overflow: hidden; display: flex; flex-direction: column; }

/* Responsive breakpoints */
@media (max-width: 1023px) {
  .app-nav { width: 64px; }
  .app-nav-title { display: none; }
  .nav-item-label { display: none; }
  .app-nav-header { justify-content: center; padding: calc(var(--safe-top) + 12px) 0 12px; }
  .nav-item { justify-content: center; padding: 10px 0; margin: 1px 6px; width: calc(100% - 12px); }
  .nav-item-icon { width: auto; }
  .app-ai-sidebar { width: 280px; }
}
@media (max-width: 767px) {
  .app-nav { display: none; }
  .app-ai-sidebar { display: none; }
  .mobile-nav-bar { display: flex; flex-direction: column; }
  .mobile-ai-fab { display: flex; }
  .app-content-header { padding: calc(var(--safe-top) + 6px) 14px 6px; height: auto; min-height: 48px; }
}
/* Hide old chat-os classes when using app-shell */
.app-shell .chat-os-header { display: none; }
.app-shell .tab-bar { display: none !important; }
